name = "quien-sabe"
compatibility_date = "2024-02-01"
compatibility_flags = ["nodejs_compat"]

# ==============================================================================
# BASE DE DATOS D1
# ==============================================================================
# Para desarrollo local: "local-d1-binding"
# Para producción: ID real de Cloudflare (ej: xxxxx-xxxx-xxxx-xxxx-xxxxx)
[[d1_databases]]
binding = "DB"
database_name = "quien-sabe-db"
database_id = "local-d1-binding" 
migrations_dir = "src/database/migrations"

# ==============================================================================
# ALMACENAMIENTO R2 (Archivos)
# ==============================================================================
[[r2_buckets]]
binding = "BUCKET"
bucket_name = "quien-sabe-files"

# ==============================================================================
# KV (Sesiones / Cache)
# ==============================================================================
# Para desarrollo local: "local-kv-binding"
# Para producción: ID real de Cloudflare
[[kv_namespaces]]
binding = "SESSION"
id = "local-kv-binding"

# ==============================================================================
# VARIABLES DE ENTORNO PÚBLICAS
# ==============================================================================
# NO COLOCAR SECRETOS AQUÍ (Usar .env o `wrangler secret put`)
[vars]
ENVIRONMENT = "development"
PUBLIC_SITE_URL = "http://localhost:4321"
