---
import HeroTradeCard from './HeroTradeCard.astro';

interface Props {
  trades: Array<Record<string, unknown>>;
}

const { trades } = Astro.props;
const trackId = 'oficios-carousel';
---

{trades.length > 0 && (
<section class="carousel-section">
  <div class="carousel-inner">
    <div class="carousel-viewport">
      <button type="button" class="carousel-btn carousel-btn-prev" data-prev={trackId} aria-label="Anterior">
        <i class="ri-arrow-left-s-line" aria-hidden="true"></i>
      </button>

      <div class="carousel-track" id={trackId} role="list">
        {trades.map((trade) => (
          <div class="carousel-item" role="listitem">
            <HeroTradeCard trade={trade as any} />
          </div>
        ))}
      </div>

      <button type="button" class="carousel-btn carousel-btn-next" data-next={trackId} aria-label="Siguiente">
        <i class="ri-arrow-right-s-line" aria-hidden="true"></i>
      </button>
    </div>
  </div>
</section>
)}

<script>
  import { initCarousel } from '../../lib/client/home/carousel';
  initCarousel('oficios-carousel');
</script>

<style>
  .carousel-section {
    position: relative;
    z-index: 3;
    width: 100%;
    max-width: 64rem;
    margin: 1rem auto;
    padding: var(--space-3);
    background: var(--bg-card);
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-card);
  }

  .carousel-inner {
    padding-inline: 0;
  }

  .carousel-viewport {
    position: relative;
  }

  .carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 4;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: var(--radius-full);
    border: 1px solid var(--border-default);
    background: var(--bg-card);
    color: var(--text-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: var(--shadow-card);
    transition: background 150ms ease, color 150ms ease;
  }
  .carousel-btn-prev { left: -0.5rem; }
  .carousel-btn-next { right: -0.5rem; }
  .carousel-btn:hover { background: var(--amber-50); color: var(--color-primary-dark); }
  .carousel-btn:focus-visible { outline: 2px solid var(--border-focus); outline-offset: 2px; }

  .carousel-track {
    display: flex;
    align-items: stretch;
    gap: 1rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding-block: 0;
    scrollbar-width: none;
  }
  .carousel-track::-webkit-scrollbar { display: none; }

  /* cards SIEMPRE enteras (sin asomo) y del mismo tamaño: 1 en movil, 2 y 4 al crecer */
  .carousel-item {
    flex: 0 0 100%;
    display: flex;
    scroll-snap-align: start;
    scroll-snap-stop: always;
  }
  @media (min-width: 640px) { .carousel-item { flex-basis: calc((100% - 1rem) / 2); } }
  @media (min-width: 900px) { .carousel-item { flex-basis: calc((100% - 3rem) / 4); } }

  /* altura definida para evitar que el poster colapse dentro del flex del carrusel */
  .carousel-track :global(.hero-card) {
    height: 15rem;
    min-height: 0;
  }
</style>
