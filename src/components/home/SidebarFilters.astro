---
const { visible = false } = Astro.props;
---

<aside id="search-sidebar" class:list={["sidebar-wrapper", { hidden: !visible }]}>
  <div class="widget-card">
    <h3 class="sidebar-title">
      <i class="ri-filter-3-line" style="color: var(--amber-600)" aria-hidden="true"></i> Filtros
    </h3>

    <!-- Categories -->
    <div class="filter-section">
      <h4 class="filter-label" id="filter-oficio-label">Oficio</h4>
      <div class="filter-options" role="group" aria-labelledby="filter-oficio-label">
        <label class="filter-option" for="filter-oficio-gasfiter">
          <input type="checkbox" id="filter-oficio-gasfiter" class="filter-checkbox">
          <span class="filter-text">Gasfiter</span>
        </label>
        <label class="filter-option" for="filter-oficio-electricista">
          <input type="checkbox" id="filter-oficio-electricista" class="filter-checkbox">
          <span class="filter-text">Electricista</span>
        </label>
        <label class="filter-option" for="filter-oficio-jardinero">
          <input type="checkbox" id="filter-oficio-jardinero" class="filter-checkbox">
          <span class="filter-text">Jardinero</span>
        </label>
        <label class="filter-option" for="filter-oficio-maestro">
          <input type="checkbox" id="filter-oficio-maestro" class="filter-checkbox">
          <span class="filter-text">Maestro</span>
        </label>
      </div>
    </div>

    <!-- Price Range -->
    <div class="filter-section">
      <h4 class="filter-label">Precio Base</h4>
      <div class="price-inputs">
        <label class="sr-only" for="filter-price-min">Precio mínimo</label>
        <input type="number" id="filter-price-min" placeholder="Min" class="price-input">
        <span class="price-separator" aria-hidden="true">-</span>
        <label class="sr-only" for="filter-price-max">Precio máximo</label>
        <input type="number" id="filter-price-max" placeholder="Max" class="price-input">
      </div>
    </div>

    <!-- Rating -->
    <div class="filter-section">
      <h4 class="filter-label" id="filter-rating-label">Valoración</h4>
      <div class="filter-options" role="radiogroup" aria-labelledby="filter-rating-label">
        <label class="filter-option" for="filter-rating-5">
          <input type="radio" name="rating" id="filter-rating-5" class="filter-radio" aria-label="5 estrellas">
          <div class="rating-stars" aria-hidden="true">
            <i class="ri-star-fill"></i><i class="ri-star-fill"></i><i class="ri-star-fill"></i><i class="ri-star-fill"></i><i class="ri-star-fill"></i>
          </div>
        </label>
        <label class="filter-option" for="filter-rating-4">
          <input type="radio" name="rating" id="filter-rating-4" class="filter-radio" aria-label="4 estrellas y más">
          <div class="rating-stars" aria-hidden="true">
            <i class="ri-star-fill"></i><i class="ri-star-fill"></i><i class="ri-star-fill"></i><i class="ri-star-fill"></i><i class="ri-star-line"></i>
          </div>
          <span class="rating-more">& más</span>
        </label>
      </div>
    </div>
  </div>

  <!-- Promo Box -->
  <div class="promo-card">
    <div class="promo-icon">
      <i class="ri-shield-star-line" aria-hidden="true"></i>
    </div>
    <h4 class="promo-title">Vecinos Verificados</h4>
    <p class="promo-text">Contrata con confianza.</p>
    <button type="button" class="promo-btn">Saber más</button>
  </div>
</aside>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .sidebar-wrapper {
    width: 100%;
  }

  @media (min-width: 1024px) {
    .sidebar-wrapper {
      width: 280px;
      flex-shrink: 0;
    }
  }

  .sidebar-wrapper.hidden {
    display: none !important;
  }

  .widget-card {
    background: var(--bg-card);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-card);
    border: 1px solid var(--border-default);
    padding: var(--space-6);
    transition: box-shadow 300ms ease;
  }

  .widget-card:hover {
    box-shadow: var(--shadow-card-hover);
  }

  .sidebar-title {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--space-5);
  }

  .filter-section {
    margin-bottom: var(--space-5);
  }

  .filter-section:last-child {
    margin-bottom: 0;
  }

  .filter-label {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    margin-bottom: var(--space-3);
  }

  .filter-options {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .filter-option {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    cursor: pointer;
    transition: color 200ms ease;
  }

  .filter-option:hover {
    color: var(--amber-600);
  }

  .filter-checkbox,
  .filter-radio {
    width: 1rem;
    height: 1rem;
    border-radius: var(--radius-sm);
    border: 2px solid var(--border-default);
    accent-color: var(--amber-600);
    cursor: pointer;
  }

  .filter-checkbox:focus-visible,
  .filter-radio:focus-visible,
  .price-input:focus-visible,
  .promo-btn:focus-visible {
    outline: 2px solid var(--border-focus);
    outline-offset: 2px;
  }

  .filter-text {
    font-size: 0.875rem;
    color: var(--slate-600);
  }

  .price-inputs {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .price-input {
    flex: 1;
    background: var(--slate-50);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-md);
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    transition: all 200ms ease;
  }

  .price-input:focus {
    outline: none;
    border-color: var(--amber-400);
    box-shadow: 0 0 0 3px var(--amber-50);
  }

  .price-separator {
    color: var(--slate-300);
  }

  .rating-stars {
    display: flex;
    gap: 2px;
    color: var(--amber-400);
    font-size: 0.875rem;
  }

  .rating-more {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-left: 0.25rem;
  }

  /* Promo Card */
  .promo-card {
    background: linear-gradient(135deg, var(--amber-600) 0%, var(--orange-700) 100%);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    text-align: center;
    box-shadow: var(--shadow-card-hover);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .promo-icon {
    width: 3rem;
    height: 3rem;
    border-radius: var(--radius-xl);
    background: rgba(255, 255, 255, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto var(--space-3);
  }

  .promo-icon i {
    font-size: 1.5rem;
    color: white;
    opacity: 0.9;
  }

  .promo-title {
    font-size: 1rem;
    font-weight: 700;
    color: white;
    margin-bottom: var(--space-1);
  }

  .promo-text {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: var(--space-4);
  }

  .promo-btn {
    background: white;
    color: var(--amber-700);
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.5rem 1.25rem;
    border-radius: var(--radius-full);
    border: none;
    cursor: pointer;
    transition: all 200ms ease;
    box-shadow: var(--shadow-card);
  }

  .promo-btn:hover {
    background: var(--cream-200);
    transform: translateY(-1px);
    box-shadow: var(--shadow-card-hover);
  }
</style>
