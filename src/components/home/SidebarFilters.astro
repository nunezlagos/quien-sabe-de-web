---
interface FilterState {
  q?: string;
  tradeName?: string;
  communeName?: string;
  availableNow?: boolean;
  verified?: boolean;
  priceMin?: number;
  priceMax?: number;
}
const { filters = {} } = Astro.props as { filters?: FilterState };
---

<aside id="search-sidebar" class="sidebar-wrapper">
  <form id="filters-form" class="widget-card">
    <h3 class="sidebar-title">
      <i class="ri-filter-3-line" style="color: var(--amber-600)" aria-hidden="true"></i> Filtros
    </h3>

    <!-- Price Range -->
    <div class="filter-section">
      <h4 class="filter-label">Precio base (CLP)</h4>
      <div class="price-inputs">
        <label class="sr-only" for="filter-price-min">Precio mínimo</label>
        <input type="number" id="filter-price-min" name="price_min" placeholder="Min" class="price-input" min="0" step="1000" value={filters.priceMin ?? ''}>
        <span class="price-separator" aria-hidden="true">–</span>
        <label class="sr-only" for="filter-price-max">Precio máximo</label>
        <input type="number" id="filter-price-max" name="price_max" placeholder="Max" class="price-input" min="0" step="1000" value={filters.priceMax ?? ''}>
      </div>
    </div>

    <!-- Toggles -->
    <div class="filter-section">
      <h4 class="filter-label">Disponibilidad</h4>
      <div class="filter-options">
        <label class="filter-option" for="filter-available">
          <input type="checkbox" id="filter-available" name="available_now" class="filter-checkbox" checked={filters.availableNow}>
          <span class="filter-text">Disponible ahora</span>
        </label>
        <label class="filter-option" for="filter-verified">
          <input type="checkbox" id="filter-verified" name="verified" class="filter-checkbox" checked={filters.verified}>
          <span class="filter-text">Solo verificados</span>
        </label>
      </div>
    </div>

    <div class="filter-actions">
      <button type="submit" class="filter-apply">Aplicar filtros</button>
      <a href="/" class="filter-clear">Limpiar</a>
    </div>
  </form>

  <!-- Promo Box -->
  <div class="promo-card">
    <div class="promo-icon">
      <i class="ri-verified-badge-fill" aria-hidden="true"></i>
    </div>
    <h4 class="promo-title">Vecinos Verificados</h4>
    <p class="promo-text">Contrata con confianza.</p>
    <button type="button" id="verified-modal-btn" class="promo-btn">Saber más</button>
  </div>

  <div id="verified-modal" class="verified-modal hidden" role="dialog" aria-modal="true" aria-labelledby="verified-modal-title" aria-hidden="true">
    <div class="verified-backdrop close-verified"></div>
    <div class="verified-card">
      <button type="button" class="verified-close close-verified" aria-label="Cerrar">
        <i class="ri-close-line" aria-hidden="true"></i>
      </button>
      <div class="verified-modal-icon">
        <i class="ri-verified-badge-fill" aria-hidden="true"></i>
      </div>
      <h2 id="verified-modal-title" class="verified-modal-title">Vecinos Verificados</h2>
      <p class="verified-modal-desc">
        El sello <strong>Verificado</strong> indica que revisamos la identidad y los antecedentes del vecino antes de mostrarlo. Así contratas con más confianza.
      </p>
      <ul class="verified-modal-list">
        <li><i class="ri-checkbox-circle-fill" aria-hidden="true"></i> Identidad validada</li>
        <li><i class="ri-checkbox-circle-fill" aria-hidden="true"></i> Documentos y oficio revisados</li>
        <li><i class="ri-checkbox-circle-fill" aria-hidden="true"></i> Reputación de la comunidad</li>
      </ul>
    </div>
  </div>
</aside>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .sidebar-wrapper {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  @media (min-width: 1024px) {
    .sidebar-wrapper {
      width: 280px;
      flex-shrink: 0;
    }
  }

  .sidebar-wrapper.hidden {
    display: none !important;
  }

  .widget-card {
    background: var(--bg-card);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-card);
    border: 1px solid var(--border-default);
    padding: var(--space-6);
    transition: box-shadow 300ms ease;
  }

  .widget-card:hover {
    box-shadow: var(--shadow-card-hover);
  }

  .sidebar-title {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--space-5);
  }

  .filter-section {
    margin-bottom: var(--space-5);
  }

  .filter-actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .filter-apply {
    flex: 1;
    padding: 0.6rem 1rem;
    font-size: 0.875rem;
    font-weight: 700;
    color: white;
    background: linear-gradient(135deg, var(--orange-500) 0%, var(--orange-600) 100%);
    border: none;
    border-radius: var(--radius-lg);
    cursor: pointer;
    box-shadow: var(--shadow-btn);
    transition: transform 200ms ease, box-shadow 200ms ease;
  }

  .filter-apply:hover {
    transform: translateY(-1px);
    box-shadow: var(--shadow-card-hover);
  }

  .filter-apply:focus-visible {
    outline: 2px solid var(--border-focus);
    outline-offset: 2px;
  }

  .filter-clear {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--text-muted);
    text-decoration: underline;
  }

  .filter-clear:hover {
    color: var(--amber-600);
  }

  .filter-label {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    margin-bottom: var(--space-3);
  }

  .filter-options {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .filter-option {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    cursor: pointer;
    transition: color 200ms ease;
  }

  .filter-option:hover {
    color: var(--amber-600);
  }

  .filter-checkbox,
  .filter-radio {
    width: 1rem;
    height: 1rem;
    border-radius: var(--radius-sm);
    border: 2px solid var(--border-default);
    accent-color: var(--amber-600);
    cursor: pointer;
  }

  .filter-checkbox:focus-visible,
  .filter-radio:focus-visible,
  .price-input:focus-visible,
  .promo-btn:focus-visible {
    outline: 2px solid var(--border-focus);
    outline-offset: 2px;
  }

  .filter-text {
    font-size: 0.875rem;
    color: var(--slate-600);
  }

  .price-inputs {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .price-input {
    width: 100%;
    box-sizing: border-box;
    background: var(--slate-50);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-md);
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    transition: all 200ms ease;
  }

  .price-input:focus {
    outline: none;
    border-color: var(--amber-400);
    box-shadow: 0 0 0 3px var(--amber-50);
  }

  .price-separator {
    display: none;
  }

  .rating-stars {
    display: flex;
    gap: 2px;
    color: var(--amber-400);
    font-size: 0.875rem;
  }

  .rating-more {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-left: 0.25rem;
  }

  /* Promo Card */
  .promo-card {
    background: linear-gradient(135deg, var(--amber-600) 0%, var(--orange-700) 100%);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    text-align: center;
    box-shadow: var(--shadow-card-hover);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .promo-icon {
    width: 3rem;
    height: 3rem;
    border-radius: var(--radius-xl);
    background: rgba(255, 255, 255, 0.95);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto var(--space-3);
  }

  .promo-icon i {
    font-size: 1.5rem;
    color: var(--green-500);
  }

  /* ocultar la promo en móvil (solo filtros al desplegar) */
  @media (max-width: 899px) {
    .promo-card {
      display: none;
    }
  }

  .promo-title {
    font-size: 1rem;
    font-weight: 700;
    color: white;
    margin-bottom: var(--space-1);
  }

  .promo-text {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: var(--space-4);
  }

  .promo-btn {
    background: white;
    color: var(--amber-700);
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.5rem 1.25rem;
    border-radius: var(--radius-full);
    border: none;
    cursor: pointer;
    transition: all 200ms ease;
    box-shadow: var(--shadow-card);
  }

  .promo-btn:hover {
    background: var(--cream-200);
    transform: translateY(-1px);
    box-shadow: var(--shadow-card-hover);
  }

  /* === MODAL VECINOS VERIFICADOS === */
  .verified-modal {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }

  .verified-modal.hidden {
    display: none;
  }

  .verified-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(41, 37, 36, 0.55);
    backdrop-filter: blur(2px);
  }

  .verified-card {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 26rem;
    background: white;
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-card-hover);
    padding: var(--space-6);
    text-align: center;
  }

  .verified-close {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    width: 2rem;
    height: 2rem;
    border-radius: var(--radius-full);
    border: 1px solid var(--border-default);
    background: white;
    color: var(--text-secondary);
    cursor: pointer;
    font-size: 1.1rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .verified-close:hover {
    background: var(--stone-50);
    color: var(--text-primary);
  }

  .verified-modal-icon {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: var(--radius-full);
    background: var(--green-50);
    color: var(--green-500);
    font-size: 1.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto var(--space-3);
  }

  .verified-modal-title {
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--text-primary);
    margin-bottom: var(--space-2);
  }

  .verified-modal-desc {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-4);
  }

  .verified-modal-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    text-align: left;
  }

  .verified-modal-list li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .verified-modal-list i {
    color: var(--green-500);
    font-size: 1.1rem;
  }
</style>
