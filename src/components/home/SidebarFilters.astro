---
const { visible = false } = Astro.props;
const hiddenClass = visible ? '' : 'hidden';
---

<aside id="search-sidebar" class="{hiddenClass} md:w-1/4 space-y-5 w-full animate-fade-in-left">
  <div class="card-sidebar">
    <h3 class="font-bold text-slate-800 mb-5 flex items-center gap-2"><i class="ri-filter-3-line text-primary"></i> Filtros</h3>

    <!-- Categories -->
    <div class="mb-6">
      <h4 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-3">Oficio</h4>
      <div class="space-y-2">
        <label class="flex items-center gap-2.5 cursor-pointer hover:text-green-primary transition">
          <input type="checkbox" class="rounded text-primary focus:ring-primary border-slate-300 w-4 h-4">
          <span class="text-sm text-slate-600">Gasfiter</span>
        </label>
        <label class="flex items-center gap-2.5 cursor-pointer hover:text-green-primary transition">
          <input type="checkbox" class="rounded text-primary focus:ring-primary border-slate-300 w-4 h-4">
          <span class="text-sm text-slate-600">Electricista</span>
        </label>
        <label class="flex items-center gap-2.5 cursor-pointer hover:text-green-primary transition">
          <input type="checkbox" class="rounded text-primary focus:ring-primary border-slate-300 w-4 h-4">
          <span class="text-sm text-slate-600">Jardinero</span>
        </label>
        <label class="flex items-center gap-2.5 cursor-pointer hover:text-green-primary transition">
          <input type="checkbox" class="rounded text-primary focus:ring-primary border-slate-300 w-4 h-4">
          <span class="text-sm text-slate-600">Maestro</span>
        </label>
      </div>
    </div>

    <!-- Price Range -->
    <div class="mb-6">
      <h4 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-3">Precio Base</h4>
      <div class="flex items-center gap-2">
        <input type="number" placeholder="Min" class="w-full bg-slate-50 border border-slate-200 rounded-lg px-3 py-2 text-sm focus:border-green-primary focus:ring-1 focus:ring-green-primary/20 transition">
        <span class="text-slate-300">-</span>
        <input type="number" placeholder="Max" class="w-full bg-slate-50 border border-slate-200 rounded-lg px-3 py-2 text-sm focus:border-green-primary focus:ring-1 focus:ring-green-primary/20 transition">
      </div>
    </div>

    <!-- Rating -->
    <div>
      <h4 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-3">Valoración</h4>
      <div class="space-y-2">
        <label class="flex items-center gap-2.5 cursor-pointer hover:text-green-primary transition">
          <input type="radio" name="rating" class="text-primary focus:ring-primary border-slate-300 w-4 h-4">
          <div class="flex text-yellow-400 text-sm gap-0.5">
            <i class="ri-star-fill"></i><i class="ri-star-fill"></i><i class="ri-star-fill"></i><i class="ri-star-fill"></i><i class="ri-star-fill"></i>
          </div>
        </label>
        <label class="flex items-center gap-2.5 cursor-pointer hover:text-green-primary transition">
          <input type="radio" name="rating" class="text-primary focus:ring-primary border-slate-300 w-4 h-4">
          <div class="flex text-yellow-400 text-sm gap-0.5">
            <i class="ri-star-fill"></i><i class="ri-star-fill"></i><i class="ri-star-fill"></i><i class="ri-star-fill"></i><i class="ri-star-line"></i>
          </div>
          <span class="text-xs text-slate-400">& más</span>
        </label>
      </div>
    </div>
  </div>

  <!-- Promo Box -->
  <div class="card-promo">
    <div class="w-12 h-12 rounded-xl bg-white/20 flex items-center justify-center mx-auto mb-3">
      <i class="ri-shield-star-line text-3xl text-white opacity-90"></i>
    </div>
    <h4 class="font-bold text-lg mb-1 text-white">Vecinos Verificados</h4>
    <p class="text-xs opacity-90 mb-5 text-white/80">Contrata con confianza.</p>
    <button class="bg-white text-green-primary text-xs font-bold px-5 py-2.5 rounded-full hover:bg-green-50 transition shadow-md">Saber más</button>
  </div>
</aside>

<style>
  .card-sidebar {
    background: white;
    border-radius: 1rem;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.07), 0 2px 4px -2px rgba(0, 0, 0, 0.05);
    border: 1px solid #e2e8f0;
    padding: 1.5rem;
    transition: box-shadow 300ms ease;
  }

  .card-sidebar:hover {
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.08), 0 4px 6px -4px rgba(0, 0, 0, 0.05);
  }

  .card-promo {
    background: linear-gradient(135deg, #2e8b57 0%, #166534 100%);
    border-radius: 1rem;
    padding: 1.75rem 1.5rem;
    text-align: center;
    box-shadow: 0 10px 15px -3px rgba(46, 139, 87, 0.3), 0 4px 6px -4px rgba(0, 0, 0, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }
</style>
