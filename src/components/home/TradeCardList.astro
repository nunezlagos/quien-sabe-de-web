---
interface Trade {
  name: string;
  slug: string;
  userName: string | null;
  description: string | null;
  symbol: string | null;
  basePriceClp: number | null;
  communeName: string | null;
  verified: number | boolean;
  rating: number | null;
}

const { trade } = Astro.props as { trade: Trade };
const initials = (trade.userName ?? '?').slice(0, 2).toUpperCase();
const precio = (trade.basePriceClp ?? 0).toLocaleString('es-CL');
const rating = trade.rating ?? 0;

function renderStars(r: number): string {
  const full = Math.floor(r);
  let s = '';
  for (let i = 1; i <= 5; i++) {
    if (i <= full) s += '<i class="ri-star-fill"></i>';
    else if (i - 0.5 <= r) s += '<i class="ri-star-half-fill"></i>';
    else s += '<i class="ri-star-line text-slate-300"></i>';
  }
  return s;
}
---

<article class="card-listitem group flex flex-col md:flex-row h-full">
  <div class="p-5 md:w-1/5 flex flex-col items-center justify-center bg-gradient-to-b from-slate-50 to-warm-50 border-b md:border-b-0 md:border-r border-slate-100">
    <div class="w-16 h-16 rounded-2xl bg-white shadow-md flex items-center justify-center text-primary font-bold text-2xl mb-3 group-hover:scale-105 transition duration-300 border-2 border-white overflow-hidden relative flex-shrink-0">
      <div class="w-full h-full bg-gradient-to-br from-green-100 to-green-50 flex items-center justify-center text-green-primary font-bold text-3xl rounded-xl">
        {initials}
      </div>
    </div>
    {trade.verified ? (
    <span class="text-[10px] font-semibold text-blue-600 bg-blue-50 px-2 py-0.5 rounded-full border border-blue-100 flex items-center gap-1 mb-2">
      <i class="ri-shield-check-fill"></i> Verificado
    </span>
    ) : null}
    <div class="text-xs text-yellow-400 text-center mb-2 flex gap-0.5" set:html={renderStars(rating)}>
    </div>
  </div>

  <div class="p-6 flex-grow flex flex-col justify-center">
    <div class="flex flex-col sm:flex-row justify-between items-start mb-3 gap-3">
      <div>
        <h3 class="font-bold text-lg text-slate-800 leading-tight break-words group-hover:text-green-primary transition font-display">{trade.name}</h3>
        {trade.communeName ? (
        <span class="text-xs text-slate-400 flex items-center gap-1 mt-1">
          <i class="ri-map-pin-line"></i> <span>{trade.communeName}</span>
        </span>
        ) : null}
      </div>
      <div class="flex flex-col items-end gap-1.5">
        <span class="text-[10px] font-bold uppercase text-white bg-green-primary px-2.5 py-1 rounded-lg border border-green-700 tracking-wider leading-normal">
          {trade.symbol ?? 'Oficio'}
        </span>
      </div>
    </div>
    <p class="text-slate-500 text-sm mb-4 line-clamp-2 leading-relaxed">
      {trade.description ?? 'Servicio profesional disponible en tu barrio.'}
    </p>
    <div class="flex flex-wrap gap-2">
      <span class="text-xs bg-slate-100 text-slate-600 px-3 py-1 rounded-lg font-medium whitespace-nowrap border border-slate-200">{trade.symbol ?? 'General'}</span>
    </div>
  </div>

  <div class="p-6 md:w-1/4 flex flex-col justify-center items-center gap-3 border-t md:border-t-0 md:border-l border-slate-100 bg-gradient-to-b from-slate-50/50 to-warm-50/50">
    <div class="text-center mb-1">
      <span class="text-[10px] text-slate-400 block uppercase tracking-wide font-semibold">Precio Base</span>
      <span class="text-xl font-extrabold text-slate-800">${precio}</span>
    </div>
    <div class="w-full space-y-2 mt-auto">
      <a
        href={`/p/${trade.slug}`}
        class="w-full bg-gradient-to-r from-green-primary to-green-dark text-white py-2.5 rounded-xl font-bold hover:from-green-dark hover:to-green-primary transition text-center text-sm flex items-center justify-center gap-2 shadow-md hover:shadow-lg"
        target="_blank"
      >
        <i class="ri-whatsapp-line"></i> Contactar
      </a>
      <a
        href={`/p/${trade.slug}`}
        class="w-full bg-white border-2 border-slate-200 text-slate-600 py-2.5 rounded-xl font-bold hover:border-green-primary hover:text-green-primary transition text-center text-sm flex items-center justify-center gap-2 hover:bg-green-50"
      >
        <i class="ri-eye-line"></i> Ver Perfil
      </a>
    </div>
  </div>
</article>

<style>
  .card-listitem {
    background: white;
    border-radius: 1rem;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.07), 0 2px 4px -2px rgba(0, 0, 0, 0.05);
    border: 1px solid #e2e8f0;
    transition: box-shadow 300ms ease, transform 200ms ease;
    overflow: hidden;
  }

  .card-listitem:hover {
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.08), 0 4px 6px -4px rgba(0, 0, 0, 0.05);
    transform: translateY(-2px);
  }

  .font-display {
    font-family: 'Nunito', sans-serif;
  }
</style>
