---
interface Trade {
  name: string;
  slug: string;
  userName: string | null;
  description: string | null;
  symbol: string | null;
  basePriceClp: number | null;
  communeName: string | null;
  verified: number | boolean;
  rating: number | null;
}

const { trade } = Astro.props as { trade: Trade };
const initials = (trade.userName ?? '?').slice(0, 2).toUpperCase();
const precio = (trade.basePriceClp ?? 0).toLocaleString('es-CL');
const rating = trade.rating ?? 0;

function renderStars(r: number): string {
  const full = Math.floor(r);
  let s = '';
  for (let i = 1; i <= 5; i++) {
    if (i <= full) s += '<i class="ri-star-fill"></i>';
    else if (i - 0.5 <= r) s += '<i class="ri-star-half-fill"></i>';
    else s += '<i class="ri-star-line"></i>';
  }
  return s;
}
---

<article class="card-list">
  <div class="list-avatar-section">
    <div class="avatar-inner">
      {initials}
    </div>
    {trade.verified ? (
    <span class="badge-verified">
      <i class="ri-shield-check-fill"></i>
    </span>
    ) : null}
    <div class="stars" set:html={renderStars(rating)}></div>
  </div>

  <div class="list-content">
    <div class="list-header">
      <div>
        <h3 class="list-title">{trade.name}</h3>
        {trade.communeName ? (
        <span class="location"><i class="ri-map-pin-line"></i> {trade.communeName}</span>
        ) : null}
      </div>
      <div class="list-meta">
        <span class="badge-trade">{trade.symbol ?? 'Oficio'}</span>
      </div>
    </div>
    <p class="list-description">{trade.description ?? 'Servicio profesional disponible en tu barrio.'}</p>
    <div class="list-tags">
      <span class="tag">{trade.symbol ?? 'General'}</span>
    </div>
  </div>

  <div class="list-action">
    <div class="price-block">
      <span class="price-label">Precio Base</span>
      <span class="price-value">${precio}</span>
    </div>
    <div class="action-buttons">
      <a href={`/p/${trade.slug}`} class="btn-whatsapp-list">
        <i class="ri-whatsapp-line"></i> Contactar
      </a>
      <a href={`/p/${trade.slug}`} class="btn-view-list">
        <i class="ri-eye-line"></i> Ver Perfil
      </a>
    </div>
  </div>
</article>

<style>
  .card-list {
    background: var(--bg-card);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-card);
    border: 1px solid var(--border-default);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: box-shadow 300ms ease, transform 200ms ease;
  }

  .card-list:hover {
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-2px);
  }

  @media (min-width: 768px) {
    .card-list {
      flex-direction: row;
    }
  }

  .list-avatar-section {
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: var(--bg-warm);
    border-bottom: 1px solid var(--border-light);
    min-width: 140px;
  }

  @media (min-width: 768px) {
    .list-avatar-section {
      border-bottom: none;
      border-right: 1px solid var(--border-light);
      min-width: 160px;
    }
  }

  .avatar-inner {
    width: 4rem;
    height: 4rem;
    border-radius: var(--radius-lg);
    background: linear-gradient(135deg, var(--green-100) 0%, var(--green-50) 100%);
    border: 2px solid white;
    box-shadow: var(--shadow-card);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--green-600);
    margin-bottom: var(--space-2);
    transition: transform 200ms ease;
  }

  .card-list:hover .avatar-inner {
    transform: scale(1.05);
  }

  .badge-verified {
    font-size: 0.625rem;
    color: var(--slate-500);
    margin-bottom: var(--space-2);
  }

  .stars {
    display: flex;
    gap: 2px;
    color: #fbbf24;
    font-size: 0.75rem;
  }

  .list-content {
    padding: var(--space-6);
    flex-grow: 1;
  }

  .list-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: var(--space-3);
    gap: var(--space-3);
  }

  .list-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.3;
    margin-bottom: var(--space-1);
    transition: color 200ms ease;
  }

  .card-list:hover .list-title {
    color: var(--green-600);
  }

  .location {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .list-meta {
    flex-shrink: 0;
  }

  .badge-trade {
    display: inline-block;
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: var(--green-600);
    color: white;
    padding: 0.25rem 0.625rem;
    border-radius: var(--radius-md);
  }

  .list-description {
    color: var(--text-secondary);
    font-size: 0.875rem;
    line-height: 1.6;
    margin-bottom: var(--space-4);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .list-tags .tag {
    font-size: 0.75rem;
    background: var(--slate-100);
    color: var(--slate-600);
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-md);
    font-weight: 500;
    border: 1px solid var(--slate-200);
  }

  .list-action {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    border-top: 1px solid var(--border-light);
    min-width: 180px;
    background: var(--bg-warm);
  }

  @media (min-width: 768px) {
    .list-action {
      border-top: none;
      border-left: 1px solid var(--border-light);
    }
  }

  .price-block {
    text-align: center;
  }

  .price-label {
    display: block;
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    margin-bottom: 0.25rem;
  }

  .price-value {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--text-primary);
  }

  .action-buttons {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    width: 100%;
  }

  .btn-whatsapp-list {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    background: var(--green-600);
    color: white;
    font-size: 0.875rem;
    font-weight: 700;
    padding: 0.625rem 1rem;
    border-radius: var(--radius-lg);
    transition: all 200ms ease;
    box-shadow: var(--shadow-card);
  }

  .btn-whatsapp-list:hover {
    background: var(--green-700);
    box-shadow: var(--shadow-card-hover);
  }

  .btn-view-list {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    background: white;
    color: var(--slate-600);
    font-size: 0.875rem;
    font-weight: 700;
    padding: 0.625rem 1rem;
    border-radius: var(--radius-lg);
    border: 2px solid var(--border-default);
    transition: all 200ms ease;
  }

  .btn-view-list:hover {
    border-color: var(--green-400);
    color: var(--green-600);
    background: var(--green-50);
  }
</style>
