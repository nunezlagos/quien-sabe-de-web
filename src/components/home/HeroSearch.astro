---
export interface Props {
  q: string;
  communeId?: number;
  communes: { id: number; name: string }[];
  trades: { name: string; slug: string }[];
}

const { q, communeId, communes, trades } = Astro.props;
---

<header id="hero-section" class="hero-section">
  <div class="container">
    <h1 class="hero-title">
      ¿Quién sabe de un <span id="dynamic-trade" class="dynamic-trade">Gasfiter</span>?
    </h1>
    <p class="hero-desc">
      Conecta con vecinos talentosos en tu barrio. Rápido, confiable y cercano.
    </p>

    <div class="hero-notice">
      <i class="ri-megaphone-fill"></i> ¡Oferta! Publica tu oficio GRATIS por tiempo limitado
    </div>

    <div id="hero-search-container" class="search-container">
      <div class="search-field">
        <i class="ri-briefcase-line search-icon"></i>
        <select id="trade-select" class="search-select">
          <option value="">Todos los oficios</option>
          {trades.map((t) => (
            <option value={t.name}>{t.name}</option>
          ))}
        </select>
      </div>

      <div class="search-divider"></div>

      <div class="search-field">
        <i class="ri-map-pin-line search-icon"></i>
        <select id="commune-select" class="search-select">
          <option value="">Todas las comunas</option>
          {communes.map((c) => (
            <option value={c.name} selected={communeId === c.id}>{c.name}</option>
          ))}
        </select>
      </div>

      <div class="search-divider"></div>

      <div class="search-field search-field-keyword">
        <i class="ri-search-line search-icon"></i>
        <input
          type="text"
          id="search-input"
          value={q}
          list="search-suggestions"
          autocomplete="off"
          class="search-input"
          placeholder="Palabra clave (ej: instalación, reparación...)"
        />
        <datalist id="search-suggestions">
          {trades.map((t) => (
            <option value={t.name} />
          ))}
          <option value="Instalación" />
          <option value="Reparación" />
          <option value="Mantención" />
          <option value="Urgente" />
          <option value="Presupuesto" />
        </datalist>
      </div>

      <label class="search-available">
        <input type="checkbox" name="available_now" class="search-checkbox">
        <span>Disponible ahora</span>
      </label>

      <button id="search-btn" class="search-btn">
        Buscar
      </button>
    </div>
  </div>
</header>

<style>
  .hero-section {
    background: var(--cream-200);
    padding: 2rem 1rem;
    position: relative;
    transition: padding 300ms ease;
  }

  .hero-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23d97706' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    pointer-events: none;
  }

  /* Collapsed state (triggered by #hero-section-wrapper.hero-collapsed) */
  :global(#hero-section-wrapper.hero-collapsed) .hero-section {
    padding: 0.5rem 1rem;
  }

  :global(#hero-section-wrapper.hero-collapsed) .hero-title,
  :global(#hero-section-wrapper.hero-collapsed) .hero-desc,
  :global(#hero-section-wrapper.hero-collapsed) .hero-notice {
    display: none;
  }

  :global(#hero-section-wrapper.hero-collapsed) .search-container {
    padding: 0.25rem;
    gap: 0.25rem;
  }

  :global(#hero-section-wrapper.hero-collapsed) .search-btn {
    padding: 0.4rem 0.75rem;
    font-size: 0.8125rem;
  }

  .container {
    max-width: 80rem;
    margin: 0 auto;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .hero-title {
    font-size: 2rem;
    font-weight: 800;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
    letter-spacing: -0.03em;
    line-height: 1.2;
    transition: font-size 300ms ease;
  }

  @media (min-width: 768px) {
    .hero-title {
      font-size: 2.75rem;
    }
  }

  .dynamic-trade {
    color: var(--amber-600);
    display: inline-block;
    min-width: 12rem;
    text-align: left;
  }

  .hero-desc {
    color: var(--text-secondary);
    font-size: 1rem;
    max-width: 36rem;
    margin: 0 auto 1.5rem;
    font-weight: 500;
    line-height: 1.5;
    transition: all 300ms ease;
  }

  @media (min-width: 768px) {
    .hero-desc {
      font-size: 1.125rem;
    }
  }

  .hero-notice {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--amber-50);
    color: var(--amber-700);
    padding: 0.5rem 1rem;
    border-radius: var(--radius-lg);
    font-size: 0.75rem;
    font-weight: 700;
    border: 1px solid var(--amber-200);
    margin-bottom: 1.5rem;
    box-shadow: var(--shadow-card);
    transition: all 300ms ease;
  }

  .hero-notice i {
    font-size: 1rem;
  }

  .search-container {
    background: white;
    padding: 0.5rem;
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-card-hover);
    border: 1px solid var(--border-light);
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    max-width: 64rem;
    margin: 0 auto;
    transition: all 300ms ease;
  }

  @media (min-width: 768px) {
    .search-container {
      flex-direction: row;
      align-items: center;
      padding: 0.5rem;
      gap: 0.25rem;
    }
  }

  .search-field {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex: 1;
    min-width: 120px;
    position: relative;
    padding: 0 0.5rem;
  }

  .search-field-keyword {
    flex: 1.5;
  }

  .search-icon {
    font-size: 1.125rem;
    color: var(--text-muted);
    position: absolute;
    left: 0.875rem;
    pointer-events: none;
  }

  .search-select,
  .search-input {
    width: 100%;
    padding: 0.625rem 0.5rem 0.625rem 2.25rem;
    font-size: 0.875rem;
    color: var(--text-primary);
    background: transparent;
    border: none;
    border-radius: var(--radius-lg);
    cursor: pointer;
    font-weight: 600;
    transition: background 200ms ease;
    appearance: none;
  }

  .search-select:hover,
  .search-input:hover {
    background: var(--stone-50);
  }

  .search-select:focus,
  .search-input:focus {
    outline: none;
    background: var(--amber-50);
    border-radius: var(--radius-lg);
  }

  .search-divider {
    display: none;
    width: 1px;
    height: 2rem;
    background: var(--border-default);
    flex-shrink: 0;
  }

  @media (min-width: 768px) {
    .search-divider {
      display: block;
    }
  }

  .search-available {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 0.75rem;
    cursor: pointer;
    border-radius: var(--radius-lg);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-secondary);
    white-space: nowrap;
    transition: all 200ms ease;
  }

  .search-available:hover {
    background: var(--stone-50);
    color: var(--text-primary);
  }

  .search-checkbox {
    width: 1rem;
    height: 1rem;
    accent-color: var(--amber-600);
    border-radius: 0.25rem;
    cursor: pointer;
  }

  .search-btn {
    background: linear-gradient(135deg, var(--orange-500) 0%, var(--orange-600) 100%);
    color: white;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-xl);
    font-weight: 700;
    font-size: 0.875rem;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    box-shadow: var(--shadow-btn);
    transition: all 200ms ease;
    white-space: nowrap;
    margin: 0 0.25rem;
  }

  .search-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(249, 115, 22, 0.4);
  }
</style>
