---
// Advertisement banner
---

<div class="ad-banner" role="complementary" aria-label="Publicidad">
  <span class="ad-badge">PUBLICIDAD</span>
  <div class="ad-content">
    <div class="ad-icon">
      <i class="ri-store-3-line" aria-hidden="true"></i>
    </div>
    <div class="ad-text">
      <h3 class="ad-title">¿Tienes una ferretería o negocio local?</h3>
      <p class="ad-description">Apoya a tu comunidad y destaca aquí. <span class="ad-link">Contáctanos</span></p>
    </div>
  </div>
  <div class="ad-arrow">
    <i class="ri-arrow-right-line" aria-hidden="true"></i>
  </div>
  <div class="ad-decoration" aria-hidden="true"></div>
</div>

<style>
  .ad-banner {
    background: var(--cream-200);
    border-radius: var(--radius-xl);
    padding: var(--space-4);
    display: flex;
    align-items: center;
    justify-content: space-between;
    border: 0.5px solid var(--border-default);
    box-shadow: var(--shadow-card);
    position: relative;
    overflow: hidden;
    cursor: pointer;
    transition: all 300ms ease;
    gap: 0.75rem;
  }

  @media (min-width: 640px) {
    .ad-banner {
      padding: var(--space-6);
      gap: 0;
    }
  }

  .ad-banner:hover {
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-1px);
  }

  .ad-badge {
    position: absolute;
    top: 0;
    right: 0;
    background: var(--stone-200);
    color: var(--stone-500);
    font-size: 0.625rem;
    font-weight: 700;
    padding: 0.25rem 0.5rem;
    border-radius: 0 var(--radius-xl) 0 var(--radius-md);
  }

  .ad-content {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    position: relative;
    z-index: 1;
  }

  .ad-icon {
    width: 3rem;
    height: 3rem;
    border-radius: var(--radius-lg);
    background: var(--bg-card);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-card);
    flex-shrink: 0;
  }

  .ad-icon i {
    font-size: 1.5rem;
    color: var(--stone-400);
  }

  .ad-title {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
  }

  .ad-description {
    font-size: 0.75rem;
    color: var(--text-secondary);
  }

  .ad-link {
    color: var(--amber-600);
    font-weight: 700;
    text-decoration: underline;
  }

  .ad-arrow {
    display: none;
    position: relative;
    z-index: 1;
  }

  @media (min-width: 768px) {
    .ad-arrow {
      display: block;
    }
  }

  .ad-arrow i {
    font-size: 1.5rem;
    color: var(--stone-300);
    transition: all 200ms ease;
  }

  .ad-banner:hover .ad-arrow i {
    color: var(--amber-500);
    transform: translateX(4px);
  }

  .ad-decoration {
    position: absolute;
    right: -1rem;
    bottom: -1rem;
    width: 6rem;
    height: 6rem;
    border-radius: 50%;
    background: var(--stone-200);
    opacity: 0.3;
  }
</style>
