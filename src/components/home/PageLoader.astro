---
const phrases = [
  'Conectando con los oficios de tu barrio…',
  'Buscando manos expertas cerca de ti…',
  'Tejiendo comunidad, un oficio a la vez…',
  'Reuniendo a los vecinos que saben…',
  'Cada vecino sabe hacer algo…',
  'Encendiendo el barrio…',
];
const phrase = phrases[Math.floor(Math.random() * phrases.length)];
---

<div id="page-loader" class="page-loader" role="status" aria-live="polite" aria-busy="true">
  <div class="loader-content">
    <div class="loader-logo-wrap" aria-hidden="true">
      <div class="loader-logo-base">Quién<span>Sabe</span></div>
      <div class="loader-logo-fill">Quién<span>Sabe</span></div>
    </div>
    <p class="loader-text">{phrase}</p>
  </div>
</div>

<script>
  import { hidePageLoader } from '../../lib/client/home/page-loader';
  hidePageLoader();
</script>

<style>
  .page-loader {
    position: fixed;
    inset: 0;
    background: white;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 500ms ease;
  }

  .page-loader.loader-hidden {
    opacity: 0;
    pointer-events: none;
  }

  .loader-content {
    text-align: center;
  }

  .loader-logo-wrap {
    position: relative;
    display: inline-block;
  }

  .loader-logo-base,
  .loader-logo-fill {
    font-size: 3rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1;
  }

  /* letras base: contorno verde muy claro que se va rellenando */
  .loader-logo-base {
    color: var(--green-100);
  }

  /* relleno verde->naranja revelado de abajo hacia arriba segun --fill */
  .loader-logo-fill {
    position: absolute;
    top: 0;
    left: 0;
    background: linear-gradient(180deg, var(--green-500), var(--color-accent));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    clip-path: inset(calc(100% - var(--fill, 0%)) 0 0 0);
    transition: clip-path 250ms ease;
  }

  .loader-text {
    color: var(--stone-500);
    font-size: 0.9375rem;
    font-weight: 600;
    margin-top: 1.25rem;
    animation: loader-pulse 1.6s ease-in-out infinite;
  }

  @keyframes loader-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  @media (prefers-reduced-motion: reduce) {
    .loader-text { animation: none; }
    .loader-logo-fill { transition: none; }
  }
</style>
