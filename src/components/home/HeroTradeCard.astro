---
interface Trade {
  name: string;
  slug: string;
  userName: string | null;
  symbol: string | null;
  basePriceClp: number | null;
  verified: number | boolean;
  rating: number | null;
  userAvatar?: string | null;
  imageUrl?: string | null;
}

const { trade } = Astro.props as { trade: Trade };
const providerName = trade.userName ?? 'Vecino QuiénSabe';
const initials = providerName.slice(0, 2).toUpperCase();
const precio = (trade.basePriceClp ?? 0).toLocaleString('es-CL');
const rating = trade.rating ?? 0;

function renderStars(r: number): string {
  let s = '';
  for (let i = 1; i <= 5; i++) {
    if (i <= Math.floor(r)) s += '<i class="ri-star-fill"></i>';
    else if (i - 0.5 <= r) s += '<i class="ri-star-half-fill"></i>';
    else s += '<i class="ri-star-line"></i>';
  }
  return s;
}
---

<article class="hero-card">
  {trade.imageUrl ? (
  <img class="hero-bg" src={trade.imageUrl} alt="" loading="lazy" decoding="async" />
  ) : (
  <div class="hero-bg hero-bg-fallback"></div>
  )}
  <div class="hero-mask"></div>

  <div class="hero-content">
    <div class="hero-avatar">
      {trade.userAvatar ? (
      <img src={trade.userAvatar} alt={providerName} loading="lazy" decoding="async" />
      ) : (
      <span class="hero-avatar-initials">{initials}</span>
      )}
    </div>

    <div class="hero-info">
      <h3 class="hero-name">
        <span class="hero-name-text">{providerName}</span>
        {trade.verified ? (
        <i class="ri-verified-badge-fill hero-name-check" title="Verificado" aria-label="Verificado"></i>
        ) : null}
      </h3>
      <span class="hero-trade">{trade.name}</span>
      <div class="hero-stars" role="img" aria-label={`Valoración ${rating} de 5`} set:html={renderStars(rating)}></div>

      <div class="hero-card-footer">
        <div class="hero-price">
          <span class="hero-price-label">Desde</span>
          <span class="hero-price-value">${precio}</span>
        </div>
        <div class="hero-actions">
          <button
            type="button"
            data-fav-toggle={trade.slug}
            class="hero-btn hero-btn-fav js-fav-btn"
            title="Guardar"
            aria-label={`Guardar ${providerName} en favoritos`}
          >
            <i class="ri-heart-line" aria-hidden="true"></i>
          </button>
          <a href={`/p/${trade.slug}`} class="hero-btn" title="Ver detalles" aria-label={`Ver detalles de ${providerName}`}>
            <i class="ri-eye-line" aria-hidden="true"></i>
          </a>
          <a href={`/p/${trade.slug}`} class="hero-btn hero-btn-whatsapp" title="Contactar" aria-label={`Contactar a ${providerName}`}>
            <i class="ri-whatsapp-line" aria-hidden="true"></i>
          </a>
        </div>
      </div>
    </div>
  </div>
</article>

<style>
  .hero-card {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 16rem;
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: 0 10px 28px rgba(41, 37, 36, 0.18);
    border: 1px solid rgba(255, 255, 255, 0.12);
    transition: box-shadow 300ms ease, transform 200ms ease;
  }

  .hero-card:hover {
    box-shadow: 0 16px 40px rgba(41, 37, 36, 0.28);
    transform: translateY(-2px);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 400ms ease;
  }

  .hero-bg-fallback {
    background: linear-gradient(135deg, var(--amber-300) 0%, var(--orange-500) 100%);
  }

  .hero-card:hover .hero-bg {
    transform: scale(1.06);
  }

  .hero-mask {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(28, 25, 23, 0.45) 0%,
      rgba(28, 25, 23, 0.1) 32%,
      rgba(28, 25, 23, 0.55) 72%,
      rgba(28, 25, 23, 0.88) 100%
    );
  }

  .hero-content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-4) var(--space-3);
    text-align: center;
  }

  .hero-avatar {
    width: 3.25rem;
    height: 3.25rem;
    border-radius: var(--radius-full);
    overflow: hidden;
    border: 2px solid rgba(255, 255, 255, 0.9);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
    background: linear-gradient(135deg, var(--amber-100) 0%, var(--orange-50) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: transform 200ms ease;
  }

  .hero-card:hover .hero-avatar {
    transform: scale(1.05);
  }

  .hero-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero-avatar-initials {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--amber-700);
  }

  .hero-info {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .hero-name {
    max-width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    font-size: 1rem;
    font-weight: 800;
    color: white;
    line-height: 1.25;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.6);
  }

  .hero-name-text {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    min-width: 0;
  }

  .hero-name-check {
    flex-shrink: 0;
    color: var(--green-400);
    font-size: 0.9rem;
  }

  .hero-trade {
    margin-top: 0.15rem;
    font-size: 0.7rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.85);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.6);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }

  .hero-stars {
    margin-top: var(--space-2);
    display: flex;
    gap: 2px;
    color: var(--amber-300);
    font-size: 0.8rem;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.5);
  }

  .hero-card-footer {
    margin-top: var(--space-3);
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
  }

  .hero-price {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .hero-price-label {
    font-size: 0.5625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: rgba(255, 255, 255, 0.75);
  }

  .hero-price-value {
    font-size: 1.05rem;
    font-weight: 800;
    color: white;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.5);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-1);
  }

  .hero-btn {
    width: 2rem;
    height: 2rem;
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255, 255, 255, 0.3);
    background: rgba(255, 255, 255, 0.16);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    color: white;
    transition: all 200ms ease;
  }

  .hero-btn i {
    font-size: 0.85rem;
  }

  .hero-btn:hover {
    background: rgba(255, 255, 255, 0.28);
  }

  .hero-btn:focus-visible {
    outline: 2px solid white;
    outline-offset: 2px;
  }

  .hero-btn-fav:hover {
    background: var(--color-error);
    border-color: var(--color-error);
  }

  .hero-btn-whatsapp {
    background: var(--green-500);
    border-color: var(--green-400);
  }
  .hero-btn-whatsapp:hover {
    background: var(--green-600);
    transform: scale(1.05);
  }
</style>
