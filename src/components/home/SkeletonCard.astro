---
// Skeleton placeholder for trade cards
---

<article class="skeleton-card" aria-hidden="true">
  <div class="skeleton-header">
    <div class="skeleton-avatar"></div>
    <div class="skeleton-info">
      <div class="skeleton-line w-3/4 h-4"></div>
      <div class="skeleton-line w-1/2 h-3"></div>
    </div>
  </div>
  <div class="skeleton-body">
    <div class="skeleton-line w-full h-3"></div>
    <div class="skeleton-line w-5/6 h-3"></div>
    <div class="skeleton-line w-2/3 h-3"></div>
  </div>
  <div class="skeleton-tags">
    <div class="skeleton-tag"></div>
    <div class="skeleton-tag w-20"></div>
  </div>
  <div class="skeleton-footer">
    <div>
      <div class="skeleton-line w-12 h-2"></div>
      <div class="skeleton-line w-16 h-5"></div>
    </div>
    <div class="skeleton-btn"></div>
  </div>
</article>

<style>
  .skeleton-card {
    background: var(--bg-card);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-card);
    border: 1px solid var(--border-default);
    padding: var(--space-6);
  }

  .skeleton-header {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-5);
  }

  .skeleton-avatar {
    width: 4rem;
    height: 4rem;
    border-radius: var(--radius-lg);
    background: var(--slate-200);
    animation: pulse 1.5s ease-in-out infinite;
  }

  .skeleton-info {
    flex-grow: 1;
  }

  .skeleton-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .skeleton-tags {
    display: flex;
    gap: var(--space-2);
    margin-bottom: var(--space-5);
  }

  .skeleton-tag {
    width: 4rem;
    height: 1.5rem;
    border-radius: var(--radius-full);
    background: var(--slate-200);
    animation: pulse 1.5s ease-in-out infinite;
  }

  .skeleton-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--space-5);
    border-top: 1px solid var(--border-light);
  }

  .skeleton-btn {
    width: 7rem;
    height: 2.75rem;
    border-radius: var(--radius-lg);
    background: var(--slate-200);
    animation: pulse 1.5s ease-in-out infinite;
  }

  .skeleton-line {
    height: 0.75rem;
    border-radius: var(--radius-sm);
    background: var(--slate-200);
    animation: pulse 1.5s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }
</style>
