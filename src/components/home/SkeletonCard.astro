---
// Skeleton placeholder for trade cards — animación pulse
---

<article class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 animate-pulse" aria-hidden="true">
  <div class="flex items-center gap-4 mb-4">
    <div class="w-12 h-12 rounded-full bg-gray-200 flex-shrink-0"></div>
    <div class="flex-1 min-w-0">
      <div class="h-4 bg-gray-200 rounded w-3/4 mb-2"></div>
      <div class="h-3 bg-gray-200 rounded w-1/2"></div>
    </div>
  </div>
  <div class="h-3 bg-gray-200 rounded mb-2"></div>
  <div class="h-3 bg-gray-200 rounded mb-2 w-5/6"></div>
  <div class="h-3 bg-gray-200 rounded mb-4 w-2/3"></div>
  <div class="flex gap-1.5 mb-4">
    <div class="h-5 bg-gray-200 rounded-full w-16"></div>
    <div class="h-5 bg-gray-200 rounded-full w-20"></div>
  </div>
  <div class="flex justify-between items-center border-t pt-4 border-gray-100">
    <div>
      <div class="h-3 bg-gray-200 rounded w-12 mb-1"></div>
      <div class="h-5 bg-gray-200 rounded w-16"></div>
    </div>
    <div class="h-8 bg-gray-200 rounded-xl w-24"></div>
  </div>
</article>
