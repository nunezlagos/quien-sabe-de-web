---
// Skeleton placeholder for trade cards — animación pulse
---

<article class="card-skeleton bg-white rounded-2xl border border-slate-200 p-6 animate-pulse shadow-sm" aria-hidden="true">
  <div class="flex items-center gap-4 mb-5">
    <div class="w-16 h-16 rounded-2xl bg-slate-100 flex-shrink-0"></div>
    <div class="flex-1 min-w-0">
      <div class="h-5 bg-slate-100 rounded w-3/4 mb-2"></div>
      <div class="h-3 bg-slate-100 rounded w-1/2"></div>
    </div>
  </div>
  <div class="h-3 bg-slate-100 rounded mb-3"></div>
  <div class="h-3 bg-slate-100 rounded mb-3 w-5/6"></div>
  <div class="h-3 bg-slate-100 rounded mb-5 w-2/3"></div>
  <div class="flex gap-2 mb-5">
    <div class="h-6 bg-slate-100 rounded-full w-16"></div>
    <div class="h-6 bg-slate-100 rounded-full w-20"></div>
  </div>
  <div class="flex justify-between items-center border-t border-slate-100 pt-5">
    <div>
      <div class="h-3 bg-slate-100 rounded w-12 mb-1"></div>
      <div class="h-5 bg-slate-100 rounded w-16"></div>
    </div>
    <div class="h-11 bg-slate-100 rounded-xl w-28"></div>
  </div>
</article>

<style>
  .card-skeleton {
    background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%);
  }
</style>
