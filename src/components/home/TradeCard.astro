---
interface Trade {
  name: string;
  slug: string;
  userName: string | null;
  description: string | null;
  symbol: string | null;
  basePriceClp: number | null;
  communeName: string | null;
  verified: number | boolean;
  availableNow: number | boolean;
  rating: number | null;
}

const { trade } = Astro.props as { trade: Trade };
const initials = (trade.userName ?? '?').slice(0, 2).toUpperCase();
const precio = (trade.basePriceClp ?? 0).toLocaleString('es-CL');
const rating = trade.rating ?? 0;

function renderStars(r: number): string {
  const full = Math.floor(r);
  const half = r - full >= 0.5;
  let s = '';
  for (let i = 1; i <= 5; i++) {
    if (i <= full) s += '<i class="ri-star-fill"></i>';
    else if (i - 0.5 <= r) s += '<i class="ri-star-half-fill"></i>';
    else s += '<i class="ri-star-line text-green-300"></i>';
  }
  return s;
}
---

<article class="card-tradecard group flex flex-col h-full">
  <div class="p-6 flex flex-col flex-grow relative">
    <div class="flex justify-between items-start mb-5 relative z-10">
      <div class="flex items-end gap-4">
        <div class="w-16 h-16 rounded-2xl bg-warm-100 border-2 border-white shadow-md flex items-center justify-center text-primary font-bold text-xl group-hover:scale-105 transition overflow-hidden relative flex-shrink-0">
          <div class="w-full h-full bg-gradient-to-br from-green-100 to-green-50 flex items-center justify-center text-green-primary font-bold text-3xl rounded-xl">
            {initials}
          </div>
        </div>
        <div class="mb-1">
          <h3 class="font-bold text-slate-800 text-lg leading-tight break-words mb-2 group-hover:text-green-primary transition font-display">{trade.name}</h3>
          <div class="flex flex-wrap gap-1.5 mt-1.5">
            <span class="text-[10px] font-bold uppercase text-white bg-green-primary px-2.5 py-1 rounded-full tracking-wider shadow-sm">
              {trade.symbol ?? 'Oficio'}
            </span>
          </div>
          <div class="flex flex-wrap gap-1.5 items-center mt-2">
            {trade.verified ? (
            <span class="text-[10px] font-semibold text-blue-600 bg-blue-50 px-2 py-0.5 rounded-full border border-blue-100 flex items-center gap-1">
              <i class="ri-shield-check-fill"></i> Verificado
            </span>
            ) : null}
            {trade.availableNow ? (
            <span class="text-[10px] font-semibold text-green-700 bg-green-50 px-2 py-0.5 rounded-full border border-green-100 flex items-center gap-1">
              <i class="ri-flashlight-fill"></i> Disponible
            </span>
            ) : null}
          </div>
          {trade.communeName ? (
          <span class="text-[10px] text-slate-400 flex items-center gap-1 mt-2">
            <i class="ri-map-pin-line"></i> <span>{trade.communeName}</span>
          </span>
          ) : null}
        </div>
      </div>
      <div class="text-right mt-6">
        <div class="text-xs text-yellow-400 drop-shadow-sm flex gap-0.5" set:html={renderStars(rating)}>
        </div>
      </div>
      </div>
    </div>

    <div class="mb-5 flex-grow">
      <p class="text-slate-500 text-sm leading-relaxed line-clamp-3">
        {trade.description ?? 'Servicio profesional disponible en tu barrio.'}
      </p>
    </div>

    <div class="flex flex-wrap gap-2 mb-4 min-h-[28px]">
      <span class="text-xs bg-slate-100 text-slate-600 px-3 py-1 rounded-lg font-medium whitespace-nowrap border border-slate-200">{trade.symbol ?? 'General'}</span>
    </div>
  </div>

  <div class="px-6 py-5 bg-gradient-to-t from-slate-50 to-warm-50 border-t border-slate-100 flex items-center justify-between mt-auto">
    <div>
      <span class="text-[10px] text-slate-400 uppercase font-bold block tracking-wide">Desde</span>
      <span class="text-xl font-extrabold text-slate-800">${precio}</span>
    </div>
    <div class="flex gap-2">
      <button
        data-fav-toggle={trade.slug}
        class="w-11 h-11 rounded-xl bg-white border border-slate-200 text-slate-400 hover:text-red-500 hover:border-red-200 hover:bg-red-50 flex items-center justify-center transition-all shadow-sm hover:shadow-md js-fav-btn"
        title="Guardar"
      >
        <i class="ri-heart-line text-lg"></i>
      </button>
      <a
        href={`/p/${trade.slug}`}
        class="w-11 h-11 rounded-xl bg-white border border-slate-200 text-slate-500 hover:text-green-primary hover:border-green-200 hover:bg-green-50 flex items-center justify-center transition-all shadow-sm hover:shadow-md"
        title="Ver Detalles"
      >
        <i class="ri-eye-line text-lg"></i>
      </a>
      <a
        href={`/p/${trade.slug}`}
        class="w-11 h-11 rounded-xl bg-gradient-to-br from-green-primary to-green-dark text-white flex items-center justify-center transition-all shadow-md hover:shadow-lg hover:scale-105 hover:-translate-y-0.5"
        title="Contactar"
      >
        <i class="ri-whatsapp-line text-xl"></i>
      </a>
    </div>
  </div>
</article>

<style>
  .card-tradecard {
    background: white;
    border-radius: 1rem;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.07), 0 2px 4px -2px rgba(0, 0, 0, 0.05);
    border: 1px solid #e2e8f0;
    transition: box-shadow 300ms ease, transform 200ms ease;
    overflow: hidden;
  }

  .card-tradecard:hover {
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.08), 0 4px 6px -4px rgba(0, 0, 0, 0.05);
    transform: translateY(-2px);
  }

  .font-display {
    font-family: 'Nunito', sans-serif;
  }
</style>
