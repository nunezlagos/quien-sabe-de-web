---
export interface Props {
  communes: Array<{ id: number; name: string }>;
}
const { communes } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-br from-orange-50 to-white flex items-center justify-center px-4 py-12">
  <div class="bg-white rounded-3xl shadow-xl border border-gray-100 w-full max-w-lg p-8 sm:p-10">
    <div class="text-center mb-8">
      <div class="w-16 h-16 bg-orange-100 rounded-full flex items-center justify-center mx-auto mb-4">
        <i class="ri-hand-wave-line text-3xl text-orange-500"></i>
      </div>
      <h1 class="text-2xl font-extrabold text-gray-800">¡Bienvenido a QuiénSabe!</h1>
      <p class="text-sm text-gray-500 mt-2">Cuéntanos un poco de ti para empezar.</p>
    </div>

    <form id="onboarding-form" class="space-y-6">
      <div>
        <label for="onboarding-commune" class="block text-sm font-bold text-gray-700 mb-1.5">
          ¿En qué comuna vives? <span class="text-red-500">*</span>
        </label>
        <select id="onboarding-commune" name="communeId" required
          class="w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-orange-500 focus:border-orange-500 outline-none transition">
          <option value="">Selecciona tu comuna</option>
          {communes.map((c) => (
            <option value={c.id}>{c.name}</option>
          ))}
        </select>
      </div>

      <div>
        <label for="onboarding-interests" class="block text-sm font-bold text-gray-700 mb-1.5">
          ¿Qué oficios te interesan? (opcional)
        </label>
        <textarea id="onboarding-interests" name="interests" rows="3" placeholder="Ej: gasfitería, electricidad, jardinería, clases..."
          class="w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-orange-500 focus:border-orange-500 outline-none transition"></textarea>
        <p class="text-xs text-gray-400 mt-1">Sepáralos por coma. Nos ayuda a recomendarte mejores resultados.</p>
      </div>

      <div class="bg-gray-50 rounded-2xl p-4 border border-gray-100">
        <label class="flex items-start gap-3 cursor-pointer">
          <input id="onboarding-terms" type="checkbox" required
            class="mt-0.5 w-5 h-5 text-orange-500 border-gray-300 rounded focus:ring-orange-500">
          <span class="text-sm text-gray-600 leading-relaxed">
            Acepto los
            <a href="/terminos" target="_blank" class="text-orange-500 font-bold hover:text-orange-600 underline">Términos y condiciones</a>
            y la
            <a href="/privacidad" target="_blank" class="text-orange-500 font-bold hover:text-orange-600 underline">Política de privacidad</a>.
          </span>
        </label>
      </div>

      <div id="onboarding-error" class="hidden bg-red-50 border border-red-200 text-red-700 text-sm font-medium px-4 py-3 rounded-xl" role="alert"></div>

      <button type="submit" id="onboarding-submit"
        class="w-full bg-orange-500 hover:bg-orange-600 text-white font-bold py-3 px-6 rounded-xl transition shadow-md text-sm flex items-center justify-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed">
        <span>Empezar</span>
        <i class="ri-arrow-right-line"></i>
      </button>
    </form>
  </div>
</div>

<script>
  const form = document.getElementById('onboarding-form') as HTMLFormElement;
  const submitBtn = document.getElementById('onboarding-submit') as HTMLButtonElement;
  const errorDiv = document.getElementById('onboarding-error') as HTMLDivElement;

  function showError(msg: string) {
    errorDiv.textContent = msg;
    errorDiv.classList.remove('hidden');
  }

  function hideError() {
    errorDiv.classList.add('hidden');
  }

  form.addEventListener('submit', async (e: Event) => {
    e.preventDefault();
    hideError();
    submitBtn.disabled = true;
    submitBtn.querySelector('span')!.textContent = 'Guardando...';

    const formData = new FormData(form);
    const communeId = Number(formData.get('communeId'));
    const acceptedTerms = formData.get('acceptedTerms') === 'on';
    const interests = (formData.get('interests') as string)?.trim() || undefined;

    if (!communeId) {
      showError('Selecciona tu comuna para continuar.');
      submitBtn.disabled = false;
      submitBtn.querySelector('span')!.textContent = 'Empezar';
      return;
    }

    if (!acceptedTerms) {
      showError('Debes aceptar los términos y condiciones.');
      submitBtn.disabled = false;
      submitBtn.querySelector('span')!.textContent = 'Empezar';
      return;
    }

    try {
      const res = await fetch('/api/v1/users/me/profile', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ communeId, acceptedTerms: true, interests }),
      });

      if (res.ok) {
        window.location.href = '/dashboard';
      } else {
        const err = await res.json();
        showError(err.error || 'Error al guardar tus datos. Intenta de nuevo.');
      }
    } catch {
      showError('Error de conexión. Verifica tu internet e intenta de nuevo.');
    } finally {
      submitBtn.disabled = false;
      submitBtn.querySelector('span')!.textContent = 'Empezar';
    }
  });
</script>
