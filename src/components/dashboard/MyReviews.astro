---
export interface ReviewItem {
  id: number;
  tradeId: number;
  tradeName: string;
  tradeSlug: string;
  rating: number;
  body: string;
  createdAt: string;
}

export interface Props {
  reviews: ReviewItem[];
}

const { reviews } = Astro.props;

function stars(rating: number): string {
  return '★'.repeat(rating) + '☆'.repeat(5 - rating);
}
---

<div class="widget-card">
  <h3 class="widget-title">
    <i class="ri-star-smile-fill" style="color: var(--amber-500)" aria-hidden="true"></i> Mis reseñas ({reviews.length})
  </h3>

  {reviews.length > 0 ? (
    <div class="reviews-list">
      {reviews.map((r) => (
        <article class="review-item">
          <div class="review-header">
            <a href={`/p/${r.tradeSlug}`} class="review-trade">{r.tradeName}</a>
            <time class="review-date">{new Date(r.createdAt).toLocaleDateString('es-CL', { day: 'numeric', month: 'short', year: 'numeric' })}</time>
          </div>
          <div class="review-stars">{stars(r.rating)}</div>
          <p class="review-body">{r.body}</p>
        </article>
      ))}
    </div>
  ) : (
    <div class="empty-state">
      <div class="empty-icon">
        <i class="ri-star-smile-line" aria-hidden="true"></i>
      </div>
      <p class="empty-text">Aún no has dejado reseñas.</p>
      <p class="empty-link"><a href="/">Buscar vecinos para reseñar</a></p>
    </div>
  )}
</div>

<style>
  .widget-card {
    background: var(--bg-card);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-card);
    border: 1px solid var(--border-default);
    padding: var(--space-6);
    transition: box-shadow 300ms ease;
  }

  .widget-card:hover {
    box-shadow: var(--shadow-card-hover);
  }

  .widget-title {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--space-5);
  }

  .reviews-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .review-item {
    background: var(--bg-warm);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-light);
    padding: var(--space-4);
    transition: all 200ms ease;
  }

  .review-item:hover {
    border-color: var(--amber-300);
    box-shadow: var(--shadow-card);
  }

  .review-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: var(--space-2);
  }

  .review-trade {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--text-primary);
    transition: color 200ms ease;
  }

  .review-trade:hover {
    color: var(--amber-600);
  }

  .review-date {
    font-size: 0.75rem;
    color: var(--text-muted);
    flex-shrink: 0;
  }

  .review-stars {
    font-size: 0.875rem;
    color: var(--amber-400);
    margin-bottom: var(--space-2);
  }

  .review-body {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .empty-state {
    text-align: center;
    padding: var(--space-10) 0;
  }

  .empty-icon {
    width: 4rem;
    height: 4rem;
    border-radius: var(--radius-xl);
    background: var(--slate-100);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto var(--space-3);
  }

  .empty-icon i {
    font-size: 1.5rem;
    color: var(--slate-300);
  }

  .empty-text {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-muted);
  }

  .empty-link {
    font-size: 0.75rem;
    margin-top: var(--space-1);
  }

  .empty-link a {
    color: var(--amber-600);
    font-weight: 700;
    transition: color 200ms ease;
  }

  .empty-link a:hover {
    color: var(--amber-700);
  }
</style>
