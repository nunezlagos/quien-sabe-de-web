---
export interface ViewItem {
  id: number;
  tradeId: number;
  tradeName: string;
  tradeSlug: string;
  createdAt: string;
}

export interface Props {
  views: ViewItem[];
}

const { views } = Astro.props;
---

<div class="card-widget">
  <h3 class="font-bold text-slate-800 text-base mb-5 flex items-center gap-2">
    <i class="ri-history-fill text-blue-500"></i> Vistos recientemente
  </h3>

  {views.length > 0 ? (
    <div class="space-y-3">
      {views.map((v) => (
        <a href={`/p/${v.tradeSlug}`} class="flex items-center gap-3 p-3 bg-gradient-to-br from-slate-50 to-warm-50 rounded-xl border border-slate-200 hover:border-green-300 hover:shadow-md hover:bg-green-50/30 transition-all duration-200 group">
          <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-green-100 to-green-50 flex items-center justify-center text-green-primary font-bold text-sm flex-shrink-0 border border-green-200 group-hover:scale-105 transition">
            {v.tradeName.slice(0, 2).toUpperCase()}
          </div>
          <div class="flex-1 min-w-0">
            <h4 class="font-bold text-slate-800 text-sm truncate font-display group-hover:text-green-primary transition">{v.tradeName}</h4>
          </div>
          <time class="text-xs text-slate-400 flex-shrink-0">
            {new Date(v.createdAt).toLocaleDateString('es-CL', { day: 'numeric', month: 'short' })}
          </time>
        </a>
      ))}
    </div>
  ) : (
    <div class="text-center py-10 text-slate-400">
      <div class="w-16 h-16 rounded-2xl bg-slate-100 flex items-center justify-center mx-auto mb-3">
        <i class="ri-history-line text-3xl text-slate-300"></i>
      </div>
      <p class="text-sm font-medium">Sin actividad reciente.</p>
      <p class="text-xs mt-1 text-slate-400">Tus búsquedas aparecerán aquí.</p>
    </div>
  )}
</div>

<style>
  .card-widget {
    background: white;
    border-radius: 1rem;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.07), 0 2px 4px -2px rgba(0, 0, 0, 0.05);
    border: 1px solid #e2e8f0;
    padding: 1.5rem;
    transition: box-shadow 300ms ease;
  }

  .card-widget:hover {
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.08), 0 4px 6px -4px rgba(0, 0, 0, 0.05);
  }

  .font-display {
    font-family: 'Nunito', sans-serif;
  }
</style>
