---
export interface ViewItem {
  id: number;
  tradeId: number;
  tradeName: string;
  tradeSlug: string;
  createdAt: string;
}

export interface Props {
  views: ViewItem[];
}

const { views } = Astro.props;
---

<div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-6">
  <h3 class="font-bold text-gray-800 text-lg mb-4 flex items-center gap-2">
    <i class="ri-history-line text-blue-500"></i> Vistos recientemente
  </h3>

  {views.length > 0 ? (
    <div class="space-y-3">
      {views.map((v) => (
        <a href={`/p/${v.tradeSlug}`} class="flex items-center gap-3 p-3 bg-gray-50 rounded-2xl border border-gray-100 hover:border-orange-500/50 transition">
          <div class="w-10 h-10 rounded-full bg-blue-100 flex items-center justify-center text-blue-500 font-bold text-sm flex-shrink-0">
            {v.tradeName.slice(0, 2).toUpperCase()}
          </div>
          <div class="flex-1 min-w-0">
            <h4 class="font-bold text-gray-800 text-sm truncate">{v.tradeName}</h4>
          </div>
          <time class="text-xs text-gray-400 flex-shrink-0">
            {new Date(v.createdAt).toLocaleDateString('es-CL', { day: 'numeric', month: 'short' })}
          </time>
        </a>
      ))}
    </div>
  ) : (
    <div class="text-center py-8 text-gray-400">
      <i class="ri-history-line text-4xl mb-2 block opacity-30"></i>
      <p class="text-sm font-medium">Sin actividad reciente.</p>
      <p class="text-xs mt-1">Tus búsquedas aparecerán aquí.</p>
    </div>
  )}
</div>
