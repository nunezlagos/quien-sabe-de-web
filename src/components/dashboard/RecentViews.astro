---
export interface ViewItem {
  id: number;
  tradeId: number;
  tradeName: string;
  tradeSlug: string;
  createdAt: string;
}

export interface Props {
  views: ViewItem[];
}

const { views } = Astro.props;
---

<div class="widget-card">
  <h3 class="widget-title">
    <i class="ri-history-fill" style="color: var(--slate-400)" aria-hidden="true"></i> Vistos recientemente
  </h3>

  {views.length > 0 ? (
    <div class="views-list">
      {views.map((v) => (
        <a href={`/p/${v.tradeSlug}`} class="view-item">
          <div class="view-avatar">
            {v.tradeName.slice(0, 2).toUpperCase()}
          </div>
          <div class="view-info">
            <h4 class="view-name">{v.tradeName}</h4>
          </div>
          <time class="view-date">{new Date(v.createdAt).toLocaleDateString('es-CL', { day: 'numeric', month: 'short' })}</time>
        </a>
      ))}
    </div>
  ) : (
    <div class="empty-state">
      <div class="empty-icon">
        <i class="ri-history-line" aria-hidden="true"></i>
      </div>
      <p class="empty-text">Sin actividad reciente.</p>
      <p class="empty-subtext">Tus búsquedas aparecerán aquí.</p>
    </div>
  )}
</div>

<style>
  .widget-card {
    background: var(--bg-card);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-card);
    border: 1px solid var(--border-default);
    padding: var(--space-6);
    transition: box-shadow 300ms ease;
  }

  .widget-card:hover {
    box-shadow: var(--shadow-card-hover);
  }

  .widget-title {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--space-5);
  }

  .views-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .view-item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3);
    background: var(--bg-warm);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-light);
    transition: all 200ms ease;
  }

  .view-item:hover {
    border-color: var(--amber-300);
    background: var(--amber-50);
    box-shadow: var(--shadow-card);
  }

  .view-avatar {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: var(--radius-lg);
    background: linear-gradient(135deg, var(--amber-100) 0%, var(--orange-50) 100%);
    border: 1px solid var(--amber-200);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--amber-700);
    flex-shrink: 0;
    transition: transform 200ms ease;
  }

  .view-item:hover .view-avatar {
    transform: scale(1.05);
  }

  .view-info {
    flex-grow: 1;
    min-width: 0;
  }

  .view-name {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 200ms ease;
  }

  .view-item:hover .view-name {
    color: var(--amber-700);
  }

  .view-date {
    font-size: 0.75rem;
    color: var(--text-muted);
    flex-shrink: 0;
  }

  .empty-state {
    text-align: center;
    padding: var(--space-10) 0;
  }

  .empty-icon {
    width: 4rem;
    height: 4rem;
    border-radius: var(--radius-xl);
    background: var(--slate-100);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto var(--space-3);
  }

  .empty-icon i {
    font-size: 1.5rem;
    color: var(--slate-300);
  }

  .empty-text {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-muted);
  }

  .empty-subtext {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: var(--space-1);
  }
</style>
