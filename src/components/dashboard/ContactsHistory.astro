---
export interface ContactEvent {
  id: number;
  eventType: string;
  tradeId: number;
  tradeName: string;
  tradeSlug: string;
  createdAt: string;
}

export interface Props {
  events: ContactEvent[];
}

const { events } = Astro.props;

const iconMap: Record<string, string> = {
  whatsapp: 'ri-whatsapp-fill',
  email: 'ri-mail-fill',
  phone: 'ri-phone-fill',
  profile: 'ri-user-fill',
};

const labelMap: Record<string, string> = {
  whatsapp: 'WhatsApp',
  email: 'Email',
  phone: 'Teléfono',
  profile: 'Perfil',
};
---

<div class="widget-card">
  <h3 class="widget-title">
    <i class="ri-chat-1-fill" style="color: var(--orange-500)"></i> Historial de contactos
  </h3>

  {events.length > 0 ? (
    <div class="events-list">
      {events.map((ev) => (
        <div class="event-item">
          <div class="event-icon" data-type={ev.eventType}>
            <i class={iconMap[ev.eventType] || 'ri-question-line'}></i>
          </div>
          <div class="event-info">
            <a href={`/p/${ev.tradeSlug}`} class="event-trade">{ev.tradeName}</a>
            <p class="event-label">Contacto vía {labelMap[ev.eventType] || ev.eventType}</p>
          </div>
          <time class="event-date">{new Date(ev.createdAt).toLocaleDateString('es-CL', { day: 'numeric', month: 'short' })}</time>
        </div>
      ))}
    </div>
  ) : (
    <div class="empty-state">
      <div class="empty-icon">
        <i class="ri-chat-1-line"></i>
      </div>
      <p class="empty-text">Aún no has contactado a ningún vecino.</p>
      <p class="empty-subtext">Cuando contactes a un oficio aparecerá aquí.</p>
    </div>
  )}
</div>

<style>
  .widget-card {
    background: var(--bg-card);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-card);
    border: 1px solid var(--border-default);
    padding: var(--space-6);
    transition: box-shadow 300ms ease;
  }

  .widget-card:hover {
    box-shadow: var(--shadow-card-hover);
  }

  .widget-title {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--space-5);
  }

  .events-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .event-item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3);
    background: var(--bg-warm);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-light);
    transition: all 200ms ease;
  }

  .event-item:hover {
    border-color: var(--green-300);
    box-shadow: var(--shadow-card);
  }

  .event-icon {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .event-icon[data-type="whatsapp"] {
    background: var(--green-100);
    color: var(--green-600);
  }

  .event-icon[data-type="email"] {
    background: var(--slate-100);
    color: var(--slate-600);
  }

  .event-icon[data-type="phone"] {
    background: var(--orange-100);
    color: var(--orange-600);
  }

  .event-icon[data-type="profile"] {
    background: var(--slate-100);
    color: var(--slate-500);
  }

  .event-icon i {
    font-size: 1.125rem;
  }

  .event-info {
    flex-grow: 1;
    min-width: 0;
  }

  .event-trade {
    display: block;
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 200ms ease;
  }

  .event-trade:hover {
    color: var(--green-600);
  }

  .event-label {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .event-date {
    font-size: 0.75rem;
    color: var(--text-muted);
    flex-shrink: 0;
  }

  .empty-state {
    text-align: center;
    padding: var(--space-10) 0;
  }

  .empty-icon {
    width: 4rem;
    height: 4rem;
    border-radius: var(--radius-xl);
    background: var(--slate-100);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto var(--space-3);
  }

  .empty-icon i {
    font-size: 1.5rem;
    color: var(--slate-300);
  }

  .empty-text {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-muted);
  }

  .empty-subtext {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: var(--space-1);
  }
</style>
