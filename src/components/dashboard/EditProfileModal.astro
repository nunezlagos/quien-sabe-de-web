---
export interface Commune {
  id: number;
  name: string;
}

export interface Props {
  open: boolean;
  communes: Commune[];
}

const { open, communes } = Astro.props;
---

<div
  id="edit-profile-modal"
  class={`edit-profile-overlay ${open ? 'is-open' : ''}`}
  role="dialog"
  aria-modal="true"
  aria-labelledby="edit-profile-title"
  aria-hidden={open ? 'false' : 'true'}
>
  <div class="edit-profile-backdrop modal-backdrop" data-modal-backdrop aria-hidden="true"></div>
  <div class="edit-profile-content">
    <button
      type="button"
      class="edit-profile-close js-edit-profile-close"
      aria-label="Cerrar"
    >
      <i class="ri-close-line" aria-hidden="true"></i>
    </button>

    <h2 id="edit-profile-title" class="edit-profile-title">Editar perfil</h2>

    <form id="edit-profile-form" class="edit-profile-form">
      <div class="edit-profile-field">
        <label for="edit-name" class="edit-profile-label">Nombre</label>
        <input id="edit-name" name="name" type="text" required class="edit-profile-input" />
      </div>

      <div class="edit-profile-field">
        <label for="edit-commune" class="edit-profile-label">Comuna</label>
        <select id="edit-commune" name="communeId" class="edit-profile-input">
          <option value="">Sin especificar</option>
          {communes.map((c) => (
            <option value={c.id}>{c.name}</option>
          ))}
        </select>
      </div>

      <div class="edit-profile-field">
        <label for="edit-interests" class="edit-profile-label">Intereses</label>
        <textarea
          id="edit-interests"
          name="interests"
          rows="3"
          class="edit-profile-input"
          placeholder="Ej: gasfitería, electricidad, jardinería..."></textarea>
      </div>

      <div class="edit-profile-actions">
        <button type="button" class="edit-profile-btn edit-profile-btn-cancel js-edit-profile-close">
          Cancelar
        </button>
        <button type="submit" class="edit-profile-btn edit-profile-btn-save">
          Guardar cambios
        </button>
      </div>
    </form>
  </div>
</div>

<style>
  .edit-profile-overlay {
    position: fixed;
    inset: 0;
    z-index: 50;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }

  .edit-profile-overlay.is-open {
    display: flex;
  }

  .edit-profile-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
  }

  .edit-profile-content {
    position: relative;
    z-index: 10;
    background: var(--bg-card);
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-card-lifted);
    width: 100%;
    max-width: 32rem;
    padding: 2rem;
  }

  .edit-profile-close {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    width: 2.75rem;
    height: 2.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    border-radius: var(--radius-full);
    color: var(--text-muted);
    font-size: 1.25rem;
    cursor: pointer;
    transition: color 200ms ease, background 200ms ease;
  }

  .edit-profile-close:hover {
    color: var(--text-primary);
    background: var(--stone-100);
  }

  .edit-profile-title {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
    padding-right: 2.5rem;
  }

  .edit-profile-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .edit-profile-field {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .edit-profile-label {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--text-secondary);
  }

  .edit-profile-input {
    width: 100%;
    padding: 0.625rem 1rem;
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    font-size: 0.875rem;
    background: var(--bg-card);
    color: var(--text-primary);
    transition: border-color 200ms ease, box-shadow 200ms ease;
  }

  .edit-profile-input:focus-visible {
    outline: none;
    border-color: var(--border-focus);
    box-shadow: 0 0 0 3px var(--orange-100);
  }

  .edit-profile-actions {
    display: flex;
    gap: 0.75rem;
    padding-top: 0.5rem;
  }

  .edit-profile-btn {
    flex: 1;
    min-height: 2.75rem;
    padding: 0.625rem 1rem;
    border-radius: var(--radius-lg);
    font-size: 0.875rem;
    font-weight: 700;
    border: none;
    cursor: pointer;
    transition: background 200ms ease;
  }

  .edit-profile-btn-cancel {
    background: var(--stone-100);
    color: var(--text-secondary);
  }

  .edit-profile-btn-cancel:hover {
    background: var(--stone-200);
  }

  .edit-profile-btn-save {
    background: var(--color-primary);
    color: var(--cream-50);
    box-shadow: var(--shadow-btn);
  }

  .edit-profile-btn-save:hover {
    background: var(--color-accent-dark);
  }
</style>

<script>
  import { initModal } from '../../lib/client/ui/modal';

  const modalEl = document.getElementById('edit-profile-modal');

  interface ProfileData {
    name: string;
    communeId: number | null;
    interests: string | null;
  }

  let profileData: ProfileData = { name: '', communeId: null, interests: null };

  async function loadProfile() {
    try {
      const res = await fetch('/api/v1/users/me/profile');
      if (res.ok) {
        profileData = await res.json();
        const form = document.getElementById('edit-profile-form') as HTMLFormElement;
        if (form) {
          (form.elements.namedItem('name') as HTMLInputElement).value = profileData.name || '';
          (form.elements.namedItem('communeId') as HTMLSelectElement).value = String(profileData.communeId ?? '');
          (form.elements.namedItem('interests') as HTMLTextAreaElement).value = profileData.interests || '';
        }
      }
    } catch (e) {
      console.error('Error loading profile:', e);
    }
  }

  if (modalEl) {
    const closers = Array.from(
      modalEl.querySelectorAll<HTMLElement>('.js-edit-profile-close')
    );

    const controller = initModal({
      modal: modalEl,
      closers,
      onOpen: () => {
        loadProfile();
      },
    });

    (window as any).openEditProfileModal = function () {
      controller.open();
    };

    (window as any).closeEditProfileModal = function () {
      controller.close();
    };
  }

  document.getElementById('edit-profile-form')!.addEventListener('submit', async (e: Event) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const data = {
      name: (form.elements.namedItem('name') as HTMLInputElement).value,
      communeId: (form.elements.namedItem('communeId') as HTMLSelectElement).value
        ? Number((form.elements.namedItem('communeId') as HTMLSelectElement).value)
        : undefined,
      interests: (form.elements.namedItem('interests') as HTMLTextAreaElement).value || undefined,
    };

    try {
      const res = await fetch('/api/v1/users/me/profile', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        (window as any).closeEditProfileModal();
        window.location.reload();
      } else {
        const err = await res.json();
        alert('Error: ' + (err.error || 'desconocido'));
      }
    } catch {
      alert('Error de conexión');
    }
  });
</script>
