---
const { userRoles = [], currentRole, currentPath } = Astro.props;
const hasMultipleRoles = userRoles.length > 1;
---

{hasMultipleRoles && (
  <div class="relative inline-flex items-center gap-1 bg-gray-100 rounded-full px-1 py-1 text-xs font-bold">
    {userRoles.map((role: string) => {
      const label = role === 'provider' ? 'Prestador' : role === 'admin' ? 'Admin' : 'Vecino';
      const targetPath = role === 'provider'
        ? '/dashboard-prestador'
        : role === 'admin'
          ? '/dashboard-admin'
          : '/dashboard';
      const isActive = currentRole === role;
      return (
        <a
          href={targetPath}
          class:list={[
            'px-3 py-1.5 rounded-full transition font-bold text-xs',
            isActive
              ? 'bg-white text-orange-600 shadow-sm'
              : 'text-gray-500 hover:text-gray-700',
          ]}
        >
          {label}
        </a>
      );
    })}
  </div>
)}
