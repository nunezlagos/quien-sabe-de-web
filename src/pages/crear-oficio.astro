---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getDb } from '../database/client';
import { communes } from '../database/schema';
import { asc } from 'drizzle-orm';

const currentUser = Astro.locals.user;
if (!currentUser) {
  return Astro.redirect('/iniciar-sesion?redirigir=/crear-oficio');
}

const error = Astro.url.searchParams.get('error');

const db = getDb();
const communeList = await db.select({ id: communes.id, name: communes.name }).from(communes).orderBy(asc(communes.name)).all();

const OFICIOS = [
  { value: '', label: 'Selecciona tu oficio…' },
  { value: 'gasfiter', label: 'Gasfiter' },
  { value: 'electricista', label: 'Electricista' },
  { value: 'jardinero', label: 'Jardinero' },
  { value: 'maestro', label: 'Maestro' },
  { value: 'costurera', label: 'Costurera' },
  { value: 'otro', label: 'Otro' },
];
---

<BaseLayout title="Crear Nuevo Oficio — QuiénSabe">
  <main class="crear-oficio-main">
    <div class="crear-oficio-header">
      <div class="crear-oficio-icon">
        <i class="ri-briefcase-line"></i>
      </div>
      <h1 class="crear-oficio-title">Ofrece tus servicios</h1>
      <p class="crear-oficio-subtitle">Completa tu perfil profesional.</p>
    </div>

    {error && (
      <div class="crear-oficio-error">
        {error}
      </div>
    )}

    <form action="/api/v1/trades" method="POST" id="form-crear-oficio">
      <section class="crear-section">
        <h3 class="crear-section-title">1. Información Básica</h3>

        <div class="crear-grid">
          <div class="crear-field">
            <label for="name" class="crear-label">Nombre Visible</label>
            <input id="name" name="name" type="text" required minlength="3" maxlength="120" placeholder="Ej: Juan Pérez" class="crear-input">
          </div>
          <div class="crear-field">
            <label for="symbol" class="crear-label">Oficio</label>
            <select id="symbol" name="symbol" required class="crear-select js-oficio-select">
              {OFICIOS.map((o) => (
                <option value={o.value}>{o.label}</option>
              ))}
            </select>
          </div>
          <div class="crear-field crear-field-full" data-oficio-otro hidden>
            <label for="symbol_custom" class="crear-label">Especifica tu oficio</label>
            <input id="symbol_custom" name="symbol_custom" type="text" maxlength="30" placeholder="Ej: yesero, tapicero, soldador…" class="crear-input">
          </div>
          <div class="crear-field crear-field-full">
            <label for="description" class="crear-label">Descripción Corta (Bio)</label>
            <textarea id="description" name="description" rows="2" required minlength="20" maxlength="1000" placeholder="Cuenta brevemente tu experiencia…" class="crear-textarea"></textarea>
          </div>
        </div>
      </section>

      <section class="crear-section">
        <h3 class="crear-section-title">2. Contacto y Precios</h3>

        <div class="crear-grid">
          <div class="crear-field">
            <label for="whatsapp" class="crear-label">WhatsApp</label>
            <div class="crear-input-wrapper">
              <span class="crear-input-prefix">+56 9</span>
              <input id="whatsapp" name="whatsapp" type="tel" required inputmode="numeric" pattern="[0-9]{8}" maxlength="8" placeholder="12345678" class="crear-input crear-input-prefixed">
            </div>
          </div>
          <div class="crear-field">
            <label for="base_price_clp" class="crear-label">Precio Base</label>
            <div class="crear-input-wrapper">
              <span class="crear-input-prefix">$</span>
              <input id="base_price_clp" name="base_price_clp" type="number" required min="1000" max="9999999" step="1000" placeholder="10000" class="crear-input crear-input-prefixed">
            </div>
          </div>
        </div>
      </section>

      <section class="crear-section">
        <h3 class="crear-section-title">3. Cobertura de Comunas</h3>
        <p class="crear-label说明">¿En qué comunas atiendes?</p>
        <div class="crear-communes-grid">
          {communeList.map((c) => (
            <label class="crear-commune-label">
              <input type="checkbox" name="commune_ids" value={c.id} class="crear-checkbox">
              {c.name}
            </label>
          ))}
        </div>
      </section>

      <section class="crear-section">
        <h3 class="crear-section-title">4. Verificación</h3>

        <div class="crear-upload-zone js-upload-cert">
          <i class="ri-file-upload-line"></i>
          <p class="crear-upload-text">Subir Certificado</p>
          <p class="crear-upload-sub">(Próximamente — HU-12.6)</p>
        </div>
      </section>

      <div class="crear-actions">
        <a href="/dashboard" class="crear-btn crear-btn-secondary">Volver</a>
        <button type="submit" class="crear-btn crear-btn-primary">Crear Perfil</button>
      </div>
    </form>
  </main>

  <style>
    .crear-oficio-main {
      max-width: 42rem;
      margin: 0 auto;
      padding: 2rem 1rem;
    }

    .crear-oficio-header {
      text-align: center;
      margin-bottom: 2rem;
    }

    .crear-oficio-icon {
      width: 3rem;
      height: 3rem;
      border-radius: 50%;
      background: var(--orange-100);
      color: var(--orange-500);
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 0.75rem;
      font-size: 1.5rem;
    }

    .crear-oficio-title {
      font-size: 1.5rem;
      font-weight: 800;
      color: var(--text-primary);
    }

    .crear-oficio-subtitle {
      color: var(--text-secondary);
      font-size: 0.875rem;
      margin-top: 0.25rem;
    }

    .crear-oficio-error {
      background: #fef2f2;
      border: 1px solid #fecaca;
      color: #b91c1c;
      padding: 1rem;
      border-radius: var(--radius-xl);
      margin-bottom: 1.5rem;
      font-size: 0.875rem;
    }

    .crear-section {
      background: white;
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow-card);
      border: 1px solid var(--border-default);
      padding: 1.5rem;
      margin-bottom: 1.5rem;
    }

    .crear-section-title {
      font-weight: 700;
      font-size: 1rem;
      color: var(--text-primary);
      margin-bottom: 1rem;
      padding-bottom: 0.75rem;
      border-bottom: 1px solid var(--border-light);
    }

    .crear-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }

    @media (max-width: 640px) {
      .crear-grid {
        grid-template-columns: 1fr;
      }
    }

    .crear-field {
      display: flex;
      flex-direction: column;
    }

    .crear-field-full {
      grid-column: 1 / -1;
    }

    .crear-label {
      font-size: 0.6875rem;
      font-weight: 700;
      color: var(--stone-700);
      margin-bottom: 0.25rem;
    }

    .crear-label说明 {
      font-size: 0.75rem;
      color: var(--text-muted);
      margin-bottom: 0.75rem;
    }

    .crear-input,
    .crear-select,
    .crear-textarea {
      background: var(--stone-50);
      border: 1px solid var(--border-default);
      border-radius: var(--radius-lg);
      padding: 0.5rem 0.75rem;
      font-size: 0.875rem;
      color: var(--text-primary);
      transition: all 200ms ease;
      width: 100%;
    }

    .crear-input:focus,
    .crear-select:focus,
    .crear-textarea:focus {
      outline: none;
      border-color: var(--amber-400);
      box-shadow: 0 0 0 3px var(--amber-100);
    }

    .crear-input-wrapper {
      position: relative;
    }

    .crear-input-prefix {
      position: absolute;
      left: 0.75rem;
      top: 50%;
      transform: translateY(-50%);
      color: var(--text-muted);
      font-size: 0.875rem;
    }

    .crear-input-prefixed {
      padding-left: 3rem;
    }

    .crear-communes-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0.5rem;
      max-height: 12rem;
      overflow-y: auto;
      border: 1px solid var(--border-default);
      border-radius: var(--radius-xl);
      padding: 0.5rem;
    }

    @media (min-width: 768px) {
      .crear-communes-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    .crear-commune-label {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5rem;
      border-radius: var(--radius-lg);
      cursor: pointer;
      font-size: 0.875rem;
      color: var(--text-secondary);
      transition: all 200ms ease;
    }

    .crear-commune-label:hover {
      background: var(--stone-50);
      color: var(--text-primary);
    }

    .crear-checkbox {
      accent-color: var(--orange-500);
      border-radius: 0.25rem;
      width: 1rem;
      height: 1rem;
    }

    .crear-upload-zone {
      border: 2px dashed var(--border-default);
      border-radius: var(--radius-xl);
      padding: 1.5rem;
      text-align: center;
      cursor: pointer;
      transition: all 200ms ease;
    }

    .crear-upload-zone:hover {
      border-color: var(--amber-400);
      background: var(--amber-50);
    }

    .crear-upload-zone i {
      font-size: 1.5rem;
      color: var(--stone-300);
      margin-bottom: 0.25rem;
    }

    .crear-upload-text {
      font-size: 0.75rem;
      font-weight: 700;
      color: var(--text-secondary);
    }

    .crear-upload-sub {
      font-size: 0.625rem;
      color: var(--text-muted);
      margin-top: 0.25rem;
    }

    .crear-actions {
      display: flex;
      gap: 0.75rem;
      padding-top: 0.5rem;
    }

    .crear-btn {
      flex: 1;
      padding: 0.75rem;
      border-radius: var(--radius-xl);
      text-align: center;
      font-weight: 700;
      font-size: 0.875rem;
      transition: all 200ms ease;
      display: flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
    }

    .crear-btn-secondary {
      background: var(--stone-100);
      color: var(--text-muted);
      border: 1px solid var(--border-default);
    }

    .crear-btn-secondary:hover {
      background: var(--stone-200);
      color: var(--text-primary);
    }

    .crear-btn-primary {
      flex: 2;
      background: var(--orange-500);
      color: white;
      box-shadow: var(--shadow-btn);
    }

    .crear-btn-primary:hover {
      background: var(--orange-600);
    }
  </style>

  <script>
    import { initCreateTradeForm } from '../lib/client/trades/create-trade';
    initCreateTradeForm();
  </script>
</BaseLayout>
