---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getDb } from '../database/client';
import { communes } from '../database/schema';
import { asc } from 'drizzle-orm';

const usuario = Astro.locals.user;
if (!usuario) {
  return Astro.redirect('/iniciar-sesion?redirigir=/crear-oficio');
}

const db = getDb(Astro.locals);
const communesList = await db
  .select()
  .from(communes)
  .orderBy(asc(communes.name))
  .all();

const error = Astro.url.searchParams.get('error');
---

<BaseLayout title="Crear oficio — QuiénSabe">
  <main class="container mx-auto px-4 py-8 max-w-2xl">
    <a href="/dashboard" class="text-sm text-gray-500 hover:text-gray-700 mb-4 inline-block">
      ← Volver a mi panel
    </a>

    <header class="mb-8">
      <h1 class="text-3xl font-extrabold text-gray-800 mb-2">Publica tu oficio</h1>
      <p class="text-gray-600">
        Cuenta brevemente qué haces, en qué comuna trabajas y cuánto cobras.
        Los vecinos te van a encontrar cuando busquen tu especialidad.
      </p>
    </header>

    {error && (
      <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl mb-6 text-sm">
        {error}
      </div>
    )}

    <form action="/api/v1/trades" method="POST" class="bg-white rounded-3xl shadow-sm border border-gray-100 p-8 space-y-6">
      <div>
        <label for="name" class="block text-sm font-bold text-gray-700 mb-2">
          Nombre del servicio <span class="text-red-500">*</span>
        </label>
        <input
          id="name"
          name="name"
          type="text"
          required
          maxlength="120"
          placeholder="ej. Gasfiter a domicilio"
          class="w-full p-3 rounded-xl border border-gray-200 focus:border-orange-500 focus:ring-2 focus:ring-orange-200"
        />
        <p class="text-xs text-gray-500 mt-1">Sé específico: en lugar de "Servicios", usa "Reparación de calefones".</p>
      </div>

      <div>
        <label for="symbol" class="block text-sm font-bold text-gray-700 mb-2">
          Categoría <span class="text-red-500">*</span>
        </label>
        <select
          id="symbol"
          name="symbol"
          required
          class="w-full p-3 rounded-xl border border-gray-200 focus:border-orange-500 focus:ring-2 focus:ring-orange-200 bg-white"
        >
          <option value="">Selecciona...</option>
          <option value="gasfiter">Gasfiter</option>
          <option value="electricista">Electricista</option>
          <option value="jardinero">Jardinero</option>
          <option value="pintor">Pintor</option>
          <option value="costurera">Costurera</option>
          <option value="programador">Programador</option>
          <option value="cerrajero">Cerrajero</option>
          <option value="mecanico">Mecánico</option>
          <option value="limpieza">Limpieza</option>
          <option value="mudanza">Mudanza</option>
          <option value="otro">Otro</option>
        </select>
      </div>

      <div>
        <label for="description" class="block text-sm font-bold text-gray-700 mb-2">
          Descripción <span class="text-red-500">*</span>
        </label>
        <textarea
          id="description"
          name="description"
          required
          rows="5"
          maxlength="1000"
          placeholder="Cuenta brevemente qué ofreces, tu experiencia, y por qué te elegirían a ti."
          class="w-full p-3 rounded-xl border border-gray-200 focus:border-orange-500 focus:ring-2 focus:ring-orange-200 resize-none"
        ></textarea>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label for="commune_id" class="block text-sm font-bold text-gray-700 mb-2">
            Comuna principal <span class="text-red-500">*</span>
          </label>
          <select
            id="commune_id"
            name="commune_id"
            required
            class="w-full p-3 rounded-xl border border-gray-200 focus:border-orange-500 focus:ring-2 focus:ring-orange-200 bg-white"
          >
            <option value="">Selecciona...</option>
            {communesList.map((c) => (
              <option value={c.id}>{c.name}</option>
            ))}
          </select>
        </div>

        <div>
          <label for="base_price_clp" class="block text-sm font-bold text-gray-700 mb-2">
            Precio base (CLP) <span class="text-red-500">*</span>
          </label>
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-500 font-bold">$</span>
            <input
              id="base_price_clp"
              name="base_price_clp"
              type="number"
              required
              min="1000"
              max="9999999"
              step="1000"
              placeholder="15000"
              class="w-full pl-8 pr-3 py-3 rounded-xl border border-gray-200 focus:border-orange-500 focus:ring-2 focus:ring-orange-200"
            />
          </div>
          <p class="text-xs text-gray-500 mt-1">Por visita / consulta inicial.</p>
        </div>
      </div>

      <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-4 text-sm text-yellow-800 flex gap-2">
        <i class="ri-information-line text-lg flex-shrink-0 mt-0.5"></i>
        <p>
          Tu oficio se publica como <b>no verificado</b>. Para obtener el badge de verificación,
          sube tu RUT y certificaciones desde tu panel.
        </p>
      </div>

      <div class="flex gap-3 pt-4 border-t border-gray-100">
        <a href="/dashboard" class="flex-1 text-center bg-gray-50 hover:bg-gray-100 text-gray-700 px-6 py-3 rounded-xl font-bold transition">
          Cancelar
        </a>
        <button
          type="submit"
          class="flex-1 bg-orange-500 hover:bg-orange-600 text-white px-6 py-3 rounded-xl font-bold transition shadow-md"
        >
          <i class="ri-rocket-line"></i> Publicar oficio
        </button>
      </div>
    </form>
  </main>
</BaseLayout>