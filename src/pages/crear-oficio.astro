---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getDb } from '../database/client';
import { communes } from '../database/schema';
import { asc } from 'drizzle-orm';

const currentUser = Astro.locals.user;
if (!currentUser) {
  return Astro.redirect('/iniciar-sesion?redirigir=/crear-oficio');
}

const error = Astro.url.searchParams.get('error');

const db = getDb(Astro.locals);
const communeList = await db.select({ id: communes.id, name: communes.name }).from(communes).orderBy(asc(communes.name)).all();

const OFICIOS = [
  { value: '', label: 'Selecciona tu oficio…' },
  { value: 'gasfiter', label: 'Gasfiter' },
  { value: 'electricista', label: 'Electricista' },
  { value: 'jardinero', label: 'Jardinero' },
  { value: 'maestro', label: 'Maestro' },
  { value: 'costurera', label: 'Costurera' },
  { value: 'otro', label: 'Otro' },
];
---

<BaseLayout title="Crear Nuevo Oficio — QuiénSabe">
  <nav class="bg-white shadow-sm sticky top-0 z-50">
    <div class="container mx-auto px-4 py-3 flex justify-between items-center">
      <a href="/" class="text-xl font-bold text-gray-800 flex items-center gap-2">
        <i class="ri-community-line text-orange-500"></i>
        Quién<span class="text-orange-500">Sabe</span>
      </a>
      <a href="/dashboard" class="text-sm text-gray-500 hover:text-orange-500 font-bold">Cancelar</a>
    </div>
  </nav>

  <main class="container mx-auto px-4 py-8 max-w-2xl">
    <div class="text-center mb-8">
      <div class="w-12 h-12 bg-orange-100 rounded-full flex items-center justify-center mx-auto mb-3 text-orange-500 text-2xl">
        <i class="ri-briefcase-line"></i>
      </div>
      <h1 class="text-2xl font-extrabold text-gray-800">Ofrece tus servicios</h1>
      <p class="text-gray-500 text-sm">Completa tu perfil profesional.</p>
    </div>

    {error && (
      <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl mb-6 text-sm">
        {error}
      </div>
    )}

    <form action="/api/v1/trades" method="POST" class="space-y-6" id="form-crear-oficio">
      <section class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
        <h3 class="font-bold text-gray-800 text-base mb-4 border-b border-gray-100 pb-2">1. Información Básica</h3>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label for="name" class="block text-xs font-bold text-gray-700 mb-1">Nombre Visible</label>
            <input id="name" name="name" type="text" required minlength="3" maxlength="120" placeholder="Ej: Juan Pérez" class="w-full bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500/50 transition">
          </div>
          <div>
            <label for="symbol" class="block text-xs font-bold text-gray-700 mb-1">Oficio</label>
            <select id="symbol" name="symbol" required class="w-full bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500/50 transition js-oficio-select">
              {OFICIOS.map((o) => (
                <option value={o.value}>{o.label}</option>
              ))}
            </select>
          </div>
          <div class="md:col-span-2" data-oficio-otro hidden>
            <label for="symbol_custom" class="block text-xs font-bold text-gray-700 mb-1">Especifica tu oficio</label>
            <input id="symbol_custom" name="symbol_custom" type="text" maxlength="30" placeholder="Ej: yesero, tapicero, soldador…" class="w-full bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500/50 transition">
          </div>
          <div class="md:col-span-2">
            <label for="description" class="block text-xs font-bold text-gray-700 mb-1">Descripción Corta (Bio)</label>
            <textarea id="description" name="description" rows="2" required minlength="20" maxlength="1000" placeholder="Cuenta brevemente tu experiencia…" class="w-full bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500/50 transition"></textarea>
          </div>
        </div>
      </section>

      <section class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
        <h3 class="font-bold text-gray-800 text-base mb-4 border-b border-gray-100 pb-2">2. Contacto y Precios</h3>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label for="whatsapp" class="block text-xs font-bold text-gray-700 mb-1">WhatsApp</label>
            <div class="relative">
              <span class="absolute left-3 top-2 text-gray-400 text-sm">+56 9</span>
              <input id="whatsapp" name="whatsapp" type="tel" required inputmode="numeric" pattern="[0-9]{8}" maxlength="8" placeholder="12345678" class="w-full bg-gray-50 border border-gray-200 rounded-lg pl-14 pr-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500/50 transition">
            </div>
          </div>
          <div>
            <label for="base_price_clp" class="block text-xs font-bold text-gray-700 mb-1">Precio Base</label>
            <div class="relative">
              <span class="absolute left-3 top-2 text-gray-400 text-sm">$</span>
              <input id="base_price_clp" name="base_price_clp" type="number" required min="1000" max="9999999" step="1000" placeholder="10000" class="w-full bg-gray-50 border border-gray-200 rounded-lg pl-6 pr-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500/50 transition">
            </div>
          </div>
        </div>
      </section>

      <section class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
        <h3 class="font-bold text-gray-800 text-base mb-4 border-b border-gray-100 pb-2">3. Cobertura de Comunas</h3>
        <p class="text-xs text-gray-500 mb-3">¿En qué comunas atiendes?</p>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-2 max-h-48 overflow-y-auto border border-gray-200 rounded-xl p-2">
          {communeList.map((c) => (
            <label class="flex items-center gap-2 p-2 hover:bg-gray-50 rounded-lg cursor-pointer text-sm">
              <input type="checkbox" name="commune_ids" value={c.id} class="accent-orange-500 rounded" />
              {c.name}
            </label>
          ))}
        </div>
      </section>

      <section class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
        <h3 class="font-bold text-gray-800 text-base mb-4 border-b border-gray-100 pb-2">4. Verificación</h3>

        <div class="border-2 border-dashed border-gray-200 rounded-xl p-6 text-center hover:border-orange-500 hover:bg-orange-50 transition cursor-pointer js-upload-cert">
          <i class="ri-file-upload-line text-2xl text-gray-300 mb-1"></i>
          <p class="text-xs text-gray-600 font-bold">Subir Certificado</p>
          <p class="text-[10px] text-gray-400 mt-1">(Próximamente — HU-12.6)</p>
        </div>
      </section>

      <div class="flex gap-3 pt-2">
        <a href="/dashboard" class="flex-1 py-3 rounded-xl text-center font-bold text-gray-500 hover:bg-gray-100 transition text-sm flex items-center justify-center">Volver</a>
        <button type="submit" class="flex-[2] bg-orange-500 text-white py-3 rounded-xl font-bold hover:bg-orange-600 transition shadow-md text-sm">
          Crear Perfil
        </button>
      </div>
    </form>
  </main>

  <script>
    import { initCreateTradeForm } from '../lib/client/trades/create-trade';
    initCreateTradeForm();
  </script>
</BaseLayout>
