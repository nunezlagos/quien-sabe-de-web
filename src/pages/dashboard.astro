---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getDb } from '../database/client';
import { trades, communes, reviews } from '../database/schema';
import { eq, desc, avg, count, sql } from 'drizzle-orm';

const usuario = Astro.locals.user;
if (!usuario) {
  return Astro.redirect('/iniciar-sesion?redirigir=/dashboard');
}

const url = Astro.url;
const tab = url.searchParams.get('tab') ?? 'oficios';

const db = getDb(Astro.locals);

const misOficios = await db
  .select({
    id: trades.id,
    slug: trades.slug,
    name: trades.name,
    symbol: trades.symbol,
    basePriceClp: trades.basePriceClp,
    verified: trades.verified,
    status: trades.status,
    communeId: trades.communeId,
    communeName: communes.name,
    ratingAvg: avg(reviews.rating),
    reviewCount: count(reviews.id),
  })
  .from(trades)
  .leftJoin(communes, eq(trades.communeId, communes.id))
  .leftJoin(reviews, eq(reviews.tradeId, trades.id))
  .where(eq(trades.userId, usuario.id))
  .groupBy(trades.id)
  .orderBy(desc(trades.createdAt))
  .all();
---

<BaseLayout title={`Mi panel — ${usuario.name}`}>
  <main class="container mx-auto px-4 py-8 max-w-4xl">
    <header class="bg-white rounded-3xl shadow-sm border border-gray-100 p-6 mb-6">
      <div class="flex items-center gap-4">
        <div class="w-16 h-16 rounded-full bg-orange-100 flex items-center justify-center text-orange-500 font-extrabold text-2xl flex-shrink-0">
          {usuario.name.slice(0, 1).toUpperCase()}
        </div>
        <div class="flex-1">
          <h1 class="text-2xl font-extrabold text-gray-800">Hola, {usuario.name}</h1>
          <p class="text-sm text-gray-500">{usuario.email}</p>
        </div>
        <div class="flex gap-2">
          <span class={`px-3 py-1 rounded-full text-xs font-bold ${usuario.role === 'admin' ? 'bg-purple-100 text-purple-700' : usuario.role === 'provider' ? 'bg-blue-100 text-blue-700' : 'bg-green-100 text-green-700'}`}>
            {usuario.role}
          </span>
          <span class="px-3 py-1 rounded-full text-xs font-bold bg-green-100 text-green-700">
            ● Activo
          </span>
        </div>
      </div>
    </header>

    <nav class="bg-white rounded-2xl shadow-sm border border-gray-100 p-2 mb-6 flex gap-1">
      <a
        href="/dashboard?tab=oficios"
        class={`flex-1 px-4 py-2.5 rounded-xl font-bold text-sm text-center transition ${tab === 'oficios' ? 'bg-orange-500 text-white shadow-sm' : 'text-gray-600 hover:bg-gray-50'}`}
      >
        <i class="ri-briefcase-line"></i> Mis oficios ({misOficios.length})
      </a>
      <a
        href="/dashboard?tab=perfil"
        class={`flex-1 px-4 py-2.5 rounded-xl font-bold text-sm text-center transition ${tab === 'perfil' ? 'bg-orange-500 text-white shadow-sm' : 'text-gray-600 hover:bg-gray-50'}`}
      >
        <i class="ri-user-settings-line"></i> Mi perfil
      </a>
    </nav>

    {tab === 'oficios' && (
      <section>
        {misOficios.length === 0 ? (
          <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-12 text-center">
            <i class="ri-briefcase-line text-6xl text-gray-300 mb-4 block"></i>
            <h2 class="text-2xl font-extrabold text-gray-800 mb-2">Aún no tienes oficios publicados</h2>
            <p class="text-gray-500 mb-6">Publica tu primer oficio para que los vecinos te encuentren.</p>
            <a href="/crear-oficio" class="inline-block bg-orange-500 hover:bg-orange-600 text-white px-6 py-3 rounded-xl font-bold transition shadow-md">
              <i class="ri-add-line"></i> Publicar mi primer oficio
            </a>
          </div>
        ) : (
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {misOficios.map((t) => (
              <article class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5">
                <div class="flex justify-between items-start mb-3">
                  <div>
                    <span class="text-xs uppercase tracking-wide font-bold text-orange-600 bg-orange-100 px-2 py-1 rounded-full">
                      {t.symbol}
                    </span>
                    {t.verified ? (
                      <span class="ml-2 text-xs font-bold text-blue-500">
                        <i class="ri-shield-check-fill"></i> Verificado
                      </span>
                    ) : null}
                  </div>
                  <span class={`text-xs font-bold px-2 py-1 rounded-full ${t.status === 'active' ? 'bg-green-100 text-green-700' : 'bg-orange-100 text-orange-700'}`}>
                    {t.status === 'active' ? 'Activo' : 'Pausado'}
                  </span>
                </div>
                <h3 class="font-bold text-gray-800 text-lg mb-1">{t.name}</h3>
                <p class="text-sm text-gray-500 mb-3">
                  {t.communeName ?? 'RM'} · ${(t.basePriceClp ?? 0).toLocaleString('es-CL')}
                </p>
                {Number(t.reviewCount) > 0 && (
                  <p class="text-sm text-gray-600 mb-3">
                    <i class="ri-star-fill text-yellow-400"></i>
                    <b>{(Number(t.ratingAvg) || 0).toFixed(1)}</b>
                    <span class="text-gray-400"> · {t.reviewCount} reseñas</span>
                  </p>
                )}
                <div class="flex gap-2 pt-3 border-t border-gray-100">
                  <a href={`/p/${t.slug}`} class="flex-1 text-center bg-gray-50 hover:bg-gray-100 text-gray-700 px-3 py-2 rounded-lg text-xs font-bold">
                    Ver público
                  </a>
                  <a href={`/dashboard/oficio/${t.id}`} class="flex-1 text-center bg-orange-500 hover:bg-orange-600 text-white px-3 py-2 rounded-lg text-xs font-bold">
                    Editar
                  </a>
                </div>
              </article>
            ))}
            <a
              href="/crear-oficio"
              class="bg-white border-2 border-dashed border-gray-300 hover:border-orange-500 rounded-2xl p-5 flex flex-col items-center justify-center text-gray-500 hover:text-orange-500 transition min-h-[180px]"
            >
              <i class="ri-add-line text-4xl mb-2"></i>
              <span class="font-bold text-sm">Publicar otro oficio</span>
            </a>
          </div>
        )}
      </section>
    )}

    {tab === 'perfil' && (
      <section class="bg-white rounded-3xl shadow-sm border border-gray-100 p-8">
        <h2 class="text-2xl font-extrabold text-gray-800 mb-6">Datos de tu cuenta</h2>
        <dl class="space-y-4">
          <div class="flex justify-between border-b border-gray-100 pb-3">
            <dt class="text-gray-500">Nombre</dt>
            <dd class="font-bold text-gray-800">{usuario.name}</dd>
          </div>
          <div class="flex justify-between border-b border-gray-100 pb-3">
            <dt class="text-gray-500">Email</dt>
            <dd class="font-bold text-gray-800">{usuario.email}</dd>
          </div>
          <div class="flex justify-between border-b border-gray-100 pb-3">
            <dt class="text-gray-500">Rol</dt>
            <dd class="font-bold text-gray-800 capitalize">{usuario.role}</dd>
          </div>
          <div class="flex justify-between border-b border-gray-100 pb-3">
            <dt class="text-gray-500">ID</dt>
            <dd class="font-bold text-gray-800">#{usuario.id}</dd>
          </div>
        </dl>
        <div class="mt-6 flex gap-3">
          <form method="POST" action="/api/v1/auth/cerrar-sesion" class="contents js-logout-form">
            <button type="submit" class="bg-gray-900 hover:bg-red-600 text-white px-6 py-2.5 rounded-xl font-bold transition">
              <i class="ri-logout-box-r-line"></i> Cerrar sesión
            </button>
          </form>
        </div>
      </section>
    )}
  </main>
</BaseLayout>