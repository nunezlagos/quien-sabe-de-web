---
import BaseLayout from '../layouts/BaseLayout.astro';

const usuario = Astro.locals.user;
if (!usuario) {
	return Astro.redirect('/iniciar-sesion?redirigir=/dashboard');
}
---

<BaseLayout title="Mi panel — QuiénSabe">
	<main class="container mx-auto px-4 py-12 max-w-3xl">
		<div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-8">
			<div class="flex items-center gap-4 mb-6">
				<div class="w-16 h-16 rounded-full bg-orange-100 flex items-center justify-center text-orange-500 font-extrabold text-2xl">
					{usuario.name.charAt(0).toUpperCase()}
				</div>
				<div>
					<h1 class="text-2xl font-extrabold text-gray-800">Hola, {usuario.name}</h1>
					<p class="text-gray-500 text-sm">{usuario.email}</p>
				</div>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-4">
				<div class="rounded-2xl border border-gray-100 p-4">
					<h2 class="text-xs uppercase font-bold text-gray-400 mb-2">Rol</h2>
					<p class="font-bold text-gray-800 capitalize">{usuario.role}</p>
				</div>
				<div class="rounded-2xl border border-gray-100 p-4">
					<h2 class="text-xs uppercase font-bold text-gray-400 mb-2">Estado</h2>
					<p class="font-bold text-green-600 capitalize">{usuario.status === 'active' ? 'Activa' : usuario.status}</p>
				</div>
				<div class="rounded-2xl border border-gray-100 p-4">
					<h2 class="text-xs uppercase font-bold text-gray-400 mb-2">ID</h2>
					<p class="font-bold text-gray-800">#{usuario.id}</p>
				</div>
			</div>

			<div class="mt-8 p-4 rounded-2xl bg-orange-50 border border-orange-100 text-sm text-orange-900">
				<p class="font-bold mb-1">MVP activo</p>
				<p>Esta es una vista mínima. Próximamente verás tus búsquedas guardadas, contactos, reseñas y configuración.</p>
			</div>

			<form method="POST" action="/api/v1/auth/cerrar-sesion" class="mt-6 js-logout-form" id="form-cerrar-sesion-dashboard">
				<button type="submit" class="w-full md:w-auto bg-gray-900 text-white px-6 py-3 rounded-xl font-bold hover:bg-red-600 transition">
					Cerrar sesión
				</button>
			</form>
		</div>
	</main>
</BaseLayout>