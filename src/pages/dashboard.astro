---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactsHistory from '../components/dashboard/ContactsHistory.astro';
import MyReviews from '../components/dashboard/MyReviews.astro';
import RecentViews from '../components/dashboard/RecentViews.astro';
import EditProfileModal from '../components/dashboard/EditProfileModal.astro';
import { getDb } from '../database/client';
import { trades, communes, reviews, contactEvents, favorites, users, userViews } from '../database/schema';
import { eq, desc, asc, avg, count, inArray } from 'drizzle-orm';

const currentUser = Astro.locals.user;
if (!currentUser) {
  return Astro.redirect('/iniciar-sesion?redirigir=/dashboard');
}

const url = Astro.url;
const tabParam = url.searchParams.get('tab') ?? 'historial';
const tab = (['historial', 'resenas', 'perfil'] as const).find((t) => t === tabParam) ?? 'historial';

const db = getDb();

const allCommunes = await db
  .select({ id: communes.id, name: communes.name })
  .from(communes)
  .orderBy(asc(communes.name))
  .all();

const myTrades = await db
  .select({
    id: trades.id,
    slug: trades.slug,
    name: trades.name,
    symbol: trades.symbol,
    basePriceClp: trades.basePriceClp,
    verified: trades.verified,
    status: trades.status,
    communeId: trades.communeId,
    communeName: communes.name,
    ratingAvg: avg(reviews.rating),
    reviewCount: count(reviews.id),
  })
  .from(trades)
  .leftJoin(communes, eq(trades.communeId, communes.id))
  .leftJoin(reviews, eq(reviews.tradeId, trades.id))
  .where(eq(trades.userId, currentUser.id))
  .groupBy(trades.id)
  .orderBy(desc(trades.createdAt))
  .all();

// Recent reviews (all, since we don't have user_id in reviews table yet)
const recentReviews = await db
  .select()
  .from(reviews)
  .orderBy(desc(reviews.createdAt))
  .limit(10)
  .all();

// Contact history for this user's trades (if any)
const myTradeIds = myTrades.map((t) => t.id);
const contactHistory = myTradeIds.length > 0
  ? await db
      .select()
      .from(contactEvents)
      .where(inArray(contactEvents.tradeId, myTradeIds))
      .orderBy(desc(contactEvents.createdAt))
      .limit(20)
      .all()
  : [];

// Contact history for this user (as a visitor / vecino)
const myContacts = await db
  .select({
    id: contactEvents.id,
    eventType: contactEvents.eventType,
    tradeId: contactEvents.tradeId,
    tradeName: trades.name,
    tradeSlug: trades.slug,
    createdAt: contactEvents.createdAt,
  })
  .from(contactEvents)
  .innerJoin(trades, eq(contactEvents.tradeId, trades.id))
  .where(eq(contactEvents.userId, currentUser.id))
  .orderBy(desc(contactEvents.createdAt))
  .limit(50)
  .all();

// Reviews written by this user
const myReviews = await db
  .select({
    id: reviews.id,
    tradeId: reviews.tradeId,
    tradeName: trades.name,
    tradeSlug: trades.slug,
    rating: reviews.rating,
    body: reviews.body,
    createdAt: reviews.createdAt,
  })
  .from(reviews)
  .innerJoin(trades, eq(reviews.tradeId, trades.id))
  .where(eq(reviews.userId, currentUser.id))
  .orderBy(desc(reviews.createdAt))
  .limit(50)
  .all();

// Recent views
const recentViews = await db
  .select({
    id: userViews.id,
    tradeId: userViews.tradeId,
    tradeName: trades.name,
    tradeSlug: trades.slug,
    createdAt: userViews.createdAt,
  })
  .from(userViews)
  .innerJoin(trades, eq(userViews.tradeId, trades.id))
  .where(eq(userViews.userId, currentUser.id))
  .orderBy(desc(userViews.createdAt))
  .limit(10)
  .all();

const myFavorites = await db
  .select({
    id: trades.id,
    name: trades.name,
    slug: trades.slug,
    symbol: trades.symbol,
    basePriceClp: trades.basePriceClp,
    userName: users.name,
  })
  .from(favorites)
  .innerJoin(trades, eq(favorites.tradeId, trades.id))
  .innerJoin(users, eq(trades.userId, users.id))
  .where(eq(favorites.userId, currentUser.id))
  .orderBy(desc(favorites.createdAt))
  .all();
---

<BaseLayout title={`Mi panel — ${currentUser.name}`}>
  <main class="container mx-auto px-4 py-8 max-w-4xl">
    {!currentUser.emailVerified ? (
      <div class="bg-yellow-50 border-2 border-yellow-200 rounded-2xl p-4 flex items-start gap-3 mb-6">
        <i class="ri-mail-unread-line text-yellow-700 text-2xl flex-shrink-0"></i>
        <div class="flex-1">
          <h4 class="font-bold text-yellow-900 text-sm">Verifica tu email</h4>
          <p class="text-yellow-800 text-xs mt-1">Revisa <b>{currentUser.email}</b> y haz clic en el enlace de verificación. ¿No lo recibiste?</p>
        </div>
        <button id="btn-resend-verification" class="text-yellow-700 hover:text-yellow-900 text-xs font-bold underline flex-shrink-0" data-email={currentUser.email}>Reenviar</button>
      </div>
    ) : null}

    <header class="bg-white rounded-3xl shadow-sm border border-gray-100 p-6 mb-6">
      <div class="flex items-center gap-4">
        <div class="w-16 h-16 rounded-full bg-orange-100 flex items-center justify-center text-orange-500 font-extrabold text-2xl flex-shrink-0">
          {currentUser.name.slice(0, 1).toUpperCase()}
        </div>
        <div class="flex-1">
          <h1 class="text-2xl font-extrabold text-gray-800">Hola, {currentUser.name}</h1>
          <p class="text-sm text-gray-500">{currentUser.email}</p>
        </div>
        <div class="flex gap-2">
          <span class={`px-3 py-1 rounded-full text-xs font-bold ${currentUser.role === 'admin' ? 'bg-purple-100 text-purple-700' : currentUser.role === 'provider' ? 'bg-blue-100 text-blue-700' : 'bg-green-100 text-green-700'}`}>
            {currentUser.role}
          </span>
          <span class="px-3 py-1 rounded-full text-xs font-bold bg-green-100 text-green-700">
            ● Activo
          </span>
        </div>
      </div>
    </header>

    <nav class="bg-white rounded-2xl shadow-sm border border-gray-100 p-2 mb-6 flex gap-1" aria-label="Secciones del panel">
      <a
        href="/dashboard?tab=historial"
        class={`flex-1 px-4 py-2.5 rounded-xl font-bold text-sm text-center transition ${tab === 'historial' ? 'bg-orange-500 text-white shadow-sm' : 'text-gray-600 hover:bg-gray-50'}`}
      >
        <i class="ri-time-line"></i> Historial
      </a>
      <a
        href="/dashboard?tab=resenas"
        class={`flex-1 px-4 py-2.5 rounded-xl font-bold text-sm text-center transition ${tab === 'resenas' ? 'bg-orange-500 text-white shadow-sm' : 'text-gray-600 hover:bg-gray-50'}`}
      >
        <i class="ri-star-smile-line"></i> Mis reseñas
      </a>
      <a
        href="/dashboard?tab=perfil"
        class={`flex-1 px-4 py-2.5 rounded-xl font-bold text-sm text-center transition ${tab === 'perfil' ? 'bg-orange-500 text-white shadow-sm' : 'text-gray-600 hover:bg-gray-50'}`}
      >
        <i class="ri-user-settings-line"></i> Perfil
      </a>
    </nav>

    {tab === 'historial' && (
      <section class="space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <a
            href="/"
            class="block p-6 bg-white rounded-3xl shadow-sm border border-gray-100 hover:border-orange-500/50 hover:shadow-md transition group text-left relative overflow-hidden"
          >
            <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition">
              <i class="ri-search-eye-line text-6xl text-orange-500"></i>
            </div>
            <div class="w-12 h-12 bg-blue-50 rounded-2xl flex items-center justify-center text-blue-500 text-2xl mb-4 group-hover:scale-110 transition">
              <i class="ri-search-line"></i>
            </div>
            <h3 class="font-bold text-gray-800 text-lg">Buscar Oficios</h3>
            <p class="text-xs text-gray-500 mt-1 font-medium">Encuentra gasfíteres, electricistas y más cerca de ti.</p>
          </a>

          <div class="p-6 bg-white border border-gray-100 rounded-3xl text-left shadow-sm relative overflow-hidden group">
            <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition">
              <i class="ri-briefcase-line text-6xl text-gray-500"></i>
            </div>
            <div class="w-12 h-12 bg-green-50 rounded-2xl flex items-center justify-center text-green-500 text-2xl mb-4 group-hover:scale-110 transition">
              <i class="ri-hammer-line"></i>
            </div>
            <h3 class="font-bold text-gray-800 text-lg">¿Ofreces un servicio?</h3>
            <p class="text-xs text-gray-500 mt-1 mb-4 font-medium">Crea tu perfil profesional y llega a más vecinos.</p>
            <a
              href="/crear-oficio"
              class="inline-block text-center bg-gray-800 text-white px-5 py-2 rounded-xl text-xs font-bold hover:bg-gray-700 transition shadow-md"
            >
              Crear Perfil PRO
            </a>
          </div>
        </div>

        {myTrades.length > 0 && (
          <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-6">
            <div class="flex items-center justify-between mb-4">
              <h3 class="font-bold text-gray-800 text-lg flex items-center gap-2">
                <i class="ri-briefcase-line text-orange-500"></i> Mis oficios publicados ({myTrades.length})
              </h3>
              <a
                href="/crear-oficio"
                class="text-xs font-bold text-orange-500 hover:text-orange-600 transition"
              >
                <i class="ri-add-line"></i> Publicar otro
              </a>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              {myTrades.map((t) => (
                <article class="bg-gray-50 rounded-2xl border border-gray-100 p-4">
                  <div class="flex justify-between items-start mb-2">
                    <span class="text-xs uppercase tracking-wide font-bold text-orange-600 bg-orange-100 px-2 py-1 rounded-full">
                      {t.symbol}
                    </span>
                    <span class={`text-xs font-bold px-2 py-1 rounded-full ${t.status === 'active' ? 'bg-green-100 text-green-700' : 'bg-orange-100 text-orange-700'}`}>
                      {t.status === 'active' ? 'Activo' : 'Pausado'}
                    </span>
                  </div>
                  <h4 class="font-bold text-gray-800 text-base mb-1">{t.name}</h4>
                  <p class="text-xs text-gray-500 mb-3">
                    {t.communeName ?? 'RM'} · ${(t.basePriceClp ?? 0).toLocaleString('es-CL')}
                  </p>
                  <div class="flex gap-2 pt-3 border-t border-gray-100">
                    <a
                      href={`/p/${t.slug}`}
                      class="flex-1 text-center bg-white hover:bg-gray-100 text-gray-700 px-3 py-1.5 rounded-lg text-xs font-bold border border-gray-200"
                    >
                      Ver público
                    </a>
                    <a
                      href={`/dashboard/oficio/${t.id}`}
                      class="flex-1 text-center bg-orange-500 hover:bg-orange-600 text-white px-3 py-1.5 rounded-lg text-xs font-bold"
                    >
                      Editar
                    </a>
                  </div>
                </article>
              ))}
            </div>
          </div>
        )}

        <ContactsHistory events={myContacts} />

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
          <div class="lg:col-span-2 bg-white rounded-3xl shadow-sm border border-gray-100 p-6">
            <h3 class="font-bold text-gray-800 text-lg mb-4 flex items-center gap-2">
              <i class="ri-heart-line text-red-500"></i> Vecinos Guardados
            </h3>
            {myFavorites.length > 0 ? (
              <div class="space-y-3">
                {myFavorites.map((fav) => (
                  <a href={`/p/${fav.slug}`} class="flex items-center gap-3 p-3 bg-gray-50 rounded-2xl border border-gray-100 hover:border-orange-500/50 transition">
                    <div class="w-10 h-10 rounded-full bg-orange-100 flex items-center justify-center text-orange-500 font-bold text-sm flex-shrink-0">
                      {fav.symbol?.slice(0, 2).toUpperCase() ?? 'OF'}
                    </div>
                    <div class="flex-1 min-w-0">
                      <h4 class="font-bold text-gray-800 text-sm truncate">{fav.name}</h4>
                      <p class="text-xs text-gray-500">{fav.userName} · ${(fav.basePriceClp ?? 0).toLocaleString('es-CL')}</p>
                    </div>
                    <i class="ri-arrow-right-s-line text-gray-400 text-xl"></i>
                  </a>
                ))}
              </div>
            ) : (
              <div class="text-center py-8 text-gray-400">
                <i class="ri-heart-line text-4xl mb-2 block opacity-30"></i>
                <p class="text-sm font-medium">Aún no has guardado vecinos.</p>
                <p class="text-xs mt-1">Haz clic en el corazón en cualquier tarjeta o perfil.</p>
              </div>
            )}
          </div>

          <RecentViews views={recentViews} />
        </div>
      </section>
    )}

    {tab === 'resenas' && (
      <section>
        <MyReviews reviews={myReviews} />
      </section>
    )}

    {tab === 'perfil' && (
      <section class="bg-white rounded-3xl shadow-sm border border-gray-100 p-8">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-2xl font-extrabold text-gray-800">Datos de tu cuenta</h2>
          <button onclick="openEditProfileModal()" class="bg-orange-500 hover:bg-orange-600 text-white px-4 py-2 rounded-xl text-xs font-bold transition flex items-center gap-1 shadow-md">
            <i class="ri-pencil-line"></i> Editar perfil
          </button>
        </div>
        <dl class="space-y-4">
          <div class="flex justify-between border-b border-gray-100 pb-3">
            <dt class="text-gray-500">Nombre</dt>
            <dd class="font-bold text-gray-800">{currentUser.name}</dd>
          </div>
          <div class="flex justify-between border-b border-gray-100 pb-3">
            <dt class="text-gray-500">Email</dt>
            <dd class="font-bold text-gray-800">{currentUser.email}</dd>
          </div>
          <div class="flex justify-between border-b border-gray-100 pb-3">
            <dt class="text-gray-500">Rol</dt>
            <dd class="font-bold text-gray-800 capitalize">{currentUser.role}</dd>
          </div>
          <div class="flex justify-between border-b border-gray-100 pb-3">
            <dt class="text-gray-500">ID</dt>
            <dd class="font-bold text-gray-800">#{currentUser.id}</dd>
          </div>
        </dl>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href="/api/v1/account/export" class="bg-white border border-gray-200 hover:border-orange-500 text-gray-700 px-4 py-2 rounded-xl text-xs font-bold transition flex items-center gap-1">
            <i class="ri-download-2-line"></i> Exportar mis datos
          </a>
          <form method="POST" action="/api/v1/account/delete" class="contents" onsubmit="return confirm('¿Estás seguro? Esta acción eliminará tu cuenta y todos tus datos de forma permanente.')">
            <button type="submit" class="bg-red-50 border border-red-200 hover:bg-red-100 text-red-600 px-4 py-2 rounded-xl text-xs font-bold transition flex items-center gap-1">
              <i class="ri-delete-bin-6-line"></i> Eliminar cuenta
            </button>
          </form>
          <form method="POST" action="/api/v1/auth/cerrar-sesion" class="contents js-logout-form">
            <button type="submit" class="bg-gray-900 hover:bg-red-600 text-white px-6 py-2.5 rounded-xl font-bold transition ml-auto">
              <i class="ri-logout-box-r-line"></i> Cerrar sesión
            </button>
          </form>
        </div>
      </section>
    )}
    <EditProfileModal open={tab === 'perfil'} communes={allCommunes} />
  </main>
<script>
  const btnResend = document.getElementById('btn-resend-verification');
  if (btnResend) {
    btnResend.addEventListener('click', async () => {
      btnResend.disabled = true;
      btnResend.textContent = 'Enviando...';
      try {
        const res = await fetch('/api/v1/auth/verify-email/resend', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: btnResend.dataset.email }),
        });
        if (res.ok) {
          btnResend.textContent = '¡Reenviado!';
          setTimeout(() => { btnResend.textContent = 'Reenviar'; btnResend.disabled = false; }, 3000);
        } else {
          btnResend.textContent = 'Error';
          setTimeout(() => { btnResend.textContent = 'Reenviar'; btnResend.disabled = false; }, 3000);
        }
      } catch {
        btnResend.textContent = 'Error';
        setTimeout(() => { btnResend.textContent = 'Reenviar'; btnResend.disabled = false; }, 3000);
      }
    });
  }
</script>
</BaseLayout>