---
import BaseLayout from '../layouts/BaseLayout.astro';

if (!import.meta.env.DEV) {
  return new Response('Not Found', { status: 404 });
}
---

<BaseLayout title="Test Users API">
  <main class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-6 text-gray-800">API Users Test</h1>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

      <div class="bg-white p-6 rounded-lg shadow-md">
        <h2 class="text-xl font-semibold mb-4 flex items-center gap-2">
          <i class="ri-user-add-line text-orange-500"></i> Create User
        </h2>
        <form id="createUserForm" class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700">Name</label>
            <input type="text" name="name" required minlength="2"
              class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-orange-500 focus:ring focus:ring-orange-200 p-2 border"
              placeholder="Juan Pérez"
            />
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700">Email</label>
            <input type="email" name="email" required
              class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-orange-500 focus:ring focus:ring-orange-200 p-2 border"
              placeholder="juan@example.com"
            />
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700">Role</label>
            <select name="role" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-orange-500 focus:ring focus:ring-orange-200 p-2 border">
              <option value="user">User</option>
              <option value="provider">Provider</option>
              <option value="admin">Admin</option>
            </select>
          </div>

          <button type="submit"
            class="w-full bg-orange-500 text-white font-bold py-2 px-4 rounded hover:bg-orange-600 transition duration-300">
            Create User
          </button>
        </form>
        <div id="formMessage" class="mt-4 text-sm hidden"></div>
      </div>

      <div class="bg-white p-6 rounded-lg shadow-md">
        <div class="flex justify-between items-center mb-4">
          <h2 class="text-xl font-semibold flex items-center gap-2">
            <i class="ri-team-line text-blue-500"></i> Current Users
          </h2>
          <button id="refreshBtn" class="text-sm text-gray-500 hover:text-orange-500 underline">
            <i class="ri-refresh-line"></i> Refresh
          </button>
        </div>

        <div id="loading" class="text-center py-4 text-gray-500">Loading...</div>
        <ul id="usersList" class="divide-y divide-gray-100 max-h-[500px] overflow-y-auto">
        </ul>
      </div>

    </div>
  </main>

  <script>
    import { inicializarTestUsers } from '../lib/client/dev/test-users';
    if (import.meta.env.DEV) {
      inicializarTestUsers();
    }
  </script>
</BaseLayout>