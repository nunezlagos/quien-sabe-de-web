---
import BaseLayout from '../layouts/BaseLayout.astro';
const totalDonations = 45000;
const totalExpenses = 12500;
const ratio = Math.round((totalExpenses / totalDonations) * 100);
---

<BaseLayout title="Transparencia — QuiénSabe">
  <main class="container mx-auto px-4 py-12 max-w-4xl">
    <h1 class="text-3xl font-extrabold text-gray-800 mb-2">Transparencia</h1>
    <p class="text-gray-500 mb-8">Conoce cómo se administran los recursos de QuiénSabe.</p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
      <div class="bg-white rounded-2xl border border-gray-100 p-6 shadow-sm">
        <p class="text-xs text-gray-400 uppercase font-bold mb-1">Donaciones (mes)</p>
        <p class="text-2xl font-extrabold text-green-600">${totalDonations.toLocaleString('es-CL')}</p>
      </div>
      <div class="bg-white rounded-2xl border border-gray-100 p-6 shadow-sm">
        <p class="text-xs text-gray-400 uppercase font-bold mb-1">Gastos (mes)</p>
        <p class="text-2xl font-extrabold text-red-600">${totalExpenses.toLocaleString('es-CL')}</p>
      </div>
      <div class="bg-white rounded-2xl border border-gray-100 p-6 shadow-sm">
        <p class="text-xs text-gray-400 uppercase font-bold mb-1">Ratio OE3</p>
        <p class="text-2xl font-extrabold text-orange-500">{ratio}%</p>
        <div class="w-full bg-gray-100 rounded-full h-2 mt-2">
          <div class="bg-orange-500 h-2 rounded-full" style="width:{ratio}%"></div>
        </div>
      </div>
    </div>

    <section class="bg-white rounded-2xl border border-gray-100 p-6 shadow-sm mb-6">
      <h2 class="text-xl font-extrabold text-gray-800 mb-4">¿Cómo funciona?</h2>
      <p class="text-gray-600">QuiénSabe es un proyecto comunitario. Las donaciones de vecinos como tú financian los costos operativos: hosting, dominios y herramientas. Publicamos mensualmente el detalle de ingresos y gastos para mantener la confianza de la comunidad.</p>
    </section>

    <section class="bg-white rounded-2xl border border-gray-100 p-6 shadow-sm">
      <h2 class="text-xl font-extrabold text-gray-800 mb-4">Reportes mensuales</h2>
      <p class="text-gray-500 text-sm">Los reportes detallados con boletas estarán disponibles próximamente.</p>
    </section>
  </main>
</BaseLayout>
