---
import BaseLayout from '../layouts/BaseLayout.astro';
import { DonationBody, GATEWAYS } from '../lib/validators/donations';

const url = Astro.url;
const ok = url.searchParams.get('ok');
const error = url.searchParams.get('error');
const amount = url.searchParams.get('amount');
const gateway = url.searchParams.get('provider');
const isLoggedIn = Boolean(Astro.locals.user);
const suggested = [3000, 5000, 10000, 25000];
---

<BaseLayout title="Donar — QuiénSabe">
  <main class="container mx-auto px-4 py-12 max-w-2xl">
    <div class="text-center mb-8">
      <i class="ri-heart-3-fill text-5xl mb-3 inline-block donate-hero-icon" aria-hidden="true"></i>
      <h1 class="text-3xl font-extrabold donate-title">Apoya a QuiénSabe</h1>
      <p class="mt-2 donate-subtitle">Tu donación mantiene la plataforma funcionando para la comunidad.</p>
    </div>

    {error && (
      <div class="donate-alert donate-alert-error rounded-2xl p-4 mb-6 text-sm" role="alert">
        <i class="ri-error-warning-line mr-1" aria-hidden="true"></i> {error}
      </div>
    )}

    {ok && (
      <div class="donate-alert donate-alert-success rounded-2xl p-6 mb-6 text-center" role="status">
        <i class="ri-checkbox-circle-line text-5xl mb-3 block donate-success-icon" aria-hidden="true"></i>
        <h2 class="text-xl font-extrabold donate-success-title">¡Gracias por tu donación!</h2>
        <p class="mt-1 donate-success-body">
          {amount && <>Has donado <b>${Number(amount).toLocaleString('es-CL')}</b></>}
          {gateway && <> vía <b>{gateway}</b></>}.
        </p>
        <p class="text-sm mt-2 donate-success-note">Recibirás un comprobante por email.</p>
      </div>
    )}

    <div id="donation-app" class="donate-card rounded-3xl p-6 sm:p-8">
      <form id="donation-form" action="/api/v1/donations" method="POST" class="space-y-6">
        <fieldset>
          <legend class="block text-xs font-bold mb-3 uppercase tracking-wide donate-legend">Monto</legend>
          <div class="grid grid-cols-2 gap-3">
            {suggested.map((m) => (
              <button type="button" class="amount-btn rounded-xl py-3 px-4 text-center transition font-bold" data-amount={m} aria-label={`Donar $${m.toLocaleString('es-CL')}`}>
                ${m.toLocaleString('es-CL')}
              </button>
            ))}
          </div>
          <div class="mt-3">
            <label for="custom-amount" class="sr-only">Monto a donar en pesos</label>
            <input type="number" name="amount" id="custom-amount" class="donate-input w-full rounded-xl px-4 py-3 text-center text-lg font-bold" placeholder="Otro monto (mín $1.000)" min="1000" max="9999999" required />
          </div>
        </fieldset>

        <fieldset>
          <legend class="block text-xs font-bold mb-3 uppercase tracking-wide donate-legend">Pasarela de pago</legend>
          <div class="grid grid-cols-2 gap-3">
            <label class="provider-card rounded-xl p-4 text-center cursor-pointer transition">
              <input type="radio" name="provider" value="mercadopago" class="sr-only" checked aria-label="Pagar con Mercado Pago" />
              <i class="ri-bank-card-line text-2xl provider-icon-blue" aria-hidden="true"></i>
              <p class="font-bold text-sm mt-1 donate-title">Mercado Pago</p>
            </label>
            <label class="provider-card rounded-xl p-4 text-center cursor-pointer transition">
              <input type="radio" name="provider" value="webpay" class="sr-only" aria-label="Pagar con Webpay" />
              <i class="ri-secure-payment-line text-2xl provider-icon-green" aria-hidden="true"></i>
              <p class="font-bold text-sm mt-1 donate-title">Webpay</p>
            </label>
          </div>
        </fieldset>

        <label for="recurring-donation" class="flex items-center gap-3 text-sm cursor-pointer donate-subtitle">
          <input type="checkbox" id="recurring-donation" name="recurring" value="on" class="donate-checkbox w-5 h-5 rounded" />
          Convertir en donación mensual
        </label>

        <button type="submit" class="donate-submit w-full text-white py-4 rounded-xl font-extrabold text-lg transition">
          <i class="ri-heart-3-fill mr-2" aria-hidden="true"></i> Donar ahora
        </button>
      </form>
    </div>

    <section class="mt-8 text-center text-sm donate-subtitle">
      <p>QuiénSabe es un proyecto comunitario. Las donaciones se usan exclusivamente para costos operativos.</p>
      <a href="/transparency" class="font-bold hover:underline mt-2 inline-block donate-link">Ver transparencia financiera →</a>
    </section>
  </main>

  <style>
    .donate-hero-icon { color: var(--color-accent); }
    .donate-title { color: var(--text-primary); }
    .donate-subtitle { color: var(--text-secondary); }
    .donate-legend { color: var(--text-secondary); }
    .donate-link { color: var(--color-accent); }

    .donate-card {
      background: var(--bg-card);
      box-shadow: var(--shadow-card);
      border: 1px solid var(--border-light);
    }

    .donate-alert-error {
      background: var(--color-red-50);
      border: 1px solid var(--color-red-200);
      color: var(--color-red-700);
    }
    .donate-alert-success {
      background: var(--color-success-light);
      border: 1px solid var(--color-success-border);
    }
    .donate-success-icon { color: var(--green-500); }
    .donate-success-title { color: var(--green-800); }
    .donate-success-body { color: var(--green-700); }
    .donate-success-note { color: var(--green-600); }

    .amount-btn {
      border: 2px solid var(--border-default);
      color: var(--text-secondary);
      min-height: 44px;
    }
    .amount-btn:hover {
      border-color: var(--color-accent);
      background: var(--orange-50);
    }
    .amount-btn:focus-visible {
      outline: none;
      border-color: var(--border-focus);
      box-shadow: 0 0 0 3px var(--amber-100);
    }
    /* Estado seleccionado: el JS agrega border-orange-500 + bg-orange-50 */

    .donate-input {
      border: 1px solid var(--border-default);
      background: var(--bg-card);
      color: var(--text-primary);
      min-height: 44px;
    }
    .donate-input:focus-visible {
      outline: none;
      border-color: var(--border-focus);
      box-shadow: 0 0 0 3px var(--amber-100);
    }

    .provider-card {
      border: 2px solid var(--border-default);
    }
    .provider-card:hover {
      border-color: var(--color-accent);
    }
    .provider-card:has(:checked) {
      border-color: var(--color-accent);
      background: var(--orange-50);
    }
    .provider-card:has(:focus-visible) {
      box-shadow: 0 0 0 3px var(--amber-100);
    }
    .provider-icon-blue { color: var(--blue-500); }
    .provider-icon-green { color: var(--green-500); }

    .donate-checkbox {
      accent-color: var(--color-accent);
      border: 1px solid var(--border-strong);
    }

    .donate-submit {
      background: linear-gradient(to right, var(--orange-500), var(--orange-600));
      box-shadow: var(--shadow-md);
      min-height: 44px;
    }
    .donate-submit:hover { box-shadow: var(--shadow-lg); }
    .donate-submit:focus-visible {
      outline: none;
      box-shadow: 0 0 0 3px var(--amber-200);
    }
    .donate-submit:disabled { opacity: 0.7; cursor: not-allowed; }
  </style>

  <script>
    document.querySelectorAll('.amount-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const input = document.getElementById('custom-amount') as HTMLInputElement;
        if (input) { input.value = btn.dataset.amount || ''; }
        document.querySelectorAll('.amount-btn').forEach(b => b.classList.remove('border-orange-500', 'bg-orange-50'));
        btn.classList.add('border-orange-500', 'bg-orange-50');
      });
    });

    document.getElementById('donation-form')?.addEventListener('submit', (e) => {
      const submitBtn = e.target?.querySelector('button[type="submit"]') as HTMLButtonElement;
      if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Redirigiendo...'; }
    });
  </script>
</BaseLayout>
