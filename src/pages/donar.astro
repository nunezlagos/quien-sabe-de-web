---
import BaseLayout from '../layouts/BaseLayout.astro';
import { DonationBody, GATEWAYS } from '../lib/validators/donations';

const url = Astro.url;
const ok = url.searchParams.get('ok');
const error = url.searchParams.get('error');
const amount = url.searchParams.get('amount');
const gateway = url.searchParams.get('provider');
const isLoggedIn = Boolean(Astro.locals.user);
const suggested = [3000, 5000, 10000, 25000];
---

<BaseLayout title="Donar — QuiénSabe">
  <main class="container mx-auto px-4 py-12 max-w-2xl">
    <div class="text-center mb-8">
      <i class="ri-heart-3-fill text-5xl text-orange-500 mb-3 inline-block"></i>
      <h1 class="text-3xl font-extrabold text-gray-800">Apoya a QuiénSabe</h1>
      <p class="text-gray-500 mt-2">Tu donación mantiene la plataforma funcionando para la comunidad.</p>
    </div>

    {error && (
      <div class="bg-red-50 border border-red-200 rounded-2xl p-4 mb-6 text-red-700 text-sm">
        <i class="ri-error-warning-line mr-1"></i> {error}
      </div>
    )}

    {ok && (
      <div class="bg-green-50 border border-green-200 rounded-2xl p-6 mb-6 text-center">
        <i class="ri-checkbox-circle-line text-5xl text-green-500 mb-3 block"></i>
        <h2 class="text-xl font-extrabold text-green-800">¡Gracias por tu donación!</h2>
        <p class="text-green-700 mt-1">
          {amount && <>Has donado <b>${Number(amount).toLocaleString('es-CL')}</b></>}
          {gateway && <> vía <b>{gateway}</b></>}.
        </p>
        <p class="text-green-600 text-sm mt-2">Recibirás un comprobante por email.</p>
      </div>
    )}

    <div id="donation-app" class="bg-white rounded-3xl shadow-sm border border-gray-100 p-8">
      <form id="donation-form" action="/api/v1/donations" method="POST" class="space-y-6">
        <div>
          <label class="block text-xs font-bold text-gray-600 mb-3 uppercase tracking-wide">Monto</label>
          <div class="grid grid-cols-2 gap-3">
            {suggested.map((m) => (
              <button type="button" class="amount-btn border-2 border-gray-200 rounded-xl py-3 px-4 text-center hover:border-orange-500 hover:bg-orange-50 transition font-bold text-gray-700" data-amount={m}>
                ${m.toLocaleString('es-CL')}
              </button>
            ))}
          </div>
          <div class="mt-3">
            <input type="number" name="amount" id="custom-amount" class="w-full border border-gray-200 rounded-xl px-4 py-3 text-center text-lg font-bold" placeholder="Otro monto (mín $1.000)" min="1000" max="9999999" required />
          </div>
        </div>

        <div>
          <label class="block text-xs font-bold text-gray-600 mb-3 uppercase tracking-wide">Pasarela de pago</label>
          <div class="grid grid-cols-2 gap-3">
            <label class="border-2 border-gray-200 rounded-xl p-4 text-center cursor-pointer hover:border-orange-500 transition has-[:checked]:border-orange-500 has-[:checked]:bg-orange-50">
              <input type="radio" name="provider" value="mercadopago" class="sr-only" checked />
              <i class="ri-bank-card-line text-2xl text-blue-500"></i>
              <p class="font-bold text-sm mt-1">Mercado Pago</p>
            </label>
            <label class="border-2 border-gray-200 rounded-xl p-4 text-center cursor-pointer hover:border-orange-500 transition has-[:checked]:border-orange-500 has-[:checked]:bg-orange-50">
              <input type="radio" name="provider" value="webpay" class="sr-only" />
              <i class="ri-secure-payment-line text-2xl text-green-500"></i>
              <p class="font-bold text-sm mt-1">Webpay</p>
            </label>
          </div>
        </div>

        <label class="flex items-center gap-3 text-sm text-gray-600 cursor-pointer">
          <input type="checkbox" name="recurring" value="on" class="w-5 h-5 rounded border-gray-300 text-orange-500" />
          Convertir en donación mensual
        </label>

        <button type="submit" class="w-full bg-gradient-to-r from-orange-500 to-orange-600 text-white py-4 rounded-xl font-extrabold text-lg shadow-md hover:shadow-lg transition">
          <i class="ri-heart-3-fill mr-2"></i> Donar ahora
        </button>
      </form>
    </div>

    <section class="mt-8 text-center text-sm text-gray-500">
      <p>QuiénSabe es un proyecto comunitario. Las donaciones se usan exclusivamente para costos operativos.</p>
      <a href="/transparency" class="text-orange-500 font-bold hover:underline mt-2 inline-block">Ver transparencia financiera →</a>
    </section>
  </main>

  <script>
    document.querySelectorAll('.amount-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const input = document.getElementById('custom-amount') as HTMLInputElement;
        if (input) { input.value = btn.dataset.amount || ''; }
        document.querySelectorAll('.amount-btn').forEach(b => b.classList.remove('border-orange-500', 'bg-orange-50'));
        btn.classList.add('border-orange-500', 'bg-orange-50');
      });
    });

    document.getElementById('donation-form')?.addEventListener('submit', (e) => {
      const submitBtn = e.target?.querySelector('button[type="submit"]') as HTMLButtonElement;
      if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Redirigiendo...'; }
    });
  </script>
</BaseLayout>
