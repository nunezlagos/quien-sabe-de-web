---
import BaseLayout from '../layouts/BaseLayout.astro';

const ok = Astro.url.searchParams.get('ok');
const montoRecibido = Astro.url.searchParams.get('amount');
const pasarelaRecibida = Astro.url.searchParams.get('provider');

const MONTOS = [
  { amount: 3000, label: 'Cafecito' },
  { amount: 5000, label: 'Pizza' },
  { amount: 10000, label: 'Servidor' },
  { amount: 25000, label: 'Sponsor' },
];
---

<BaseLayout title="Donaciones — QuiénSabe">
  <nav class="bg-white shadow-sm sticky top-0 z-50">
    <div class="container mx-auto px-4 py-3 flex justify-between items-center">
      <a href="/" class="text-2xl font-bold text-gray-800 flex items-center gap-2">
        <i class="ri-community-line text-orange-500"></i>
        Quién<span class="text-orange-500">Sabe</span>
      </a>
      <a href="/" class="text-gray-600 hover:text-orange-500 transition font-bold">Volver al Inicio</a>
    </div>
  </nav>

  <main class="container mx-auto px-4 py-16 max-w-4xl flex-grow">
    <div class="bg-white rounded-[2rem] shadow-xl overflow-hidden border border-gray-100">
      <div class="bg-gray-900 text-white p-10 md:p-16 text-center relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-full opacity-10 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')]"></div>
        <div class="relative z-10">
          <div class="w-20 h-20 bg-orange-500 rounded-full flex items-center justify-center mx-auto mb-6 shadow-lg">
            <i class="ri-heart-3-fill text-4xl"></i>
          </div>
          <h1 class="text-3xl md:text-5xl font-extrabold mb-4 tracking-tight">Mantengamos vivo el barrio</h1>
          <p class="text-lg text-gray-300 max-w-xl mx-auto font-medium">
            "Quién Sabe" es 100% gratuito y libre de comisiones. Solo existimos gracias a la generosidad de vecinos como tú.
          </p>
        </div>
      </div>

      <div class="p-8 md:p-12">
        {ok && (
          <div class="bg-green-50 border border-green-200 text-green-800 px-6 py-4 rounded-xl mb-6 text-sm flex items-start gap-3">
            <i class="ri-checkbox-circle-fill text-2xl flex-shrink-0"></i>
            <div>
              <p class="font-bold">¡Gracias por tu donación!</p>
              <p class="text-green-700 mt-1">Registramos tu intención de donar <b>${Number(montoRecibido).toLocaleString('es-CL')}</b> vía <b>{pasarelaRecibida === 'webpay' ? 'Webpay' : 'Mercado Pago'}</b>. En MVP no procesamos el pago real (HU-14.8 integrará Webpay). Te enviaremos un comprobante a tu correo una vez procesado.</p>
            </div>
          </div>
        )}

        <form action="/api/v1/donations" method="POST" class="space-y-6" id="form-donar">
          <input type="hidden" name="amount" id="donation-amount" required>

          <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-4">
            {MONTOS.map((m) => (
              <button type="button" data-amount={m.amount} class="bg-white border-2 border-orange-200 hover:border-orange-500 p-4 rounded-2xl transition shadow-sm hover:shadow-md group js-monto">
                <div class="text-3xl font-extrabold text-gray-800 group-hover:text-orange-500">${m.amount.toLocaleString('es-CL')}</div>
                <div class="text-xs text-gray-500 mt-1">{m.label}</div>
              </button>
            ))}
          </div>

          <div>
            <label for="custom_amount" class="block text-sm font-bold text-gray-700 mb-2">O ingresa otro monto</label>
            <div class="relative">
              <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-500 font-bold">$</span>
              <input type="number" id="custom_amount" min="1000" placeholder="Mínimo $1.000" class="w-full pl-8 pr-4 py-3 rounded-xl border border-gray-200 focus:border-orange-500 focus:ring-orange-500 bg-white text-lg font-bold">
            </div>
          </div>

          <div class="space-y-4">
            <div>
              <label class="block text-sm font-bold text-gray-700 mb-2">Pasarela de pago</label>
              <div class="grid grid-cols-2 gap-2">
                <label class="flex items-center gap-3 p-3 border-2 border-orange-500 bg-orange-50 rounded-xl cursor-pointer">
                  <input type="radio" name="provider" value="mercadopago" checked class="w-4 h-4 accent-orange-500">
                  <span class="font-bold text-sm">Mercado Pago</span>
                </label>
                <label class="flex items-center gap-3 p-3 border-2 border-gray-200 hover:border-orange-500 rounded-xl cursor-pointer">
                  <input type="radio" name="provider" value="webpay" class="w-4 h-4 accent-orange-500">
                  <span class="font-bold text-sm">Webpay</span>
                </label>
              </div>
            </div>
            <label class="flex items-center gap-3 p-4 bg-blue-50 border border-blue-100 rounded-xl cursor-pointer">
              <input type="checkbox" name="recurring" class="w-5 h-5 accent-orange-500">
              <div>
                <div class="font-bold text-sm text-gray-800">Hacer esta donación todos los meses</div>
                <div class="text-xs text-gray-600">Puedes cancelar en cualquier momento</div>
              </div>
            </label>
          </div>

          <div class="grid md:grid-cols-2 gap-10 items-center pt-6">
            <div class="bg-gradient-to-br from-orange-50 to-orange-100 border border-orange-200 rounded-2xl p-6">
              <div class="flex items-center gap-2 mb-3">
                <i class="ri-heart-pulse-line text-orange-500 text-xl"></i>
                <h3 class="font-bold text-gray-800">¿Sabías que...</h3>
              </div>
              <p class="text-sm text-gray-700 mb-4">Nuestras donaciones ya cubren el <b class="text-orange-500 text-xl">80%</b> de los costos operativos. Meta: llegar al 100% este año.</p>
              <div class="space-y-2 mb-4">
                <div class="flex justify-between text-xs">
                  <span class="font-bold text-gray-600">Cobertura actual</span>
                  <span class="font-bold text-orange-500">80%</span>
                </div>
                <div class="h-3 bg-gray-200 rounded-full overflow-hidden">
                  <div class="h-full bg-gradient-to-r from-orange-500 to-orange-300 rounded-full" style="width: 80%"></div>
                </div>
              </div>
              <a href="/transparency" class="text-orange-500 hover:text-orange-600 font-bold text-sm flex items-center gap-1">
                Ver reportes mensuales <i class="ri-arrow-right-line"></i>
              </a>
            </div>
            <div class="bg-gray-50 p-6 rounded-2xl border border-gray-100">
              <h2 class="text-2xl font-bold text-gray-800 mb-4 flex items-center gap-2">
                <i class="ri-lightbulb-flash-line text-yellow-500"></i> ¿Por qué donar?
              </h2>
              <ul class="space-y-3 text-gray-600">
                <li class="flex items-start gap-2">
                  <i class="ri-checkbox-circle-fill text-orange-500 mt-1"></i>
                  <span>Sin publicidad invasiva.</span>
                </li>
                <li class="flex items-start gap-2">
                  <i class="ri-checkbox-circle-fill text-orange-500 mt-1"></i>
                  <span>Datos privados y seguros.</span>
                </li>
                <li class="flex items-start gap-2">
                  <i class="ri-checkbox-circle-fill text-orange-500 mt-1"></i>
                  <span>Apoyo real a la economía local.</span>
                </li>
              </ul>
            </div>
          </div>

          <button type="submit" class="w-full bg-orange-500 hover:bg-orange-600 text-white font-bold py-4 rounded-xl shadow-lg transition text-lg">
            Donar ahora
          </button>
        </form>
      </div>
    </div>
  </main>

  <footer class="relative bg-gray-900 text-white py-12 text-center text-xs mt-12 overflow-hidden">
    <div class="absolute inset-0 z-0 opacity-25">
      <img src="https://images.unsplash.com/photo-1581094794329-cd11965d15eb?q=80&w=2000&auto=format&fit=crop" class="w-full h-full object-cover filter blur-sm grayscale">
    </div>
    <div class="absolute inset-0 z-0 bg-gradient-to-t from-gray-900 via-gray-900/80 to-gray-900/40"></div>
    <div class="container mx-auto px-4 flex flex-col md:flex-row justify-between items-center gap-6 relative z-10">
      <div class="text-left">
        <h4 class="text-xl font-extrabold text-white mb-1 flex items-center gap-2">
          <i class="ri-community-line text-orange-500"></i> QuiénSaba
        </h4>
        <p class="text-gray-400 max-w-xs">Conectando barrios, un oficio a la vez. Construido con cariño para la comunidad.</p>
      </div>
      <div class="flex gap-8">
        <a href="/donar" class="hover:text-orange-500 transition font-bold text-gray-300">Donaciones</a>
        <a href="/terminos" class="hover:text-orange-500 transition font-bold text-gray-300">Términos</a>
        <a href="/transparency" class="hover:text-orange-500 transition font-bold text-gray-300">Transparencia</a>
      </div>
      <div class="text-right text-gray-500">
        <p class="font-bold">&copy; 2026 Quién Sabe.</p>
        <p class="text-[10px]">Hecho en Chile 🇨🇱</p>
      </div>
    </div>
  </footer>

  <script>
    import { inicializarFormularioDonar } from '../lib/client/donations/donar';
    inicializarFormularioDonar();
  </script>
</BaseLayout>
