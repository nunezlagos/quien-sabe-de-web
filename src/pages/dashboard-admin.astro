---
import { getDb } from '../database/client';
import { users, trades, communes } from '../database/schema';
import { desc, eq } from 'drizzle-orm';

const SECCIONES_VALIDAS = [
	'dashboard',
	'usuarios',
	'oficios',
	'tickets',
	'finanzas',
	'configuracion',
	'analytics',
	'auditoria',
] as const;
type SeccionId = (typeof SECCIONES_VALIDAS)[number];

const usuario = Astro.locals.user;
if (!usuario) {
	return Astro.redirect('/iniciar-sesion?redirigir=/dashboard-admin');
}
if (usuario.role !== 'admin') {
	return Astro.redirect('/dashboard');
}

const param = Astro.url.searchParams.get('section') ?? 'dashboard';
const seccionActiva: SeccionId = (SECCIONES_VALIDAS as readonly string[]).includes(param)
	? (param as SeccionId)
	: 'dashboard';

const db = getDb(Astro.locals);

let listaUsuarios: Array<{
	id: number;
	email: string;
	name: string;
	role: 'user' | 'provider' | 'admin';
	status: 'active' | 'banned';
	createdAt: Date | null;
}> = [];

let listaOficios: Array<{
	id: number;
	name: string;
	symbol: string;
	category: string;
	status: 'active' | 'paused';
	userId: number;
	userName: string | null;
	communeId: number | null;
	communeName: string | null;
}> = [];

if (seccionActiva === 'usuarios') {
	listaUsuarios = await db
		.select({
			id: users.id,
			email: users.email,
			name: users.name,
			role: users.role,
			status: users.status,
			createdAt: users.createdAt,
		})
		.from(users)
		.orderBy(desc(users.createdAt))
		.all();
}

if (seccionActiva === 'oficios') {
	listaOficios = await db
		.select({
			id: trades.id,
			name: trades.name,
			symbol: trades.symbol,
			category: trades.category,
			status: trades.status,
			userId: trades.userId,
			userName: users.name,
			communeId: trades.communeId,
			communeName: communes.name,
		})
		.from(trades)
		.leftJoin(communes, eq(trades.communeId, communes.id))
		.leftJoin(users, eq(trades.userId, users.id))
		.orderBy(desc(trades.createdAt))
		.all();
}

const TITULOS: Record<SeccionId, string> = {
	dashboard: 'Resumen General',
	usuarios: 'Usuarios',
	oficios: 'Oficios',
	tickets: 'Tickets',
	finanzas: 'Finanzas',
	configuracion: 'Configuración',
	analytics: 'Analytics',
	auditoria: 'Auditoría',
};
const titulo = TITULOS[seccionActiva];

const CATEGORIAS: Record<string, string> = {
	hogar: 'Hogar',
	tecnologia: 'Tecnología',
	automotriz: 'Automotriz',
	educacion: 'Educación',
	salud_belleza: 'Salud/Belleza',
	otros: 'Otros',
};

const ROLES: Record<string, string> = {
	user: 'Usuario',
	provider: 'Proveedor',
	admin: 'Administrador',
};

const NAV: Array<{ id: SeccionId; href: string; label: string; icon: string; badge?: string }> = [
	{ id: 'dashboard', href: '/dashboard-admin', label: 'Dashboard', icon: 'ri-dashboard-3-line' },
	{ id: 'usuarios', href: '/dashboard-admin?section=usuarios', label: 'Usuarios', icon: 'ri-user-settings-line' },
	{ id: 'oficios', href: '/dashboard-admin?section=oficios', label: 'Oficios', icon: 'ri-briefcase-4-line' },
	{ id: 'tickets', href: '/dashboard-admin?section=tickets', label: 'Tickets', icon: 'ri-customer-service-2-line', badge: '12' },
	{ id: 'finanzas', href: '/dashboard-admin?section=finanzas', label: 'Finanzas', icon: 'ri-money-dollar-circle-line' },
	{ id: 'configuracion', href: '/dashboard-admin?section=configuracion', label: 'Configuración', icon: 'ri-settings-4-line' },
	{ id: 'analytics', href: '/dashboard-admin?section=analytics', label: 'Analytics', icon: 'ri-bar-chart-2-line' },
	{ id: 'auditoria', href: '/dashboard-admin?section=auditoria', label: 'Auditoría', icon: 'ri-file-shield-2-line' },
];

const kpiUsuariosTotales = 2543;
const kpiOficiosActivos = 856;
const kpiValoracionMedia = 4.7;
const kpiSolicitudes = 12;

const chartActividad = [40, 65, 45, 80, 95, 60, 75];
const diasSemana = ['Lun', 'Mar', 'Mié', 'Jue', 'Vie', 'Sáb', 'Dom'];

const embudo = [
	{ label: 'Visitantes únicos', value: '12,847', pct: 100, color: 'primary' },
	{ label: 'Vieron un perfil', value: '3,402', pct: 26.5, color: 'blue' },
	{ label: 'Contactaron', value: '1,432', pct: 11.1, color: 'orange' },
	{ label: 'Dejaron reseña', value: '287', pct: 2.2, color: 'green' },
];

const finanzas6m = [
	{ mes: 'Ene', donaciones: 60, gastos: 30 },
	{ mes: 'Feb', donaciones: 70, gastos: 30 },
	{ mes: 'Mar', donaciones: 75, gastos: 30 },
	{ mes: 'Abr', donaciones: 80, gastos: 30 },
	{ mes: 'May', donaciones: 85, gastos: 30 },
	{ mes: 'Jun', donaciones: 90, gastos: 30 },
];

const topOficios = [
	{ rank: 1, nombre: 'Gasfiter', pct: 92, count: '2,134' },
	{ rank: 2, nombre: 'Electricista', pct: 78, count: '1,812' },
	{ rank: 3, nombre: 'Jardinero', pct: 65, count: '1,508' },
	{ rank: 4, nombre: 'Pintor', pct: 52, count: '1,206' },
	{ rank: 5, nombre: 'Cerrajero', pct: 43, count: '998' },
];

const auditPlaceholder = [
	{ fecha: '2026-06-24 14:32', admin: 'Admin', accion: 'approve_verification', accionColor: 'green', entidad: 'providers', id: '#42' },
	{ fecha: '2026-06-24 11:15', admin: 'Admin', accion: 'hide_review', accionColor: 'red', entidad: 'reviews', id: '#128' },
	{ fecha: '2026-06-23 18:02', admin: 'Admin', accion: 'ban_user', accionColor: 'red', entidad: 'users', id: '#87' },
];
---

<!DOCTYPE html>
<html lang="es">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Admin · QuiénSabe</title>
	<link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
	<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;600;700;800&display=swap" rel="stylesheet">
</head>
<body class="admin-shell">

	<aside class="admin-sidebar">
		<div class="admin-sidebar__brand">
			<i class="ri-shield-star-line admin-sidebar__brand-icon"></i>
			<span class="admin-sidebar__brand-text">AdminPanel</span>
		</div>

		<nav class="admin-sidebar__nav" aria-label="Secciones de administración">
			{NAV.map((item) => (
				<a
					href={item.href}
					class={`admin-nav-link ${seccionActiva === item.id ? 'admin-nav-link--active' : ''}`}
					aria-current={seccionActiva === item.id ? 'page' : undefined}
				>
					<i class={item.icon}></i>
					<span>{item.label}</span>
					{item.badge && (
						<span class={`admin-nav-badge admin-nav-badge--${item.id === 'oficios' ? 'red' : 'orange'}`}>
							{item.badge}
						</span>
					)}
				</a>
			))}
		</nav>

		<div class="admin-sidebar__footer">
			<form method="POST" action="/api/v1/auth/cerrar-sesion" class="admin-logout-form">
				<button type="submit" class="admin-logout-btn">
					<i class="ri-logout-box-line"></i> Cerrar Sesión
				</button>
			</form>
		</div>
	</aside>

	<div class="admin-main">
		<header class="admin-header">
			<h1 class="admin-header__title">{titulo}</h1>
			<div class="admin-header__user">
				<div class="admin-header__user-info">
					<p class="admin-header__user-name">Admin Supremo</p>
					<p class="admin-header__user-role">Superusuario</p>
				</div>
				<div class="admin-header__avatar" aria-hidden="true">A</div>
			</div>
		</header>

		<main class="admin-content">
			{seccionActiva === 'dashboard' && (
				<div class="admin-section" data-section="dashboard">
					<div class="admin-kpi-grid">
						<article class="admin-kpi-card">
							<i class="ri-user-fill admin-kpi-card__bg" aria-hidden="true"></i>
							<div class="admin-kpi-card__head">
								<div class="admin-kpi-card__icon admin-kpi-card__icon--blue">
									<i class="ri-user-line"></i>
								</div>
								<span class="admin-trend admin-trend--up">+12%</span>
							</div>
							<h3 class="admin-kpi-card__label">Usuarios Totales</h3>
							<p class="admin-kpi-card__value">{kpiUsuariosTotales.toLocaleString('es-CL')}</p>
						</article>

						<article class="admin-kpi-card">
							<i class="ri-hammer-fill admin-kpi-card__bg" aria-hidden="true"></i>
							<div class="admin-kpi-card__head">
								<div class="admin-kpi-card__icon admin-kpi-card__icon--primary">
									<i class="ri-hammer-line"></i>
								</div>
								<span class="admin-trend admin-trend--up">+5%</span>
							</div>
							<h3 class="admin-kpi-card__label">Oficios Activos</h3>
							<p class="admin-kpi-card__value">{kpiOficiosActivos.toLocaleString('es-CL')}</p>
						</article>

						<article class="admin-kpi-card">
							<i class="ri-star-fill admin-kpi-card__bg" aria-hidden="true"></i>
							<div class="admin-kpi-card__head">
								<div class="admin-kpi-card__icon admin-kpi-card__icon--orange">
									<i class="ri-star-smile-line"></i>
								</div>
								<span class="admin-trend admin-trend--neutral">0%</span>
							</div>
							<h3 class="admin-kpi-card__label">Valoración Media</h3>
							<p class="admin-kpi-card__value">{kpiValoracionMedia.toFixed(1)}</p>
						</article>

						<article class="admin-kpi-card">
							<i class="ri-alert-fill admin-kpi-card__bg" aria-hidden="true"></i>
							<div class="admin-kpi-card__head">
								<div class="admin-kpi-card__icon admin-kpi-card__icon--red">
									<i class="ri-alert-line"></i>
								</div>
								<span class="admin-trend admin-trend--warn">Pendientes</span>
							</div>
							<h3 class="admin-kpi-card__label">Solicitudes</h3>
							<p class="admin-kpi-card__value">{kpiSolicitudes}</p>
						</article>
					</div>

					<section class="admin-panel">
						<div class="admin-panel__head">
							<h3 class="admin-panel__title">Actividad por día</h3>
							<select class="admin-select" aria-label="Rango de fechas">
								<option>Últimos 7 días</option>
								<option>Este Mes</option>
							</select>
						</div>
						<div class="admin-bar-chart">
							{chartActividad.map((valor, i) => (
								<div class="admin-bar-chart__col">
									<div
										class={`admin-bar h-[${valor}%] ${i === 4 ? 'admin-bar--highlight' : ''}`}
									>
										<span class="admin-bar__tip">{valor}%</span>
									</div>
									<span class="admin-bar-chart__label">{diasSemana[i]}</span>
								</div>
							))}
						</div>
					</section>

					<section class="admin-panel">
						<h3 class="admin-panel__title">Embudo de conversión</h3>
						<div class="admin-funnel">
							{embudo.map((paso) => (
								<div class="admin-funnel__row">
									<div class="admin-funnel__head">
										<span class="admin-funnel__label">{paso.label}</span>
										<span class="admin-funnel__value">{paso.value}</span>
									</div>
									<div class={`admin-funnel__bar admin-funnel__bar--${paso.color} w-[${paso.pct}%]`}></div>
								</div>
							))}
						</div>
					</section>
				</div>
			)}

			{seccionActiva === 'usuarios' && (
				<div class="admin-section" data-section="usuarios">
					<section class="admin-panel">
						<div class="admin-panel__head admin-panel__head--with-action">
							<h3 class="admin-panel__title">
								<i class="ri-user-settings-line admin-panel__title-icon"></i> Mantenedor Usuarios
							</h3>
							<button type="button" class="admin-btn admin-btn--primary" disabled aria-disabled="true" title="Próximamente">
								<i class="ri-add-line"></i> Nuevo
							</button>
						</div>
						<div class="admin-table-wrap">
							{listaUsuarios.length === 0 ? (
								<p class="admin-empty">No hay usuarios registrados todavía.</p>
							) : (
								<table class="admin-table">
									<thead>
										<tr>
											<th>ID</th>
											<th>Email</th>
											<th>Nombre</th>
											<th>Rol</th>
											<th>Estado</th>
											<th class="text-right">Acciones</th>
										</tr>
									</thead>
									<tbody>
										{listaUsuarios.map((u) => (
											<tr>
												<td class="admin-table__id">#{u.id}</td>
												<td class="admin-table__email">{u.email}</td>
												<td class="admin-table__name">{u.name}</td>
												<td>
													<span class={`admin-pill admin-pill--${u.role}`}>{ROLES[u.role] ?? u.role}</span>
												</td>
												<td>
													<span class={`admin-pill admin-pill--${u.status === 'active' ? 'active' : 'banned'}`}>
														{u.status === 'active' ? 'Activo' : 'Baneado'}
													</span>
												</td>
												<td class="admin-table__actions">
													<button type="button" class="admin-icon-btn admin-icon-btn--blue" aria-label="Editar usuario" disabled>
														<i class="ri-edit-line"></i>
													</button>
													<button type="button" class="admin-icon-btn admin-icon-btn--red" aria-label="Eliminar usuario" disabled>
														<i class="ri-delete-bin-line"></i>
													</button>
												</td>
											</tr>
										))}
									</tbody>
								</table>
							)}
						</div>
					</section>
				</div>
			)}

			{seccionActiva === 'oficios' && (
				<div class="admin-section" data-section="oficios">
					<section class="admin-panel">
						<div class="admin-panel__head admin-panel__head--with-action">
							<h3 class="admin-panel__title">
								<i class="ri-briefcase-line admin-panel__title-icon"></i> Mantenedor Oficios
							</h3>
							<button type="button" class="admin-btn admin-btn--primary" disabled aria-disabled="true" title="Próximamente">
								<i class="ri-add-line"></i> Nuevo
							</button>
						</div>
						<div class="admin-table-wrap">
							{listaOficios.length === 0 ? (
								<p class="admin-empty">No hay oficios publicados todavía.</p>
							) : (
							<table class="admin-table">
								<thead>
									<tr>
										<th>ID</th>
										<th>Nombre</th>
										<th>Símbolo</th>
										<th>Categoría</th>
										<th>Prestador</th>
										<th>Comuna</th>
										<th>Estado</th>
										<th class="text-right">Acciones</th>
									</tr>
								</thead>
								<tbody>
									{listaOficios.map((t) => (
										<tr>
											<td class="admin-table__id">#{t.id}</td>
											<td class="admin-table__name">{t.name}</td>
											<td class="admin-table__symbol">{t.symbol}</td>
											<td>
												<span class="admin-pill admin-pill--blue">{CATEGORIAS[t.category] ?? t.category}</span>
											</td>
											<td class="admin-table__provider">{t.userName ?? `Usuario #${t.userId}`}</td>
											<td class="admin-table__commune">{t.communeName ?? '—'}</td>
											<td>
												<span class={`admin-pill admin-pill--${t.status === 'active' ? 'active' : 'paused'}`}>
													{t.status === 'active' ? 'Activo' : 'Pausado'}
												</span>
											</td>
											<td class="admin-table__actions">
												<button type="button" class="admin-icon-btn admin-icon-btn--blue" aria-label="Editar oficio" disabled>
													<i class="ri-edit-line"></i>
												</button>
											</td>
										</tr>
									))}
								</tbody>
							</table>
							)}
						</div>
					</section>
				</div>
			)}

			{seccionActiva === 'tickets' && (
				<div class="admin-section" data-section="tickets">
					<div class="admin-section__head">
						<h2 class="admin-section__title">Cola de tickets</h2>
						<div class="admin-section__filters">
							<select class="admin-select" aria-label="Filtrar por estado" disabled>
								<option>Todos los estados</option>
							</select>
							<select class="admin-select" aria-label="Filtrar por tipo" disabled>
								<option>Todos los tipos</option>
							</select>
						</div>
					</div>
					<section class="admin-panel">
						<div class="admin-table-wrap">
							<p class="admin-empty">
								<i class="ri-tools-line admin-empty__icon"></i>
								El endpoint de tickets se implementará en REQ-10. Por ahora la cola está vacía.
							</p>
						</div>
					</section>
				</div>
			)}

			{seccionActiva === 'finanzas' && (
				<div class="admin-section" data-section="finanzas">
					<div class="admin-finance-grid">
						<article class="admin-finance-card">
							<h3 class="admin-finance-card__label">Donaciones (mes)</h3>
							<p class="admin-finance-card__value">$45.000</p>
							<span class="admin-trend admin-trend--up">+12% vs mes anterior</span>
						</article>
						<article class="admin-finance-card">
							<h3 class="admin-finance-card__label">Gastos (mes)</h3>
							<p class="admin-finance-card__value">$12.500</p>
							<span class="admin-finance-card__hint">Hosting + dominios</span>
						</article>
						<article class="admin-finance-card">
							<h3 class="admin-finance-card__label">Ratio OE3</h3>
							<p class="admin-finance-card__value admin-finance-card__value--primary">80%</p>
							<div class="admin-progress">
								<div class="admin-progress__bar w-[80%]"></div>
							</div>
						</article>
					</div>

					<section class="admin-panel">
						<h3 class="admin-panel__title">Donaciones vs gastos (últimos 6 meses)</h3>
						<div class="admin-stacked-chart">
							{finanzas6m.map((m) => (
								<div class="admin-stacked-chart__col">
									<div class="admin-stacked-chart__bars">
										<div class={`admin-stacked-chart__bar admin-stacked-chart__bar--donaciones h-[${m.donaciones}%]`}></div>
										<div class={`admin-stacked-chart__bar admin-stacked-chart__bar--gastos h-[${m.gastos}%]`}></div>
									</div>
									<span class="admin-stacked-chart__label">{m.mes}</span>
								</div>
							))}
						</div>
						<div class="admin-legend">
							<span class="admin-legend__item">
								<span class="admin-legend__swatch admin-legend__swatch--donaciones"></span> Donaciones
							</span>
							<span class="admin-legend__item">
								<span class="admin-legend__swatch admin-legend__swatch--gastos"></span> Gastos
							</span>
						</div>
					</section>
				</div>
			)}

			{seccionActiva === 'configuracion' && (
				<div class="admin-section" data-section="configuracion">
					<h2 class="admin-section__title">Configuración global</h2>
					<section class="admin-panel admin-panel--narrow">
						<form class="admin-form" data-disabled="true" aria-disabled="true">
							<div class="admin-form__field">
								<label class="admin-form__label" for="rate-limit">Rate limit de contactos (por hora)</label>
								<input id="rate-limit" type="number" value="10" min="1" max="100" class="admin-form__input admin-form__input--small" disabled>
								<p class="admin-form__hint">Vecino no puede contactar más de N prestadores por hora</p>
							</div>
							<div class="admin-form__field">
								<label class="admin-form__label" for="sla">SLA tickets (horas)</label>
								<input id="sla" type="number" value="48" min="1" max="168" class="admin-form__input admin-form__input--small" disabled>
							</div>
							<div class="admin-form__field">
								<label class="admin-form__label" for="terms">Versión de Términos actual</label>
								<input id="terms" type="text" value="2026-06-15" class="admin-form__input admin-form__input--medium" disabled>
							</div>
							<label class="admin-form__toggle">
								<input type="checkbox" class="admin-form__checkbox" disabled>
								<span class="admin-form__toggle-text">Modo mantenimiento (sitio en construcción)</span>
							</label>
							<button type="button" class="admin-btn admin-btn--warning" disabled>
								Guardar configuración
							</button>
							<p class="admin-form__note">
								<i class="ri-information-line"></i> Las mutaciones de configuración se implementarán en HU-13.5. Esta vista es de solo lectura por ahora.
							</p>
						</form>
					</section>
				</div>
			)}

			{seccionActiva === 'analytics' && (
				<div class="admin-section" data-section="analytics">
					<div class="admin-kpi-grid">
						<article class="admin-kpi-card">
							<div class="admin-kpi-card__head">
								<div class="admin-kpi-card__icon admin-kpi-card__icon--primary">
									<i class="ri-eye-line"></i>
								</div>
								<span class="admin-trend admin-trend--up">+18%</span>
							</div>
							<h3 class="admin-kpi-card__label">Vistas Perfil (7d)</h3>
							<p class="admin-kpi-card__value">12,847</p>
						</article>
						<article class="admin-kpi-card">
							<div class="admin-kpi-card__head">
								<div class="admin-kpi-card__icon admin-kpi-card__icon--blue">
									<i class="ri-chat-3-line"></i>
								</div>
