---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getDb } from '../database/client';
import { trades, reviews, contactEvents, portfolioImages } from '../database/schema';
import { eq, desc, avg, count, gt, and, inArray, isNotNull } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/iniciar-sesion?redirigir=/dashboard-prestador');
}
if (user.role !== 'provider' && user.role !== 'admin') {
  return Astro.redirect('/dashboard');
}

const db = getDb(Astro.locals);

const myTrades = await db
  .select({
    id: trades.id,
    slug: trades.slug,
    name: trades.name,
    symbol: trades.symbol,
    description: trades.description,
    basePriceClp: trades.basePriceClp,
    whatsapp: trades.whatsapp,
    verified: trades.verified,
    availableNow: trades.availableNow,
    status: trades.status,
    ratingAvg: avg(reviews.rating),
    reviewCount: count(reviews.id),
  })
  .from(trades)
  .leftJoin(reviews, eq(reviews.tradeId, trades.id))
  .where(eq(trades.userId, user.id))
  .groupBy(trades.id)
  .orderBy(desc(trades.createdAt))
  .all();

const totalOficios = myTrades.length;
const ratingGlobal = myTrades.length > 0
  ? myTrades.reduce((acc, t) => acc + Number(t.ratingAvg || 0), 0) / myTrades.length
  : 0;
const totalReviews = myTrades.reduce((acc, t) => acc + Number(t.reviewCount || 0), 0);

// Real metrics from contact_events
const myTradeIds = myTrades.map((t) => t.id);
const thirtyDaysAgo = new Date(Date.now() - 30 * 24 * 60 * 60 * 1000);
const contactEventsCount = myTradeIds.length > 0
  ? await db
      .select({ count: count() })
      .from(contactEvents)
      .where(and(
        gt(contactEvents.createdAt, thirtyDaysAgo),
        inArray(contactEvents.tradeId, myTradeIds)
      ))
      .get()
  : { count: 0 };
const contactos30d = contactEventsCount?.count ?? 0;

// Reviews with response info for provider dashboard
const myReviews = myTradeIds.length > 0 ? await db
  .select({
    id: reviews.id,
    tradeId: reviews.tradeId,
    reviewerName: reviews.reviewerName,
    rating: reviews.rating,
    body: reviews.body,
    response: reviews.response,
    respondedAt: reviews.respondedAt,
    createdAt: reviews.createdAt,
    tradeName: trades.name,
    tradeSymbol: trades.symbol,
  })
  .from(reviews)
  .innerJoin(trades, eq(trades.id, reviews.tradeId))
  .where(inArray(reviews.tradeId, myTradeIds))
  .orderBy(desc(reviews.createdAt))
  .all() : [];

const reviewsConRespuesta = myReviews.filter((r) => r.response);
const reviewsSinRespuesta = myReviews.filter((r) => !r.response);

// Rating breakdown
const ratingBreakdown = [5, 4, 3, 2, 1].map((n) => ({
  rating: n,
  count: myReviews.filter((r) => r.rating === n).length,
}));

const estrellas = [1, 2, 3, 4, 5];
const initials = user.name.slice(0, 1).toUpperCase();
const perfilActualizado = Astro.url.searchParams.get('perfil') === 'actualizado';
const algunVerificado = myTrades.some((t) => Boolean(t.verified));
const showVerificationBanner = totalOficios > 0 && !algunVerificado;

// Portfolio images for the provider
const myPortfolio = myTradeIds.length > 0 ? await db
  .select({
    id: portfolioImages.id,
    url: portfolioImages.url,
    caption: portfolioImages.caption,
    tradeName: trades.name,
    tradeSlug: trades.slug,
  })
  .from(portfolioImages)
  .innerJoin(trades, eq(trades.id, portfolioImages.tradeId))
  .where(inArray(portfolioImages.tradeId, myTradeIds))
  .orderBy(desc(portfolioImages.createdAt))
  .all() : [];
---

<BaseLayout title="Panel Proveedor — QuiénSabe">
  <nav class="bg-white shadow-sm sticky top-0 z-50">
    <div class="container mx-auto px-4 py-3 flex justify-between items-center">
      <a href="/" class="text-xl font-bold text-gray-800 flex items-center gap-2">
        <i class="ri-community-line text-orange-500"></i>
        Quién<span class="text-orange-500">Sabe</span> <span class="text-xs bg-orange-500 text-white px-2 py-0.5 rounded ml-2">PRO</span>
      </a>
      <div class="flex items-center gap-4">
        <button class="w-8 h-8 rounded-full bg-gray-200 flex items-center justify-center text-gray-600 hover:bg-gray-300 transition" aria-label="Notificaciones">
          <i class="ri-notification-3-line"></i>
        </button>
        <form method="POST" action="/api/v1/auth/cerrar-sesion" class="contents js-logout-form">
          <button type="submit" class="text-sm text-red-500 hover:text-red-700 font-bold">Salir</button>
        </form>
      </div>
    </div>
  </nav>

  <main class="container mx-auto px-4 py-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
      <!-- Sidebar -->
      <aside class="md:col-span-1 space-y-4">
        <div class="bg-white p-6 rounded-3xl shadow-sm text-center border border-gray-100">
          <div class="w-24 h-24 bg-orange-100 rounded-full flex items-center justify-center mx-auto mb-4 text-orange-500 text-3xl font-bold">
            {initials}
          </div>
          <h2 class="font-bold text-gray-800 text-lg">{user.name}</h2>
          <p class="text-sm text-gray-500 font-medium">{user.role}</p>
          <div class="mt-4 flex justify-center gap-1 text-yellow-400 text-lg">
            <i class="ri-star-fill"></i><i class="ri-star-fill"></i><i class="ri-star-fill"></i><i class="ri-star-fill"></i><i class="ri-star-half-fill"></i>
            <span class="text-gray-400 ml-1 text-sm font-bold">({ratingGlobal.toFixed(1)})</span>
          </div>
        </div>

        <nav class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">
          <div class="p-4 border-b border-gray-50 bg-gray-50/50">
            <div class="flex items-center justify-between">
              <span class="text-xs font-bold text-gray-500 uppercase">Estado</span>
              <label class="relative inline-flex items-center cursor-pointer">
                <input type="checkbox" checked class="sr-only peer" data-provider-toggle>
                <div class="w-9 h-5 bg-gray-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-green-500"></div>
                <p class="text-xs font-bold text-orange-500 ml-2" data-toggle-label>Visible para vecinos</p>
              </label>
            </div>
          </div>
          <a href="/dashboard-prestador" class="block px-6 py-4 border-l-4 border-orange-500 bg-orange-50 text-orange-500 font-bold"><i class="ri-dashboard-line mr-2 align-middle"></i> Resumen</a>
          <a href="#editar-perfil" class="block px-6 py-4 border-l-4 border-transparent hover:bg-gray-50 text-gray-600 font-medium transition"><i class="ri-edit-line mr-2 align-middle"></i> Editar Perfil</a>
          <a href="#mis-servicios" class="block px-6 py-4 border-l-4 border-transparent hover:bg-gray-50 text-gray-600 font-medium transition"><i class="ri-list-settings-line mr-2 align-middle"></i> Mis Servicios</a>
          <a href="#resenas" class="block px-6 py-4 border-l-4 border-transparent hover:bg-gray-50 text-gray-600 font-medium transition"><i class="ri-chat-1-line mr-2 align-middle"></i> Reseñas</a>
          <a href="#portfolio" class="block px-6 py-4 border-l-4 border-transparent hover:bg-gray-50 text-gray-600 font-medium transition"><i class="ri-gallery-line mr-2 align-middle"></i> Portafolio</a>
          <a href="/dashboard-prestador/soporte" class="w-full text-left block px-6 py-4 border-l-4 border-transparent hover:bg-red-50 text-red-500 font-medium transition border-t border-gray-100 mt-2">
            <i class="ri-customer-service-2-line mr-2 align-middle"></i> Soporte / Ayuda
          </a>
        </nav>
      </aside>

      <!-- Main Panel -->
      <div class="md:col-span-3 space-y-6">
        <div class="flex justify-end gap-2">
          {myTrades.length > 0 && (
            <>
              <button id="btn-preview-profile" data-slug={myTrades[0].slug} class="bg-white border border-gray-200 text-gray-600 px-4 py-2 rounded-xl text-sm font-bold hover:text-orange-500 hover:border-orange-500 transition flex items-center gap-2 shadow-sm">
                <i class="ri-eye-line"></i> Previsualizar Perfil
              </button>
              <a href={`/p/${myTrades[0].slug}`} class="bg-white border border-gray-200 text-gray-600 px-4 py-2 rounded-xl text-sm font-bold hover:text-orange-500 hover:border-orange-500 transition flex items-center gap-2 shadow-sm">
                <i class="ri-external-link-line"></i> Ver Público
              </a>
            </>
          )}
        </div>

        <!-- Preview Modal -->
        <div id="preview-modal" class="fixed inset-0 z-50 hidden bg-black/50 flex items-center justify-center p-4" role="dialog" aria-modal="true">
          <div class="bg-white rounded-3xl max-w-2xl w-full max-h-[90vh] overflow-y-auto shadow-xl">
            <div class="sticky top-0 bg-white border-b border-gray-100 p-4 flex justify-between items-center rounded-t-3xl">
              <h3 class="font-bold text-gray-800">Vista previa del perfil público</h3>
              <button id="close-preview" class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-gray-100 transition text-gray-500">
                <i class="ri-close-line text-xl"></i>
              </button>
            </div>
            <div id="preview-content" class="p-6">
              <div class="flex items-center justify-center py-12">
                <div class="animate-spin w-8 h-8 border-4 border-orange-500 border-t-transparent rounded-full"></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Quick Stats -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div class="bg-white p-4 rounded-2xl shadow-sm border border-gray-100 flex flex-col items-center justify-center text-center">
            <span class="text-3xl font-extrabold text-gray-800">{visitas30d}</span>
            <span class="text-xs text-gray-400 font-bold uppercase mt-1">Visitas Perfil</span>
          </div>
          <div class="bg-white p-4 rounded-2xl shadow-sm border border-gray-100 flex flex-col items-center justify-center text-center">
            <span class="text-3xl font-extrabold text-orange-500">{contactos30d}</span>
            <span class="text-xs text-gray-400 font-bold uppercase mt-1">Contactos</span>
          </div>
          <div class="bg-white p-4 rounded-2xl shadow-sm border border-gray-100 flex flex-col items-center justify-center text-center">
            <span class="text-3xl font-extrabold text-yellow-400 flex items-center gap-1">{ratingGlobal.toFixed(1)} <i class="ri-star-fill text-xl"></i></span>
            <span class="text-xs text-gray-400 font-bold uppercase mt-1">Valoración</span>
          </div>
          <div class="bg-white p-4 rounded-2xl border border-gray-100 text-center shadow-sm flex flex-col items-center justify-center">
            <span class="text-3xl font-extrabold text-gray-800">{totalReviews}</span>
            <span class="text-xs text-gray-400 font-bold uppercase mt-1">Reseñas</span>
            <span class="text-xs text-green-500 font-bold mt-1">+{Math.floor(totalReviews/3)} este mes</span>
          </div>
        </div>

        {perfilActualizado ? (
        <div class="bg-green-50 border-2 border-green-200 rounded-2xl p-4 flex items-start gap-3">
          <i class="ri-check-line text-green-700 text-2xl flex-shrink-0 mt-0.5"></i>
          <div class="flex-1">
            <h4 class="font-bold text-green-900 text-sm">Perfil actualizado</h4>
            <p class="text-green-800 text-xs mt-1">Tus cambios se guardaron correctamente.</p>
          </div>
        </div>
        ) : null}

        <!-- Banner Verificación -->
        {showVerificationBanner ? (
        <div class="bg-yellow-50 border-2 border-yellow-200 rounded-2xl p-4 flex items-start gap-3">
          <i class="ri-time-line text-yellow-700 text-2xl flex-shrink-0 mt-0.5"></i>
          <div class="flex-1">
            <h4 class="font-bold text-yellow-900 text-sm">Verifica tu oficio para inspirar confianza</h4>
            <p class="text-yellow-800 text-xs mt-1">Los vecinos confían más en perfiles verificados. Sube tu RUT y obtén el sello de verificado.</p>
          </div>
          <a href="/verificar-oficio" class="text-yellow-700 hover:text-yellow-900 text-xs font-bold underline flex-shrink-0">Verificar ahora</a>
        </div>
        ) : null}

        <!-- Edit Profile Section -->
        <section id="editar-perfil" class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
          <h3 class="font-bold text-gray-800 text-base mb-4 flex items-center gap-2"><i class="ri-user-edit-line text-orange-500"></i> Editar Perfil</h3>

          <!-- Avatar upload -->
          <form class="mb-6 p-4 bg-gray-50 rounded-2xl" action="/api/v1/providers/me/avatar" method="POST" enctype="multipart/form-data" id="form-avatar">
            <div class="flex items-center gap-4">
              <div class="w-16 h-16 rounded-full bg-orange-100 flex items-center justify-center text-orange-500 text-2xl font-bold flex-shrink-0 overflow-hidden" id="avatar-preview">
                {user.avatarUrl ? (
                  <img src={user.avatarUrl} alt="Avatar" class="w-full h-full object-cover" />
                ) : (
                  initials
                )}
              </div>
              <div class="flex-1">
                <label class="block text-xs font-bold text-gray-700 mb-1">Foto de perfil</label>
                <input type="file" name="avatar" accept="image/*" class="block w-full text-xs text-gray-500 file:mr-2 file:py-1 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-bold file:bg-orange-50 file:text-orange-700 hover:file:bg-orange-100 transition" />
                <p class="text-[10px] text-gray-400 mt-1">PNG, JPG. Máx 2MB.</p>
              </div>
              <button type="submit" class="text-xs bg-orange-500 text-white px-3 py-1.5 rounded-lg font-bold hover:bg-orange-600 transition self-end">Subir</button>
            </div>
          </form>

          <form class="space-y-4" action="/api/v1/providers/me" method="POST" id="form-edit-profile">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label class="block text-xs font-bold text-gray-700 mb-1">Nombre Completo</label>
                <input type="text" name="name" value={user.name} class="w-full bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500/50 transition">
              </div>
              <div>
                <label class="block text-xs font-bold text-gray-700 mb-1">Email (no editable)</label>
                <input type="email" value={user.email} disabled class="w-full bg-gray-100 border border-gray-200 rounded-lg px-3 py-2 text-sm text-gray-500 cursor-not-allowed">
              </div>
            </div>

            {myTrades.length > 0 && (
              <div>
                <label class="block text-xs font-bold text-gray-700 mb-1">Biografía / Presentación</label>
                <textarea name="description" rows="2" class="w-full bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500/50 transition" placeholder="Cuéntales a los vecinos sobre ti y tu experiencia">{myTrades[0].description ?? ''}</textarea>
              </div>
            )}

            {myTrades.length > 0 && (
              <div>
                <label class="block text-xs font-bold text-gray-700 mb-1">WhatsApp (para contacto)</label>
                <div class="flex">
                  <span class="inline-flex items-center px-3 rounded-l-lg border border-r-0 border-gray-200 bg-gray-100 text-gray-500 text-xs font-bold">+56 9</span>
                  <input type="tel" inputmode="numeric" pattern="[0-9]{8}" maxlength="8" name="whatsapp" value={(myTrades[0].whatsapp ?? '').replace(/^569/, '')} class="w-full bg-gray-50 border border-gray-200 rounded-r-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500/50 transition" placeholder="12345678">
                </div>
                <p class="text-[10px] text-gray-400 mt-1">8 dígitos, sin el 9 inicial. Se almacena completo (569XXXXXXXX).</p>
              </div>
            )}

            {myTrades.length === 0 && (
              <div class="text-center py-4 text-sm text-gray-500 bg-gray-50 rounded-xl">
                Publica tu primer oficio para habilitar la edición de biografía y WhatsApp.
              </div>
            )}

            <div class="flex justify-end pt-4">
              <button type="button" class="px-4 py-1.5 bg-gray-100 text-gray-600 rounded-lg text-xs font-bold hover:bg-gray-200 transition mr-2">Cancelar</button>
              <button type="submit" class="px-4 py-1.5 bg-orange-500 text-white rounded-lg text-xs font-bold hover:bg-orange-600 transition shadow-sm">Guardar cambios</button>
            </div>
          </form>
        </section>

        <!-- Mis Servicios -->
        <section id="mis-servicios" class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
          <div class="flex justify-between items-center mb-4">
            <h3 class="font-bold text-gray-800 text-base flex items-center gap-2"><i class="ri-list-settings-line text-orange-500"></i> Mis Servicios Activos</h3>
            <a href="/crear-oficio" class="text-xs bg-orange-500 text-white px-3 py-1.5 rounded-lg font-bold hover:bg-orange-600 transition">+ Nuevo servicio</a>
          </div>

          {myTrades.length === 0 ? (
            <div class="text-center py-8 text-gray-500">
              <i class="ri-briefcase-line text-4xl text-gray-300 mb-2 block"></i>
              <p class="mb-4">Aún no tienes oficios publicados.</p>
              <a href="/crear-oficio" class="inline-block bg-orange-500 text-white px-4 py-2 rounded-xl text-sm font-bold hover:bg-orange-600 transition">Publicar mi primer oficio</a>
            </div>
          ) : (
            <div class="space-y-3">
              {myTrades.map((t) => (
                <div class="flex items-center justify-between p-3 bg-gray-50 rounded-xl hover:bg-white hover:shadow-sm transition border border-transparent hover:border-gray-100">
                  <div class="flex-1">
                    <div class="flex items-center gap-2">
                      <span class="text-xs uppercase tracking-wide font-bold text-orange-600 bg-orange-100 px-2 py-0.5 rounded-full">{t.symbol}</span>
                      <h4 class="font-bold text-gray-800 text-sm">{t.name}</h4>
                      {t.verified && (
                        <span class="text-xs font-bold text-blue-500"><i class="ri-shield-check-fill"></i> Verificado</span>
                      )}
                    </div>
                    <p class="text-xs text-gray-500 mt-1">${(t.basePriceClp ?? 0).toLocaleString('es-CL')} CLP base</p>
                    {Number(t.reviewCount) > 0 && (
                      <p class="text-xs text-gray-400 mt-1">
                        <i class="ri-star-fill text-yellow-400"></i> {(Number(t.ratingAvg) || 0).toFixed(1)} ({t.reviewCount})
                      </p>
                    )}
                  </div>
                  <div class="flex items-center gap-2">
                    {t.status === 'active' && !t.verified ? (
                      <span class="text-xs px-2 py-1 rounded-full font-bold bg-yellow-100 text-yellow-700">Pendiente</span>
                    ) : (
                      <span class={`text-xs px-2 py-1 rounded-full font-bold ${t.status === 'active' ? 'bg-green-100 text-green-700' : 'bg-orange-100 text-orange-700'}`}>
                        {t.status === 'active' ? 'Activo' : 'Pausado'}
                      </span>
                    )}
                    <span class={`text-xs px-2 py-1 rounded-full font-bold ${t.availableNow ? 'bg-green-100 text-green-700 border border-green-200' : 'bg-gray-100 text-gray-400'}`}>
                      <i class="ri-flashlight-fill"></i> {t.availableNow ? 'Disponible' : 'No disponible'}
                    </span>
                    <a href={`/p/${t.slug}`} class="text-xs bg-gray-100 hover:bg-gray-200 text-gray-700 px-3 py-1.5 rounded-lg font-bold transition">Ver</a>
                    <button
                      data-toggle-id={t.id}
                      data-toggle-status={t.status}
                      class="text-xs bg-white border border-gray-200 hover:border-orange-500 text-gray-700 px-3 py-1.5 rounded-lg font-bold transition js-toggle-status"
                    >
                      {t.status === 'active' ? 'Pausar' : 'Activar'}
                    </button>
                    <button
                      data-toggle-availability={t.id}
                      data-avail-current={t.availableNow ? 'true' : 'false'}
                      class="text-xs bg-white border hover:border-green-500 px-3 py-1.5 rounded-lg font-bold transition"
                      class:list={[t.availableNow ? 'bg-green-50 text-green-700 border-green-200 hover:bg-green-100' : 'bg-gray-100 text-gray-500 border-gray-200']}
                    >
                      <i class="ri-flashlight-fill"></i>
                    </button>
                  </div>
                </div>
              ))}
            </div>
          )}
        </section>

        <!-- Mi Horario (placeholder MVP) -->
        <section class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
          <div class="flex justify-between items-center mb-4">
            <h3 class="font-bold text-gray-800 text-base flex items-center gap-2"><i class="ri-time-line text-orange-500"></i> Mi Horario de Atención</h3>
            <span class="text-xs bg-gray-100 text-gray-500 px-2 py-1 rounded">Próximamente</span>
          </div>
          <div class="grid grid-cols-7 gap-2">
            {['L', 'M', 'M', 'J', 'V', 'S', 'D'].map((d, i) => (
              <div class="text-center p-3 bg-gray-50 rounded-xl">
                <p class="text-xs font-bold text-gray-500 uppercase mb-2">{d}</p>
                <p class="text-sm font-bold text-gray-400">{i < 5 ? '9-18' : '—'}</p>
              </div>
            ))}
          </div>
          <p class="text-xs text-gray-500 mt-4 text-center">Configuración detallada de horario disponible en próxima versión (HU-24.2).</p>
        </section>

        <!-- Reseñas -->
        <section id="resenas" class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
          <h3 class="font-bold text-gray-800 text-base mb-4 flex items-center gap-2"><i class="ri-chat-1-line text-orange-500"></i> Reseñas Recibidas</h3>
          {totalReviews === 0 ? (
            <p class="text-sm text-gray-500 text-center py-4">Aún no tienes reseñas.</p>
          ) : (
            <>
              <div class="flex items-center gap-4 mb-6 p-4 bg-gray-50 rounded-2xl">
                <div class="text-center">
                  <span class="block text-3xl font-extrabold text-gray-800">{ratingGlobal.toFixed(1)}</span>
                  <div class="flex justify-center text-yellow-400 text-sm">{estrellas.map((n) => <i class={n <= Math.round(ratingGlobal) ? 'ri-star-fill' : 'ri-star-line'}></i>)}</div>
                  <span class="text-xs text-gray-500">{totalReviews} reseña{totalReviews !== 1 ? 's' : ''}</span>
                </div>
                <div class="flex-1 space-y-1">
                  {ratingBreakdown.map((rb) => (
                    <div class="flex items-center gap-2 text-xs">
                      <span class="w-8 text-right text-gray-600 font-bold">{rb.rating}★</span>
                      <div class="flex-1 h-2 bg-gray-200 rounded-full overflow-hidden">
                        <div class="h-full bg-yellow-400 rounded-full" style={`width: ${totalReviews > 0 ? (rb.count / totalReviews) * 100 : 0}%`}></div>
                      </div>
                      <span class="w-6 text-gray-500">{rb.count}</span>
                    </div>
                  ))}
                </div>
              </div>

              <div class="flex gap-2 mb-4">
                <button type="button" class="text-xs px-3 py-1.5 rounded-lg font-bold bg-orange-500 text-white" data-filter-reviews="all">Todas</button>
                <button type="button" class="text-xs px-3 py-1.5 rounded-lg font-bold bg-gray-100 text-gray-600 hover:bg-gray-200 transition" data-filter-reviews="pending">Sin responder</button>
                <button type="button" class="text-xs px-3 py-1.5 rounded-lg font-bold bg-gray-100 text-gray-600 hover:bg-gray-200 transition" data-filter-reviews="responded">Respondidas</button>
              </div>

              <div class="space-y-3" id="reviews-list">
                {myReviews.map((r) => (
                  <div class="border border-gray-100 rounded-2xl p-4" data-review-id={r.id} data-review-status={r.response ? 'responded' : 'pending'}>
                    <div class="flex items-center gap-2 mb-2">
                      <div class="flex text-yellow-400 text-sm">
                        {[1,2,3,4,5].map((n) => <i class={n <= r.rating ? 'ri-star-fill' : 'ri-star-line'}></i>)}
                      </div>
                      <span class="font-bold text-gray-800 text-sm">{r.reviewerName}</span>
                      <span class="text-[10px] text-gray-400 ml-auto">{r.createdAt.toLocaleDateString('es-CL')}</span>
                    </div>
                    <p class="text-xs text-orange-600 font-bold mb-1">En {r.tradeName} ({r.tradeSymbol})</p>
                    <p class="text-gray-600 text-sm">{r.body}</p>

                    {r.response ? (
                      <div class="mt-3 ml-4 pl-3 border-l-2 border-green-300 bg-green-50/50 rounded-r-lg p-3">
                        <p class="text-xs font-bold text-green-700 mb-1"><i class="ri-reply-line"></i> Tu respuesta</p>
                        <p class="text-gray-700 text-sm">{r.response}</p>
                        {r.respondedAt && <p class="text-[10px] text-gray-400 mt-1">{r.respondedAt.toLocaleDateString('es-CL')}</p>}
                      </div>
                    ) : (
                      <form class="mt-3 ml-4 js-response-form" data-review-id={r.id}>
                        <textarea name="response" rows="2" placeholder="Responde a esta reseña..." class="w-full bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 text-xs focus:outline-none focus:ring-2 focus:ring-orange-500/50 transition" required></textarea>
                        <button type="submit" class="mt-1 text-xs bg-orange-500 text-white px-3 py-1 rounded-lg font-bold hover:bg-orange-600 transition">Responder</button>
                      </form>
                    )}
                  </div>
                ))}
              </div>
            </>
          )}
        </section>

        <!-- Portfolio Section -->
        <section id="portfolio" class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
          <h3 class="font-extrabold text-xl text-gray-800 mb-4 flex items-center gap-2">
            <i class="ri-gallery-line text-orange-500"></i> Portafolio
          </h3>
          {myPortfolio.length > 0 ? (
            <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
              {myPortfolio.map((img) => (
                <a href={`/p/${img.tradeSlug}`} class="group relative rounded-xl overflow-hidden bg-gray-100 aspect-square">
                  <img src={img.url} alt={img.caption || img.tradeName} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
                  {img.caption && <span class="absolute bottom-0 inset-x-0 bg-gradient-to-t from-black/60 to-transparent p-2 text-xs text-white">{img.caption}</span>}
                </a>
              ))}
            </div>
          ) : (
            <div class="text-center py-8 text-gray-500">
              <i class="ri-image-2-line text-4xl text-gray-300 mb-2 block"></i>
              <p class="text-sm font-medium">Aún no tienes fotos en tu portafolio.</p>
              <p class="text-xs text-gray-400 mt-1">Las fotos que subas aparecerán en tu perfil público.</p>
            </div>
          )}
        </section>

        <!-- Tips Banner -->
        <div class="bg-yellow-50 border border-yellow-200 rounded-2xl p-4 flex items-start gap-3">
          <i class="ri-lightbulb-flash-line text-yellow-700 text-2xl flex-shrink-0"></i>
          <div>
            <h4 class="font-bold text-yellow-900 text-sm">Consejo Pro</h4>
            <p class="text-yellow-800 text-xs mt-1">Sube fotos de tus trabajos realizados para aumentar tu visibilidad. Los vecinos contratan 3x más a quienes muestran su portafolio.</p>
          </div>
        </div>
      </div>
    </div>
  </main>

  <script>
    import { initProviderDashboard } from '../lib/client/dashboard/provider';
    import { initProviderPreview, initReviewFilters, initReviewResponseForms } from '../lib/client/dashboard/provider-reviews';
    initProviderDashboard();
    initProviderPreview();
    initReviewFilters();
    initReviewResponseForms();
  </script>
</BaseLayout>