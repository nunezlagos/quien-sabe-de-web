---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageLoader from '../components/home/PageLoader.astro';
import HeroSearch from '../components/home/HeroSearch.astro';
import TradeCard from '../components/home/TradeCard.astro';
import AdBanner from '../components/home/AdBanner.astro';
import LoginModal from '../components/home/LoginModal.astro';
import SidebarFilters from '../components/home/SidebarFilters.astro';
import { getTradesService } from '../lib/services/trades.service';
import { getDb } from '../database/client';
import { communes } from '../database/schema';
import { asc } from 'drizzle-orm';

const isLoggedIn = Boolean(Astro.locals.user);
const user = Astro.locals.user;

const url = Astro.url;
const q = url.searchParams.get('q') ?? '';
const rawCommuneId = url.searchParams.get('commune_id');
const communeId = rawCommuneId ? Number.parseInt(rawCommuneId, 10) : undefined;
const availableNow = url.searchParams.get('available_now') === '1';

const tradesService = getTradesService(Astro.locals);
const results = await tradesService.search({
  q: q || undefined,
  communeId,
  availableNow: availableNow || undefined,
  limit: 50,
});

const db = getDb(Astro.locals);
const communesList = await db.select({ id: communes.id, name: communes.name }).from(communes).orderBy(asc(communes.name)).all();

const allTrades = await tradesService.search({ limit: 50 });
const uniqueTrades = [...new Set(allTrades.map((t) => t.name).filter(Boolean))];
const tradeOptions = uniqueTrades.map((name) => ({ name, slug: name.toLowerCase().replace(/\s+/g, '-') }));
const isSearching = Boolean(q || communeId || availableNow);

const shuffled = [...allTrades].sort(() => Math.random() - 0.5);
const recommendedTrades = shuffled.slice(0, 6);
---

<BaseLayout title="QuiénSabe — Conecta con oficios de tu barrio">
  <PageLoader />

  <!-- Hero section -->
  <div id="hero-section-wrapper">
    <HeroSearch
      q={q}
      communeId={communeId}
      communes={communesList}
      trades={tradeOptions}
    />
  </div>

  <!-- Ad Banner -->
  <section class="ad-section">
    <div class="container">
      <AdBanner />
    </div>
  </section>

  <!-- Main Content -->
  <main class="container main-content">

    {!isSearching && (
      <section class="recommended-section">
        <div class="recommended-header">
          <div>
            <h2 class="section-title">Vecinos Recomendados</h2>
            <p class="section-subtitle">{recommendedTrades.length} disponibles cerca de ti</p>
          </div>
        </div>
        <div class="cards-with-ads">
          <!-- Left lateral ad (desktop only) -->
          <aside class="lateral-ad lateral-ad-left" aria-label="Publicidad">
            <AdBanner />
          </aside>

          <div class="cards-grid">
            {recommendedTrades.map((t) => (
              <TradeCard trade={t} />
            ))}
          </div>

          <!-- Right lateral ad (desktop only) -->
          <aside class="lateral-ad lateral-ad-right" aria-label="Publicidad">
            <AdBanner />
          </aside>
        </div>
      </section>
    )}

    {isSearching && (
      <div class="search-layout container">
        <!-- Sidebar column (desktop only: sidebar + ads) -->
        <div class="sidebar-col">
          <SidebarFilters visible={true} />
          <div class="lateral-ads">
            <AdBanner />
            <AdBanner />
          </div>
        </div>

        <!-- Results column -->
        <div class="results-col" id="results-section">
          <!-- Controls bar -->
          <div class="controls-bar">
            <div class="controls-left">
              <h2 class="section-title">
                {q ? `Resultados para "${q}"` : 'Resultados'}
              </h2>
              <p id="results-count" class="section-subtitle">
                {results.length} vecino{results.length !== 1 ? 's' : ''} disponible{results.length !== 1 ? 's' : ''}
              </p>
            </div>
            <div class="view-toggle">
              <button id="grid-view-btn" class="view-btn view-btn-active" title="Grid" aria-label="Vista grilla">
                <i class="ri-grid-fill"></i>
              </button>
              <button id="list-view-btn" class="view-btn" title="Lista" aria-label="Vista lista">
                <i class="ri-list-check"></i>
              </button>
            </div>
          </div>

          <!-- Mobile ad banner (shown only on mobile) -->
          <div class="mobile-ad">
            <AdBanner />
          </div>

          {results.length === 0 ? (
            <div class="no-results">
              <div class="no-results-icon">
                <i class="ri-search-eye-line"></i>
              </div>
              <h3 class="no-results-title">No encontramos resultados</h3>
              <p class="no-results-text">Intenta con otro oficio o palabra clave.</p>
            </div>
          ) : (
            <div id="neighbors-container" class="cards-grid">
              {results.map((t) => (
                <TradeCard trade={t} />
              ))}
            </div>
          )}

          {(q || communeId) && (
            <p class="search-summary">
              {results.length} resultado{results.length !== 1 ? 's' : ''}
              {q && <> para "<b>{q}</b>"</>}
              {communeId && <> en la comuna seleccionada</>}
              {' · '}
              <a href="/" class="clear-link">Limpiar filtros</a>
            </p>
          )}
        </div>
      </div>
    )}
  </main>



  <script>
    import { initDynamicText } from '../lib/client/home/dynamic-text';
    import { initHomeInteractions } from '../lib/client/home/home-interactions';
    import { initFavButtons } from '../lib/client/ui/favorites';
    import { initHeroCollapse } from '../lib/client/home/hero-collapse';

    document.addEventListener('DOMContentLoaded', () => {
      if (typeof AOS !== 'undefined') {
        AOS.init({
          duration: 600,
          easing: 'ease-out',
          once: true,
          offset: 80,
        });
      }
    });

    initDynamicText();
    initHomeInteractions();
    initFavButtons();
    initHeroCollapse();

    // Smooth scroll to results when arriving with search params
    const urlParams = new URLSearchParams(window.location.search);
    const hasSearch = urlParams.has('q') || urlParams.has('trade') || urlParams.has('commune') || urlParams.has('available_now');
    if (hasSearch) {
      const resultsSection = document.getElementById('results-section');
      if (resultsSection) {
        setTimeout(() => {
          resultsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 100);
      }
    }
  </script>
</BaseLayout>

<style>
  /* === LAYOUT CONTAINERS === */
  .container {
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1rem;
    box-sizing: border-box;
  }

  .main-content {
    padding-top: 1.5rem;
    padding-bottom: 3rem;
  }

  /* === CARDS WITH LATERAL ADS (non-searching) === */
  .cards-with-ads {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .lateral-ad {
    display: none;
  }

  @media (min-width: 900px) {
    .cards-with-ads {
      flex-direction: row;
      align-items: stretch;
      gap: 1rem;
    }

    .lateral-ad {
      display: block;
      width: 120px;
      flex-shrink: 0;
      position: sticky;
      top: 0;
      height: 100vh;
    }

    .lateral-ad :global(.ad-banner) {
      height: 100%;
      min-height: 400px;
    }

    .cards-grid {
      flex: 1;
      min-width: 0;
    }
  }

  /* === HERO WRAPPER — handles collapse state === */
  #hero-section-wrapper {
    transition: all 300ms ease;
  }

  #hero-section-wrapper.hero-collapsed :global(.hero-section) {
    padding: 0.5rem 1rem;
  }

  #hero-section-wrapper.hero-collapsed :global(.hero-title),
  #hero-section-wrapper.hero-collapsed :global(.hero-desc),
  #hero-section-wrapper.hero-collapsed :global(.hero-notice) {
    display: none;
  }

  #hero-section-wrapper.hero-collapsed :global(.search-container) {
    padding: 0.25rem;
    gap: 0.25rem;
  }

  #hero-section-wrapper.hero-collapsed :global(.search-btn) {
    padding: 0.4rem 0.75rem;
    font-size: 0.8125rem;
  }

  /* === AD SECTION === */
  .ad-section {
    background: var(--cream-200);
    padding: 0.875rem 0;
    border-bottom: 1px solid var(--border-light);
  }

  /* === RECOMMENDED SECTION === */
  .recommended-section {
    margin-bottom: 2rem;
  }

  .recommended-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 1.25rem;
    gap: 0.75rem;
  }

  .section-title {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .section-subtitle {
    font-size: 0.8125rem;
    color: var(--text-muted);
    font-weight: 500;
    margin-top: 0.125rem;
  }

  /* === CARDS GRID === */
  .cards-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }

  @media (min-width: 480px) {
    .cards-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 900px) {
    .cards-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* === SEARCH LAYOUT === */
  .search-layout {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* Mobile: sidebar hidden, full-width results */
  .sidebar-col {
    display: none;
  }

  .results-col {
    width: 100%;
  }

  /* Mobile ad — shown only on mobile */
  .mobile-ad {
    display: block;
    margin-bottom: 0.75rem;
  }

  /* === LATERAL ADS === */
  .lateral-ads {
    display: none;
  }

  /* Desktop: sidebar left, results right */
  @media (min-width: 900px) {
    .search-layout {
      flex-direction: row;
      align-items: flex-start;
      gap: 1.5rem;
      max-width: 1280px;
      margin: 0 auto;
      box-sizing: border-box;
    }

    .sidebar-col {
      width: 280px;
      flex-shrink: 0;
      position: sticky;
      top: 1rem;
      max-height: calc(100vh - 2rem);
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .results-col {
      flex: 1;
      min-width: 0;
      max-width: calc(1280px - 280px - 1.5rem);
      overflow: hidden;
    }

    .mobile-ad {
      display: none;
    }

    .lateral-ads {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
  }

  /* === CONTROLS BAR === */
  .controls-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border-default);
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .controls-left {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    min-width: 0;
  }

  .controls-left .section-title {
    font-size: 1.125rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }

  .view-toggle {
    display: flex;
    gap: 0.25rem;
    background: white;
    border: 1px solid var(--border-default);
    border-radius: var(--radius-xl);
    padding: 0.25rem;
    box-shadow: var(--shadow-card);
    flex-shrink: 0;
  }

  .view-btn {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    background: transparent;
    color: var(--stone-400);
    cursor: pointer;
    transition: all 200ms ease;
    font-size: 1rem;
  }

  .view-btn:hover {
    color: var(--amber-600);
    background: var(--amber-50);
  }

  .view-btn-active {
    background: white;
    color: var(--amber-600);
    box-shadow: var(--shadow-card);
  }

  /* === NO RESULTS === */
  .no-results {
    text-align: center;
    padding: 3rem 1.5rem;
    background: white;
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-card);
    border: 1px solid var(--border-default);
  }

  .no-results-icon {
    width: 4rem;
    height: 4rem;
    border-radius: var(--radius-2xl);
    background: var(--stone-100);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1rem;
    font-size: 2rem;
    color: var(--stone-300);
  }

  .no-results-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.375rem;
  }

  .no-results-text {
    font-size: 0.875rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  /* === SEARCH SUMMARY === */
  .search-summary {
    margin-top: 1.25rem;
    text-align: center;
    font-size: 0.8125rem;
    color: var(--text-secondary);
  }

  .clear-link {
    color: var(--amber-600);
    font-weight: 700;
    text-decoration: underline;
  }

  /* === LIST VIEW === */
  .cards-grid.list-view {
    grid-template-columns: 1fr;
  }

  /* Tablet adjustment: 2 columns for cards even in search */
  @media (min-width: 640px) and (max-width: 899px) {
    .search-layout .cards-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
