---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageLoader from '../components/home/PageLoader.astro';
import HeroSearch from '../components/home/HeroSearch.astro';
import HeroTradeCard from '../components/home/HeroTradeCard.astro';
import TradeCarousel from '../components/home/TradeCarousel.astro';
import AdBanner from '../components/home/AdBanner.astro';
import LoginModal from '../components/home/LoginModal.astro';
import SidebarFilters from '../components/home/SidebarFilters.astro';
import { getTradesService } from '../lib/services/trades.service';
import { getDb } from '../database/client';
import { communes } from '../database/schema';
import { asc } from 'drizzle-orm';

const isLoggedIn = Boolean(Astro.locals.user);
const user = Astro.locals.user;

const db = getDb();
const communesList = await db.select({ id: communes.id, name: communes.name }).from(communes).orderBy(asc(communes.name)).all();

const url = Astro.url;
const params = url.searchParams;
const q = params.get('q') ?? '';
const tradeName = params.get('trade') ?? '';
const communeName = params.get('commune') ?? '';
const communeId = communesList.find((c) => c.name === communeName)?.id;
const availableNow = params.get('available_now') === '1';
const verified = params.get('verified') === '1';
const priceMinRaw = Number.parseInt(params.get('price_min') ?? '', 10);
const priceMaxRaw = Number.parseInt(params.get('price_max') ?? '', 10);
const priceMin = Number.isNaN(priceMinRaw) ? undefined : priceMinRaw;
const priceMax = Number.isNaN(priceMaxRaw) ? undefined : priceMaxRaw;

const tradesService = getTradesService(Astro.locals);
const results = await tradesService.search({
  q: q || undefined,
  tradeName: tradeName || undefined,
  communeId,
  availableNow: availableNow || undefined,
  verified: verified || undefined,
  priceMin,
  priceMax,
  limit: 50,
});

const allTrades = await tradesService.search({ limit: 50 });
const uniqueTrades = [...new Set(allTrades.map((t) => t.name).filter(Boolean))];
const tradeOptions = uniqueTrades.map((name) => ({ name, slug: name.toLowerCase().replace(/\s+/g, '-') }));
const isSearching = Boolean(q || tradeName || communeName || availableNow || verified || priceMin !== undefined || priceMax !== undefined);
const filterState = { q, tradeName, communeName, availableNow, verified, priceMin, priceMax };

const shuffled = [...allTrades].sort(() => Math.random() - 0.5);
const recommendedTrades = shuffled.slice(0, 6);
const carouselTrades = shuffled.slice(0, 12);

// collage del hero: formas espaciadas (1 cada 4, rotando) + padding de cuadrados
// para que la ultima fila del mosaico quede siempre completa (repite imagen si hace falta)
const COLLAGE_COUNT = 198;
const COLLAGE_COLS = 20;
// solo 40 imagenes unicas: los tiles reusan src (i % UNIQUE_IMAGES) para cortar requests
const UNIQUE_IMAGES = 40;
const collageShapes = ['c-wide', 'c-tall', 'c-big'];
const shapeCells = { 'c-wide': 2, 'c-tall': 2, 'c-big': 4, '': 1 };
const collageTiles = Array.from({ length: COLLAGE_COUNT }, (_, i) =>
  i % 4 === 0 ? collageShapes[(i / 4) % 3] : ''
);
let collageCells = collageTiles.reduce((sum, sh) => sum + shapeCells[sh], 0);
while (collageCells % COLLAGE_COLS !== 0) {
  collageTiles.push('');
  collageCells++;
}
// brillo random: ~35% de los tiles pulsan con delay/duracion aleatorios (varios a la vez, sin orden)
const collageGlow = collageTiles.map(() =>
  Math.random() > 0.35
    ? null
    : { delay: (Math.random() * 8).toFixed(2), dur: (4 + Math.random() * 3).toFixed(2) }
);
---

<BaseLayout title="QuiénSabe — Conecta con oficios de tu barrio">
  <PageLoader />

  <!-- Primera sección: hero + publicidad sobre un collage de oficios -->
  <section class:list={['hero-block', { 'hero-block-search': isSearching }]}>
    {!isSearching && (
    <div class="hero-collage" aria-hidden="true">
      {collageTiles.map((shape, i) => {
        const glow = collageGlow[i];
        const cls = ['c-tile', shape, glow ? 'c-glow' : ''].filter(Boolean).join(' ');
        return (
          <div
            class={cls}
            style={glow ? `--glow-delay:${glow.delay}s;--glow-dur:${glow.dur}s` : undefined}
          >
            <img
              src={`/images/collage/${String(i % UNIQUE_IMAGES).padStart(3, '0')}.webp`}
              alt=""
              decoding="async"
            />
          </div>
        );
      })}
    </div>
    )}
    <div id="hero-section-wrapper">
      <HeroSearch
        q={q}
        selectedTrade={tradeName}
        selectedCommune={communeName}
        availableNow={availableNow}
        communes={communesList}
        trades={tradeOptions}
      />
    </div>

    {!isSearching && <TradeCarousel trades={carouselTrades} />}

    {!isSearching && (
    <div class="ad-section">
      <div class="container">
        <AdBanner />
      </div>
    </div>
    )}
  </section>

  <!-- Main Content -->
  <main class:list={['container', 'main-content', { 'main-search': isSearching }]}>

    {!isSearching && (
      <section id="recomendados" class="recommended-section">
        <div class="recommended-header">
          <div>
            <h2 class="section-title">Vecinos Recomendados</h2>
            <p class="section-subtitle">{recommendedTrades.length} disponibles cerca de ti</p>
          </div>
        </div>
        <div class="cards-with-ads">
          <!-- Left lateral ad (desktop only) — el AdBanner ya expone role=complementary -->
          <div class="lateral-ad lateral-ad-left">
            <AdBanner />
          </div>

          <div class="cards-grid">
            {recommendedTrades.map((t) => (
              <HeroTradeCard trade={t as any} />
            ))}
          </div>

          <!-- Right lateral ad (desktop only) — el AdBanner ya expone role=complementary -->
          <div class="lateral-ad lateral-ad-right">
            <AdBanner />
          </div>
        </div>
      </section>
    )}

    {isSearching && (
      <div class="search-layout container">
        <!-- Sidebar column (solo filtros, sin publicidad) -->
        <div class="sidebar-col" id="search-filters">
          <SidebarFilters filters={filterState} />
        </div>

        <!-- Results column -->
        <div class="results-col" id="results-section">
          <button id="filters-toggle-btn" type="button" class="filters-toggle" aria-controls="search-filters" aria-expanded="false">
            <i class="ri-equalizer-line" aria-hidden="true"></i> Filtros
          </button>
          <!-- Controls bar -->
          <div class="controls-bar">
            <div class="controls-left">
              <h2 class="section-title">
                {q ? `Resultados para "${q}"` : 'Resultados'}
              </h2>
              <p id="results-count" class="section-subtitle">
                {results.length} vecino{results.length !== 1 ? 's' : ''} disponible{results.length !== 1 ? 's' : ''}
              </p>
            </div>
            <div class="view-toggle" role="group" aria-label="Cambiar vista de resultados">
              <button id="grid-view-btn" type="button" class="view-btn view-btn-active" title="Grid" aria-label="Vista grilla" aria-pressed="true">
                <i class="ri-grid-fill" aria-hidden="true"></i>
              </button>
              <button id="list-view-btn" type="button" class="view-btn" title="Lista" aria-label="Vista lista" aria-pressed="false">
                <i class="ri-list-check" aria-hidden="true"></i>
              </button>
            </div>
          </div>

          {results.length === 0 ? (
            <div class="no-results">
              <div class="no-results-icon">
                <i class="ri-search-eye-line"></i>
              </div>
              <h3 class="no-results-title">No encontramos resultados</h3>
              <p class="no-results-text">Intenta con otro oficio o palabra clave.</p>
            </div>
          ) : (
            <div id="neighbors-container" class="cards-grid">
              {results.map((t) => (
                <HeroTradeCard trade={t as any} />
              ))}
            </div>
          )}

          {(q || communeId) && (
            <p class="search-summary">
              {results.length} resultado{results.length !== 1 ? 's' : ''}
              {q && <> para "<b>{q}</b>"</>}
              {communeId && <> en la comuna seleccionada</>}
              {' · '}
              <a href="/" class="clear-link">Limpiar filtros</a>
            </p>
          )}
        </div>
      </div>
    )}
  </main>

  <button id="scroll-fab" type="button" class="scroll-fab" aria-label="Ir a Vecinos Recomendados">
    <i class="ri-arrow-down-line" aria-hidden="true"></i>
  </button>

  <script>
    import { initDynamicText } from '../lib/client/home/dynamic-text';
    import { initHomeInteractions } from '../lib/client/home/home-interactions';
    import { initFavButtons } from '../lib/client/ui/favorites';
    import { initScrollFab } from '../lib/client/home/scroll-fab';
    import { initFiltersToggle } from '../lib/client/home/filters-toggle';

    document.addEventListener('DOMContentLoaded', () => {
      if (typeof AOS !== 'undefined') {
        AOS.init({
          duration: 600,
          easing: 'ease-out',
          once: true,
          offset: 80,
        });
      }
    });

    initDynamicText();
    initHomeInteractions();
    initFavButtons();
    initScrollFab();
    initFiltersToggle();
  </script>
</BaseLayout>

<style>
  /* === LAYOUT CONTAINERS === */
  .container {
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1rem;
    box-sizing: border-box;
  }

  .main-content {
    padding-top: 1.5rem;
    padding-bottom: 3rem;
  }

  /* === CARDS WITH LATERAL ADS (non-searching) === */
  .cards-with-ads {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .lateral-ad {
    display: none;
  }

  @media (min-width: 900px) {
    .cards-with-ads {
      flex-direction: row;
      align-items: stretch;
      gap: 1rem;
    }

    .lateral-ad {
      display: block;
      width: 120px;
      flex-shrink: 0;
      position: sticky;
      top: 1rem;
      max-height: calc(100vh - 2rem);
    }

    .lateral-ad :global(.ad-banner) {
      height: 100%;
      max-height: calc(100vh - 2rem);
      min-height: 400px;
      justify-content: center;
    }

    /* en la columna angosta solo se muestra la palabra PUBLICIDAD de lado */
    .lateral-ad :global(.ad-content),
    .lateral-ad :global(.ad-arrow) {
      display: none;
    }

    .lateral-ad :global(.ad-badge) {
      position: static;
      background: transparent;
      color: var(--stone-500);
      font-size: 0.9375rem;
      letter-spacing: 0.2em;
      padding: 0;
      border-radius: 0;
      transform: rotate(-90deg);
      white-space: nowrap;
    }

    .cards-grid {
      flex: 1;
      min-width: 0;
    }
  }

  /* === HERO WRAPPER — handles collapse state === */
  #hero-section-wrapper {
    transition: all 300ms ease;
  }

  #hero-section-wrapper.hero-collapsed :global(.hero-section) {
    padding: 0.5rem 1rem;
  }

  #hero-section-wrapper.hero-collapsed :global(.hero-title),
  #hero-section-wrapper.hero-collapsed :global(.hero-desc),
  #hero-section-wrapper.hero-collapsed :global(.hero-notice) {
    display: none;
  }

  #hero-section-wrapper.hero-collapsed :global(.search-container) {
    padding: 0.25rem;
    gap: 0.25rem;
  }

  #hero-section-wrapper.hero-collapsed :global(.search-btn) {
    padding: 0.4rem 0.75rem;
    font-size: 0.8125rem;
  }

  /* === PRIMERA SECCIÓN (hero + ad sobre foto, ocupa el viewport) === */
  .hero-block {
    position: relative;
    min-height: calc(100dvh - 4rem);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 4rem 0 3rem;
    background: var(--cream-200);
    overflow: hidden;
  }

  /* collage: cada oficio en su propio frame dentro de una grilla */
  .hero-collage {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: grid;
    grid-template-columns: repeat(20, 1fr);
    grid-auto-rows: calc((100dvh - 4rem) / 12);
    grid-auto-flow: dense;
    gap: 2px;
  }

  .hero-collage .c-tile {
    position: relative;
    overflow: hidden;
    min-width: 0;
    min-height: 0;
    isolation: isolate;
  }

  .hero-collage img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* mezcla desordenada: algunos tiles rectangulares */
  .hero-collage .c-wide { grid-column: span 2; }
  .hero-collage .c-tall { grid-row: span 2; }
  .hero-collage .c-big { grid-column: span 2; grid-row: span 2; }

  /* mascara naranja de marca: subconjunto random se tiñe, sin orden */
  .hero-collage .c-glow img {
    animation: tile-glow var(--glow-dur, 6s) ease-in-out var(--glow-delay, 0s) infinite;
  }

  .hero-collage .c-glow::after {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--color-accent);
    mix-blend-mode: color;
    opacity: 0;
    pointer-events: none;
    animation: tile-tint var(--glow-dur, 6s) ease-in-out var(--glow-delay, 0s) infinite;
  }

  @keyframes tile-glow {
    0%, 100% { filter: brightness(1); }
    50% { filter: brightness(1.4); }
  }

  @keyframes tile-tint {
    0%, 100% { opacity: 0; }
    50% { opacity: 0.85; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-collage .c-glow img,
    .hero-collage .c-glow::after { animation: none; }
  }

  @media (max-width: 640px) {
    .hero-collage {
      grid-template-columns: repeat(10, 1fr);
    }
  }

  /* velo naranja calido para legibilidad de los textos sobre el collage */
  .hero-block::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(180deg, rgba(21, 128, 61, 0.62) 0%, rgba(22, 163, 74, 0.28) 55%, rgba(34, 197, 94, 0.21) 100%);
    pointer-events: none;
  }

  .hero-block > #hero-section-wrapper,
  .hero-block > .ad-section {
    position: relative;
    z-index: 2;
  }

  /* texto del hero en claro para que resalte sobre el velo naranja */
  .hero-block :global(.hero-title) {
    color: var(--cream-50);
    text-shadow: 0 2px 4px rgba(20, 83, 45, 0.55), 0 1px 16px rgba(20, 83, 45, 0.45);
  }

  .hero-block :global(.dynamic-trade) {
    color: var(--orange-500);
    text-shadow: 0 0 12px rgba(255, 255, 255, 0.9), 0 1px 3px rgba(255, 255, 255, 0.8);
  }

  .hero-block :global(.hero-desc) {
    color: #fff;
    font-weight: 900;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.9), 0 2px 10px rgba(0, 0, 0, 0.7);
  }

  /* === AD SECTION === */
  .ad-section {
    background: transparent;
    padding: 0.875rem 0 2rem;
  }

  /* === MODO BÚSQUEDA (hero oculto, barra compacta) === */
  .hero-block-search {
    min-height: auto;
    padding: 0.75rem 0 1rem;
    justify-content: flex-start;
    position: sticky;
    top: 4rem;
    z-index: 20;
  }

  .hero-block-search::before {
    display: none;
  }

  .hero-block-search :global(.hero-title),
  .hero-block-search :global(.hero-desc) {
    display: none;
  }

  /* fondo full-bleed cream para toda la sección de búsqueda (no un panel centrado) */
  .main-search {
    max-width: none;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    padding: 1.5rem max(1rem, calc(50vw - 640px)) 3rem;
    background: var(--cream-200);
    background-image:
      radial-gradient(circle at 15% 0%, rgba(234, 88, 12, 0.06), transparent 40%),
      radial-gradient(circle at 85% 20%, rgba(234, 88, 12, 0.05), transparent 45%);
  }

  /* === RECOMMENDED SECTION === */
  .recommended-section {
    margin-bottom: 2rem;
    scroll-margin-top: 5rem;
    padding: 1.5rem 1.25rem;
    background: linear-gradient(135deg, rgba(255, 237, 213, 0.5) 0%, rgba(255, 250, 245, 0.35) 100%);
    border: 1px solid rgba(255, 255, 255, 0.6);
    border-radius: var(--radius-2xl);
    box-shadow: 0 8px 32px rgba(234, 88, 12, 0.08);
  }

  .recommended-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    margin-bottom: 1.25rem;
    gap: 0.25rem;
  }

  .section-title {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .section-subtitle {
    font-size: 0.8125rem;
    color: var(--text-muted);
    font-weight: 500;
    margin-top: 0.125rem;
  }

  /* === CARDS GRID === */
  .cards-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }

  .recommended-section .cards-grid {
    gap: 1rem;
  }

  @media (min-width: 480px) {
    .cards-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /*
   * En 900px aparecen los anuncios laterales (2 × 120px + gaps), por lo que
   * mantenemos 2 columnas en este paso intermedio para no estrujar las cards.
   * Recién en pantallas anchas pasamos a 3 columnas.
   */
  @media (min-width: 1100px) {
    .cards-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* === SEARCH LAYOUT === */
  .search-layout {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* Mobile: sidebar hidden tras un toggle, full-width results */
  .sidebar-col {
    display: none;
  }

  .search-layout.filters-open .sidebar-col {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    width: 100%;
    margin-bottom: 1rem;
  }

  /* el panel de filtros ocupa el mismo ancho que las cards de abajo */
  .search-layout.filters-open .sidebar-col :global(.sidebar-wrapper),
  .search-layout.filters-open .sidebar-col :global(.widget-card) {
    width: 100%;
  }

  .filters-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    align-self: flex-start;
    margin-bottom: 0.75rem;
    padding: 0.5rem 0.9rem;
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--text-primary);
    background: var(--bg-card);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-card);
    cursor: pointer;
  }

  .filters-toggle:focus-visible {
    outline: 2px solid var(--border-focus);
    outline-offset: 2px;
  }

  .results-col {
    width: 100%;
  }

  /* Mobile ad — shown only on mobile */
  .mobile-ad {
    display: block;
    margin-bottom: 0.75rem;
  }

  /* === LATERAL ADS === */
  .lateral-ads {
    display: none;
  }

  /* Desktop: sidebar left, results right */
  @media (min-width: 900px) {
    .search-layout {
      flex-direction: row;
      align-items: flex-start;
      gap: 1.5rem;
      max-width: 1280px;
      margin: 0 auto;
      box-sizing: border-box;
    }

    .sidebar-col {
      width: 280px;
      flex-shrink: 0;
      position: sticky;
      top: 1rem;
      max-height: calc(100vh - 2rem);
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .filters-toggle {
      display: none;
    }

    .results-col {
      flex: 1;
      min-width: 0;
      max-width: calc(1280px - 280px - 1.5rem);
      overflow: hidden;
    }

    .mobile-ad {
      display: none;
    }

    .lateral-ads {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .lateral-ads :global(.ad-banner) {
      min-height: 320px;
      justify-content: center;
    }

    /* mismo criterio que .lateral-ad: solo la palabra PUBLICIDAD de lado */
    .lateral-ads :global(.ad-content),
    .lateral-ads :global(.ad-arrow) {
      display: none;
    }

    .lateral-ads :global(.ad-badge) {
      position: static;
      background: transparent;
      color: var(--stone-500);
      font-size: 0.9375rem;
      letter-spacing: 0.2em;
      padding: 0;
      border-radius: 0;
      transform: rotate(-90deg);
      white-space: nowrap;
    }
  }

  /* === CONTROLS BAR === */
  .controls-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border-default);
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .controls-left {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    min-width: 0;
  }

  .controls-left .section-title {
    font-size: 1.125rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }

  .view-toggle {
    display: flex;
    gap: 0.25rem;
    background: var(--bg-card);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-xl);
    padding: 0.25rem;
    box-shadow: var(--shadow-card);
    flex-shrink: 0;
  }

  .view-btn {
    width: 2.75rem;
    height: 2.75rem;
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    background: transparent;
    color: var(--stone-400);
    cursor: pointer;
    transition: all 200ms ease;
    font-size: 1rem;
  }

  .view-btn:hover {
    color: var(--amber-600);
    background: var(--amber-50);
  }

  .view-btn:focus-visible {
    outline: 2px solid var(--border-focus);
    outline-offset: 2px;
  }

  .view-btn-active {
    background: var(--bg-card);
    color: var(--amber-600);
    box-shadow: var(--shadow-card);
  }

  /* === NO RESULTS === */
  .no-results {
    text-align: center;
    padding: 3rem 1.5rem;
    background: var(--bg-card);
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-card);
    border: 1px solid var(--border-default);
  }

  .no-results-icon {
    width: 4rem;
    height: 4rem;
    border-radius: var(--radius-2xl);
    background: var(--stone-100);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1rem;
    font-size: 2rem;
    color: var(--stone-300);
  }

  .no-results-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.375rem;
  }

