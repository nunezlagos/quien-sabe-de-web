---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageLoader from '../components/home/PageLoader.astro';
import HeroSearch from '../components/home/HeroSearch.astro';
import TradeCard from '../components/home/TradeCard.astro';
import TradeCardList from '../components/home/TradeCardList.astro';
import AdBanner from '../components/home/AdBanner.astro';
import LoginModal from '../components/home/LoginModal.astro';
import SidebarFilters from '../components/home/SidebarFilters.astro';
import { getTradesService } from '../lib/services/trades.service';
import { getDb } from '../database/client';
import { communes } from '../database/schema';
import { asc } from 'drizzle-orm';

const isLoggedIn = Boolean(Astro.locals.user);
const usuario = Astro.locals.user;

const url = Astro.url;
const q = url.searchParams.get('q') ?? '';
const rawCommuneId = url.searchParams.get('commune_id');
const communeId = rawCommuneId ? Number.parseInt(rawCommuneId, 10) : undefined;

const tradesService = getTradesService(Astro.locals);
const resultados = await tradesService.search({
  q: q || undefined,
  communeId,
  limit: 50,
});

const db = getDb(Astro.locals);
const communesList = await db.select({ id: communes.id, name: communes.name }).from(communes).orderBy(asc(communes.name)).all();

const allTrades = await tradesService.search({ limit: 50 });
const uniqueTrades = [...new Set(allTrades.map((t) => t.name).filter(Boolean))];
const tradeOptions = uniqueTrades.map((name) => ({ name, slug: name.toLowerCase().replace(/\s+/g, '-') }));
---

<BaseLayout title="QuiénSabe — Conecta con oficios de tu barrio">
  <PageLoader />

  <HeroSearch
    q={q}
    communeId={communeId}
    communes={communesList}
    trades={tradeOptions}
  />

  <main class="container mx-auto px-4 py-12 flex-grow">
    <!-- Advertisement Banner -->
    <AdBanner />

    <!-- Controls -->
    <div class="flex justify-between items-end mb-8 border-b border-gray-200 pb-4">
      <div>
        <h2 class="text-2xl font-extrabold text-gray-800">
          {q ? 'Resultados' : 'Vecinos Recomendados'}
        </h2>
        <p id="results-count" class="text-gray-500 text-sm mt-1 font-medium">
          {resultados.length} vecino{resultados.length !== 1 ? 's' : ''} disponible{resultados.length !== 1 ? 's' : ''}
        </p>
      </div>

      <div class="flex gap-2 bg-white p-1 rounded-xl shadow-sm border border-gray-200">
        <button id="grid-view-btn" class="p-2 rounded-lg bg-white shadow-sm text-primary transition">
          <i class="ri-grid-fill text-xl"></i>
        </button>
        <button id="list-view-btn" class="p-2 rounded-lg text-gray-400 hover:text-primary transition">
          <i class="ri-list-check text-xl"></i>
        </button>
      </div>
    </div>

    <div class="flex flex-col md:flex-row gap-8 items-start">
      <!-- Sidebar Filters -->
      <SidebarFilters visible={isSearching} />

      <!-- Grid Container -->
      <div class="flex-grow w-full">
        {resultados.length === 0 ? (
          <div id="no-results" class="text-center py-20">
            <div class="bg-gray-100 rounded-full w-24 h-24 flex items-center justify-center mx-auto mb-4">
              <i class="ri-search-eye-line text-4xl text-gray-400"></i>
            </div>
            <h3 class="text-xl font-bold text-gray-700">No encontramos resultados</h3>
            <p class="text-gray-500 font-medium">Intenta con otro oficio o palabra clave.</p>
          </div>
        ) : (
          <div id="neighbors-container" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {resultados.map((t) => (
              <TradeCard trade={t} />
            ))}
          </div>
        )}

        {(q || communeId) && (
          <p class="mt-4 text-sm text-gray-600 text-center">
            {resultados.length} resultado{resultados.length !== 1 ? 's' : ''}
            {q && <> para "<b>{q}</b>"</>}
            {communeId && <> en la comuna seleccionada</>}
            {' · '}
            <a href="/" class="text-orange-500 underline">Limpiar filtros</a>
          </p>
        )}
      </div>
    </div>
  </main>

  <!-- Login Modal -->
  {isLoggedIn ? null : <LoginModal />}

  <script>
    import { initDynamicText } from '../lib/client/home/dynamic-text';
    import { initHomeInteractions } from '../lib/client/home/home-interactions';
    initDynamicText();
    initHomeInteractions();
  </script>
</BaseLayout>
