---
import BaseLayout from '../layouts/BaseLayout.astro';

const currentUser = Astro.locals.user;
if (!currentUser) {
  return Astro.redirect('/iniciar-sesion?redirigir=/verificar-oficio');
}
if (currentUser.role !== 'provider' && currentUser.role !== 'admin') {
  return Astro.redirect('/dashboard');
}

const error = Astro.url.searchParams.get('error');
const ok = Astro.url.searchParams.get('ok');
const tradeRecibido = Astro.url.searchParams.get('trade');
const rutRecibido = Astro.url.searchParams.get('rut');

const OFICIOS_VERIFICABLES = [
  { value: '', label: 'Selecciona tu oficio…' },
  { value: 'gasfiter', label: 'Gasfiter' },
  { value: 'electricista', label: 'Electricista' },
  { value: 'maestro', label: 'Maestro' },
  { value: 'jardinero', label: 'Jardinero' },
  { value: 'programador', label: 'Programador' },
  { value: 'pintor', label: 'Pintor' },
  { value: 'costurera', label: 'Costurera' },
];
---

<BaseLayout title="Verificación de Oficio — QuiénSabe">
  <header class="verif-header">
    <div class="verif-header-bg" aria-hidden="true"></div>
    <div class="verif-header-inner">
      <div class="verif-header-badge">
        <i class="ri-shield-check-fill" aria-hidden="true"></i>
      </div>
      <h1 class="verif-header-title">Verifica tu Oficio</h1>
      <p class="verif-header-lead">Genera confianza en tu comunidad. Destaca tu perfil con el sello de verificado y consigue más clientes.</p>
    </div>
  </header>

  <main class="verif-main">
    <div class="verif-note">
      <i class="ri-heart-line verif-note-icon" aria-hidden="true"></i>
      <div>
        <h2 class="verif-note-title">Tu trabajo vale</h2>
        <p class="verif-note-text">Sabemos que eres un profesional, tengas o no una empresa formal. La verificación es solo una herramienta para que tus vecinos te conozcan mejor y confíen en tu talento.</p>
      </div>
    </div>

    <ol class="verif-steps">
      <li class="verif-step">
        <span class="verif-step-num verif-step-num-1" aria-hidden="true">1</span>
        <h3 class="verif-step-title">Regístrate</h3>
        <p class="verif-step-text">Crea tu perfil con tus datos básicos y cuéntanos qué oficios realizas.</p>
      </li>

      <li class="verif-step">
        <span class="verif-step-num verif-step-num-2" aria-hidden="true">2</span>
        <h3 class="verif-step-title">Sube documentos</h3>
        <p class="verif-step-text">Tu RUT, certificaciones y fotos de trabajos.</p>
      </li>

      <li class="verif-step">
        <span class="verif-step-num verif-step-num-3" aria-hidden="true">3</span>
        <h3 class="verif-step-title">¡Listo!</h3>
        <p class="verif-step-text">Revisaremos tu perfil y te otorgaremos el sello de verificado.</p>
      </li>
    </ol>

    <div class="verif-card">
      <div class="verif-card-head">
        <h2 class="verif-card-title">Solicitud de Verificación</h2>
        <p class="verif-card-sub">Completa lo que puedas. No es necesario tener todo.</p>
      </div>

      {error && (
        <div class="verif-alert verif-alert-error" role="alert">
          {error}
        </div>
      )}

      {ok && (
        <div class="verif-alert verif-alert-ok" role="status">
          <i class="ri-checkbox-circle-fill verif-alert-icon" aria-hidden="true"></i>
          <div>
            <p class="verif-alert-title">¡Solicitud enviada!</p>
            <p class="verif-alert-text">Recibimos tu verificación para <b>{tradeRecibido}</b> con RUT <b>{rutRecibido}</b>. Te avisaremos por email en 24-48h. Próximamente: subir documentos.</p>
          </div>
        </div>
      )}

      <form action="/api/v1/providers/me/verification" method="POST" class="verif-form">
        <div class="verif-field">
          <label for="rut" class="verif-label">Tu RUT <span class="verif-required" aria-hidden="true">*</span></label>
          <input id="rut" name="rut" type="text" required placeholder="12345678-9" pattern="[0-9]+-[0-9kK]" maxlength="12" class="verif-input" aria-describedby="rut-hint">
          <p id="rut-hint" class="verif-hint">Formato: 12345678-9 (sin puntos, con guión).</p>
        </div>

        <div class="verif-field">
          <label for="trade" class="verif-label">Oficio principal a verificar <span class="verif-required" aria-hidden="true">*</span></label>
          <select id="trade" name="trade" required class="verif-input">
            {OFICIOS_VERIFICABLES.map((o) => (
              <option value={o.value}>{o.label}</option>
            ))}
          </select>
        </div>

        <div class="verif-info">
          <i class="ri-information-line verif-info-icon" aria-hidden="true"></i>
          <p><b>Próximo paso:</b> tras enviar este formulario, te pediremos que subas tus documentos (cédula, certificaciones) y fotos de trabajos realizados en la siguiente pantalla.</p>
        </div>

        <button type="submit" class="verif-submit">
          Continuar a subir documentos →
        </button>
      </form>
    </div>
  </main>

  <footer class="verif-footer">
    <div class="verif-footer-inner">
      <p>&copy; 2026 Quién Sabe. Todos los derechos reservados.</p>
    </div>
  </footer>

  <style>
    /* Header full-bleed responsive */
    .verif-header {
      position: relative;
      overflow: hidden;
      background: var(--color-primary);
      color: var(--cream-50);
      text-align: center;
      padding: clamp(2.5rem, 8vw, 4rem) 1rem;
    }

    .verif-header-bg {
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, var(--orange-400), var(--orange-600));
      opacity: 0.25;
    }

    .verif-header-inner {
      position: relative;
      z-index: 1;
      max-width: 42rem;
      margin: 0 auto;
    }

    .verif-header-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 1rem;
      margin-bottom: 1rem;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.12);
      border: 1px solid rgba(255, 255, 255, 0.25);
    }

    .verif-header-badge i {
      font-size: 2.5rem;
      line-height: 1;
    }

    .verif-header-title {
      font-size: clamp(1.75rem, 6vw, 3rem);
      font-weight: 800;
      margin-bottom: 0.75rem;
      overflow-wrap: break-word;
    }

    .verif-header-lead {
      font-size: clamp(0.95rem, 2.5vw, 1.125rem);
      color: var(--orange-100);
      max-width: 40rem;
      margin: 0 auto;
    }

    /* Main */
    .verif-main {
      max-width: 56rem;
      margin: 0 auto;
      padding: 3rem 1rem;
    }

    /* Nota destacada (info) */
    .verif-note {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      background: var(--color-info-light);
      border: 1px solid var(--color-info-border);
      border-radius: var(--radius-xl);
      padding: 1.5rem;
      margin-bottom: 3rem;
    }

    .verif-note-icon {
      font-size: 1.75rem;
      color: var(--blue-500);
      flex-shrink: 0;
    }

    .verif-note-title {
      font-weight: 700;
      font-size: 1.125rem;
      color: var(--blue-700);
      margin-bottom: 0.25rem;
    }

    .verif-note-text {
      font-size: 0.875rem;
      color: var(--color-info-text);
    }

    /* Pasos */
    .verif-steps {
      list-style: none;
      margin: 0 0 4rem;
      padding: 0;
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    @media (min-width: 640px) {
      .verif-steps {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (min-width: 768px) {
      .verif-steps {
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
      }
    }

    .verif-step {
      background: var(--bg-card);
      padding: 2rem;
      border-radius: var(--radius-2xl);
      box-shadow: var(--shadow-card);
      border: 1px solid var(--border-light);
      text-align: center;
    }

    .verif-step-num {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 3rem;
      height: 3rem;
      margin: 0 auto 1rem;
      border-radius: 50%;
      color: var(--cream-50);
      font-weight: 700;
      font-size: 1.25rem;
      border: 4px solid var(--bg-card);
      box-shadow: var(--shadow-card);
    }

    .verif-step-num-1 { background: var(--stone-800); }
    .verif-step-num-2 { background: var(--orange-400); }
    .verif-step-num-3 { background: var(--green-500); }

    .verif-step-title {
      font-weight: 700;
      font-size: 1.125rem;
      color: var(--text-primary);
      margin-bottom: 0.5rem;
    }

    .verif-step-text {
      font-size: 0.875rem;
      color: var(--text-muted);
    }

    /* Card del formulario */
    .verif-card {
      background: var(--bg-card);
      border-radius: var(--radius-2xl);
      box-shadow: var(--shadow-card-hover);
      border: 1px solid var(--border-light);
      overflow: hidden;
    }

    .verif-card-head {
      background: var(--bg-inset);
      padding: 1.5rem;
      border-bottom: 1px solid var(--border-light);
    }

    .verif-card-title {
      font-weight: 700;
      font-size: 1.25rem;
      color: var(--text-primary);
    }

    .verif-card-sub {
      font-size: 0.875rem;
      color: var(--text-muted);
      margin-top: 0.25rem;
    }

    /* Alertas */
    .verif-alert {
      font-size: 0.875rem;
    }

    .verif-alert-error {
      background: var(--color-error-bg);
      border: 1px solid var(--color-error-border);
      color: var(--color-error-text);
      padding: 0.75rem 1.5rem;
    }

    .verif-alert-ok {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
      background: var(--color-success-light);
      border: 1px solid var(--color-success-border);
      color: var(--green-800);
      padding: 1rem 1.5rem;
    }

    .verif-alert-icon {
      font-size: 1.5rem;
      flex-shrink: 0;
    }

    .verif-alert-title {
      font-weight: 700;
    }

    .verif-alert-text {
      color: var(--green-700);
      margin-top: 0.25rem;
    }

    /* Form */
    .verif-form {
      padding: 2rem;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .verif-field {
      display: flex;
      flex-direction: column;
    }

    .verif-label {
      font-size: 0.875rem;
      font-weight: 700;
      color: var(--stone-700);
      margin-bottom: 0.5rem;
    }

    .verif-required {
      color: var(--color-error);
    }

    .verif-input {
      width: 100%;
      min-height: 44px;
      background: var(--stone-50);
      border: 1px solid var(--border-default);
      border-radius: var(--radius-xl);
      padding: 0.75rem 1rem;
      font-size: 1rem;
      color: var(--text-primary);
      transition: all 200ms ease;
    }

    .verif-input:focus-visible {
      outline: 2px solid transparent;
      border-color: var(--border-focus);
      box-shadow: 0 0 0 3px var(--amber-100);
    }

    .verif-hint {
      font-size: 0.75rem;
      color: var(--text-muted);
      margin-top: 0.375rem;
    }

    /* Info dentro del form */
    .verif-info {
      display: flex;
      gap: 0.5rem;
      background: var(--color-info-light);
      border: 1px solid var(--color-info-border);
      border-radius: var(--radius-xl);
      padding: 1rem;
      font-size: 0.875rem;
      color: var(--color-info-text);
    }

    .verif-info-icon {
      font-size: 1.25rem;
      flex-shrink: 0;
    }

    /* Submit */
    .verif-submit {
      width: 100%;
      min-height: 44px;
      background: linear-gradient(to right, var(--orange-500), var(--orange-600));
      color: var(--cream-50);
      font-weight: 700;
      padding: 0.875rem;
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow-btn);
      transition: all 200ms ease;
      cursor: pointer;
    }

    .verif-submit:hover {
      filter: brightness(0.95);
      box-shadow: var(--shadow-card-hover);
    }

    .verif-submit:focus-visible {
      outline: 2px solid var(--border-focus);
      outline-offset: 2px;
    }

    /* Footer full-bleed */
    .verif-footer {
      background: var(--stone-900);
      color: var(--cream-50);
      text-align: center;
      font-size: 0.75rem;
      padding: 2rem 1rem;
      margin-top: 3rem;
    }

    .verif-footer-inner {
      max-width: 56rem;
      margin: 0 auto;
    }

    .verif-footer p {
      color: var(--stone-500);
    }
  </style>
</BaseLayout>
