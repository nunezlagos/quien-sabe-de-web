---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getDb } from '../database/client';
import { users } from '../database/schema';
import { eq } from 'drizzle-orm';

const currentUser = Astro.locals.user;
if (!currentUser) {
	return Astro.redirect('/iniciar-sesion?redirigir=/cuenta');
}

const exportSolicitado = Astro.url.searchParams.get('export') === 'requested';

const db = getDb();
const consents = await db
	.select({
		emailProduct: users.consentEmailProduct,
		analytics: users.consentAnalytics,
		profilePublic: users.consentProfilePublic,
	})
	.from(users)
	.where(eq(users.id, currentUser.id))
	.get();

const emailProductOn = consents?.emailProduct !== false;
const analyticsOn = consents?.analytics !== false;
const profilePublicOn = consents?.profilePublic !== false;

const esPrestador = currentUser.role === 'provider';
---

<BaseLayout title="Mis datos personales — QuiénSabe">
	<main class="cuenta-main">
		<nav class="cuenta-breadcrumb">
			<a href="/dashboard" class="cuenta-breadcrumb-link">Mi cuenta</a>
			<i class="ri-arrow-right-s-line"></i>
			<span class="cuenta-breadcrumb-current">Datos personales</span>
		</nav>

		<div class="cuenta-page-header">
			<h1 class="cuenta-page-title">Mis Datos Personales</h1>
			<p class="cuenta-page-subtitle">
				Ejerce tus derechos según la Ley 19.628 desde un solo lugar.
			</p>
		</div>

		{exportSolicitado && (
			<div id="export-toast" class="cuenta-toast" role="status">
				<i class="ri-mail-send-line"></i>
				<div>
					<p class="cuenta-toast-title">Solicitud recibida.</p>
					<p class="cuenta-toast-body">
						Te enviaremos un ZIP con tus datos a <b>{currentUser.email}</b> en un máximo de 24 horas.
					</p>
				</div>
			</div>
		)}

		<div class="cuenta-cards">
			<!-- Card 1: Descargar datos -->
			<section class="cuenta-card">
				<form method="POST" action="/api/v1/users/me/data-export" class="cuenta-card-form">
					<div class="cuenta-card-icon cuenta-card-icon-blue">
						<i class="ri-download-cloud-2-line" aria-hidden="true"></i>
					</div>
					<div class="cuenta-card-content">
						<h2 class="cuenta-card-title">Descargar mis datos</h2>
						<p class="cuenta-card-desc">
							Recibirás un archivo ZIP con todos tus datos: perfil, mensajes, reseñas y configuraciones.
							Te llegará al correo en un máximo de 24 horas.
						</p>
					</div>
					<button type="submit" class="cuenta-btn cuenta-btn-primary">
						Solicitar descarga
					</button>
				</form>
			</section>

			<!-- Card 2: Consentimientos -->
			<section class="cuenta-card">
				<div class="cuenta-card-header">
					<div class="cuenta-card-icon cuenta-card-icon-orange">
						<i class="ri-toggle-line" aria-hidden="true"></i>
					</div>
					<div>
						<h2 class="cuenta-card-title">Consentimientos</h2>
						<p class="cuenta-card-desc">Decide qué autorizas y qué no. Puedes cambiar esto cuando quieras.</p>
					</div>
				</div>

				<div class="cuenta-consents">
					<label class="cuenta-consent-item">
						<div class="cuenta-consent-info">
							<i class="ri-mail-send-line" aria-hidden="true"></i>
							<div>
								<h4 class="cuenta-consent-title">Recibir emails de comunicaciones del producto</h4>
								<p class="cuenta-consent-desc">Novedades, mejoras y avisos importantes.</p>
							</div>
						</div>
						<div class="cuenta-toggle">
							<input
								type="checkbox"
								class="sr-only peer js-consent-toggle"
								data-consent-key="consent_email_product"
								checked={emailProductOn}
							/>
							<div class="toggle-track"></div>
						</div>
					</label>

					<label class="cuenta-consent-item">
						<div class="cuenta-consent-info">
							<i class="ri-bar-chart-2-line" aria-hidden="true"></i>
							<div>
								<h4 class="cuenta-consent-title">Analytics y métricas anónimas</h4>
								<p class="cuenta-consent-desc">Ayuda a mejorar la plataforma sin identificarte.</p>
							</div>
						</div>
						<div class="cuenta-toggle">
							<input
								type="checkbox"
								class="sr-only peer js-consent-toggle"
								data-consent-key="consent_analytics"
								checked={analyticsOn}
							/>
							<div class="toggle-track"></div>
						</div>
					</label>

					<label class={`cuenta-consent-item ${esPrestador ? '' : 'cuenta-consent-disabled'}`}>
						<div class="cuenta-consent-info">
							<i class="ri-eye-line" aria-hidden="true"></i>
							<div>
								<h4 class="cuenta-consent-title">
									Perfil público visible en el buscador
									{esPrestador ? (
										<span class="cuenta-badge cuenta-badge-orange">Solo prestador</span>
									) : (
										<span class="cuenta-badge">Solo prestador</span>
									)}
								</h4>
								<p class="cuenta-consent-desc">
									{esPrestador
										? 'Si lo desactivas, tu perfil deja de aparecer en búsquedas.'
										: 'Tu rol actual no tiene perfil público. Se activará si te conviertes en prestador.'}
								</p>
							</div>
						</div>
						<div class="cuenta-toggle">
							<input
								type="checkbox"
								class="sr-only peer js-consent-toggle"
								data-consent-key="consent_profile_public"
								checked={profilePublicOn}
								disabled={!esPrestador}
							/>
							<div class="toggle-track"></div>
						</div>
					</label>
				</div>
			</section>

			<!-- Card 3: Eliminar cuenta -->
			<section class="cuenta-card cuenta-card-danger">
				<div class="cuenta-card-form">
					<div class="cuenta-card-icon cuenta-card-icon-red">
						<i class="ri-delete-bin-line" aria-hidden="true"></i>
					</div>
					<div class="cuenta-card-content">
						<h2 class="cuenta-card-title">Eliminar mi cuenta</h2>
						<p class="cuenta-card-desc">
							Acción irreversible. Tus reseñas se anonimizan y tus datos se eliminan en 30 días,
							según los plazos legales de retención.
						</p>
					</div>
					<button
						type="button"
						id="open-delete-btn"
						class="cuenta-btn cuenta-btn-danger"
					>
						Eliminar mi cuenta
					</button>
				</div>
			</section>
		</div>
	</main>

	<!-- Modal de confirmación de eliminación -->
	<div
		id="delete-modal"
		class="modal-overlay"
		role="dialog"
		aria-modal="true"
		aria-labelledby="delete-modal-title"
	>
		<div id="delete-modal-content" class="modal-content">
			<div class="modal-header">
				<h3 id="delete-modal-title" class="modal-title">
					<i class="ri-alert-line" aria-hidden="true"></i> Confirmar eliminación
				</h3>
				<button
					id="close-delete-btn"
					type="button"
					class="modal-close"
					aria-label="Cerrar"
				>
					<i class="ri-close-line" aria-hidden="true"></i>
				</button>
			</div>

			<form id="form-eliminar" class="modal-form">
				<div class="modal-warning">
					<p class="modal-warning-text">
						<i class="ri-information-line" aria-hidden="true"></i>
						Esta acción es irreversible. Perderás acceso a tu perfil, mensajes y servicios publicados.
					</p>
				</div>

				<div class="modal-field">
					<label for="delete-confirm-input" class="modal-label">
						Para confirmar, escribe <span class="modal-label-danger">ELIMINAR</span>
					</label>
					<input
						id="delete-confirm-input"
						name="confirm"
						type="text"
						placeholder="ELIMINAR"
						autocomplete="off"
						class="modal-input"
					/>
				</div>

				<div class="modal-actions">
					<button
						type="button"
						id="cancel-delete-btn"
						class="modal-btn modal-btn-cancel"
					>
						Cancelar
					</button>
					<button
						type="submit"
						id="confirm-delete-btn"
						disabled
						class="modal-btn modal-btn-danger modal-btn-disabled"
					>
						Eliminar definitivamente
					</button>
				</div>
			</form>
		</div>
	</div>

	<style>
		.cuenta-main {
			max-width: 52rem;
			margin: 0 auto;
			padding: 2rem 1rem;
		}

		.cuenta-breadcrumb {
			display: flex;
			align-items: center;
			gap: 0.25rem;
			font-size: 0.875rem;
			font-weight: 500;
			color: var(--text-muted);
			margin-bottom: 1.5rem;
		}

		.cuenta-breadcrumb-link {
			color: var(--amber-600);
			text-decoration: none;
		}

		.cuenta-breadcrumb-link:hover {
			text-decoration: underline;
		}

		.cuenta-breadcrumb-current {
			color: var(--text-primary);
			font-weight: 700;
		}

		.cuenta-page-header {
			margin-bottom: 2rem;
		}

		.cuenta-page-title {
			font-size: 1.5rem;
			font-weight: 800;
			color: var(--text-primary);
			margin-bottom: 0.25rem;
		}

		.cuenta-page-subtitle {
			color: var(--text-secondary);
			font-size: 0.875rem;
			font-weight: 500;
		}

		.cuenta-toast {
			background: var(--blue-50);
			border: 1px solid var(--blue-200);
			color: var(--blue-700);
			border-radius: var(--radius-2xl);
			padding: 1rem;
			margin-bottom: 1.5rem;
			display: flex;
			align-items: flex-start;
			gap: 0.75rem;
		}

		.cuenta-toast i {
			font-size: 1.25rem;
			margin-top: 0.125rem;
			flex-shrink: 0;
		}

		.cuenta-toast-title {
			font-weight: 700;
			font-size: 0.875rem;
		}

		.cuenta-toast-body {
			font-size: 0.75rem;
			font-weight: 500;
			margin-top: 0.25rem;
		}

		.cuenta-cards {
			display: flex;
			flex-direction: column;
			gap: 1.5rem;
		}

		.cuenta-card {
			background: white;
			border-radius: var(--radius-xl);
			box-shadow: var(--shadow-card);
			border: 1px solid var(--border-default);
			padding: 1.5rem;
		}

		.cuenta-card-danger {
			border: 2px solid #fecaca;
		}

		.cuenta-card-form {
			display: flex;
			flex-direction: column;
			gap: 1rem;
			align-items: flex-start;
		}

		@media (min-width: 768px) {
			.cuenta-card-form {
				flex-direction: row;
				align-items: center;
			}
		}

		.cuenta-card-header {
			display: flex;
			align-items: flex-start;
			gap: 1rem;
			margin-bottom: 1.5rem;
		}

		.cuenta-card-icon {
			width: 3.5rem;
			height: 3.5rem;
			border-radius: var(--radius-xl);
			display: flex;
			align-items: center;
			justify-content: center;
			font-size: 1.5rem;
			flex-shrink: 0;
		}

		.cuenta-card-icon-blue {
			background: var(--blue-50);
			color: var(--blue-500);
		}

		.cuenta-card-icon-orange {
			background: var(--orange-50);
			color: var(--orange-500);
		}

		.cuenta-card-icon-red {
			background: #fef2f2;
			color: #dc2626;
		}

		.cuenta-card-content {
			flex-grow: 1;
		}

		.cuenta-card-title {
			font-size: 1.125rem;
			font-weight: 700;
			color: var(--text-primary);
			margin-bottom: 0.25rem;
		}

		.cuenta-card-desc {
			font-size: 0.875rem;
			color: var(--text-secondary);
			font-weight: 500;
			line-height: 1.6;
		}

		.cuenta-btn {
			padding: 0.75rem 1.5rem;
			border-radius: var(--radius-xl);
			font-weight: 700;
			font-size: 0.875rem;
			transition: all 200ms ease;
			border: none;
			cursor: pointer;
			white-space: nowrap;
			width: 100%;
		}

		@media (min-width: 768px) {
			.cuenta-btn {
				width: auto;
			}
		}

		.cuenta-btn-primary {
			background: var(--orange-500);
			color: white;
			box-shadow: var(--shadow-btn);
		}

		.cuenta-btn-primary:hover {
			background: var(--orange-600);
		}

		.cuenta-btn-danger {
			background: #dc2626;
			color: white;
			box-shadow: 0 2px 4px rgba(220, 38, 38, 0.3);
		}

		.cuenta-btn-danger:hover {
			background: #b91c1c;
		}

		/* Consent items */
		.cuenta-consents {
			display: flex;
			flex-direction: column;
			gap: 0.75rem;
		}

		.cuenta-consent-item {
			display: flex;
			align-items: center;
			justify-content: space-between;
			padding: 1rem;
			background: var(--stone-50);
			border-radius: var(--radius-xl);
			border: 1px solid var(--border-light);
			cursor: pointer;
			transition: all 200ms ease;
			gap: 1rem;
		}

		.cuenta-consent-item:hover {
			background: white;
			box-shadow: var(--shadow-card);
		}

		.cuenta-consent-disabled {
			opacity: 0.6;
			cursor: default;
		}

		.cuenta-consent-disabled:hover {
			background: var(--stone-50);
			box-shadow: none;
		}

		.cuenta-consent-info {
			display: flex;
			align-items: center;
			gap: 0.75rem;
			flex-grow: 1;
		}

		.cuenta-consent-info > i {
			font-size: 1.25rem;
			color: var(--orange-500);
			flex-shrink: 0;
		}

		.cuenta-consent-title {
			font-size: 0.875rem;
			font-weight: 700;
			color: var(--text-primary);
			display: flex;
			align-items: center;
			gap: 0.375rem;
			flex-wrap: wrap;
		}

		.cuenta-consent-desc {
			font-size: 0.75rem;
			color: var(--text-muted);
			font-weight: 500;
			margin-top: 0.125rem;
		}

		.cuenta-badge {
			font-size: 0.625rem;
			padding: 0.125rem 0.5rem;
			border-radius: var(--radius-full);
			font-weight: 700;
			background: var(--stone-200);
			color: var(--stone-600);
		}

		.cuenta-badge-orange {
			background: var(--orange-100);
			color: var(--orange-700);
		}

		/* Toggle switch */
		.cuenta-toggle {
			position: relative;
			flex-shrink: 0;
		}

		.toggle-track {
			width: 2.75rem;
			height: 1.5rem;
			background: var(--stone-200);
			border-radius: var(--radius-full);
			transition: all 200ms ease;
			cursor: pointer;
			position: relative;
		}

		.toggle-track::after {
			content: '';
			position: absolute;
			top: 0.125rem;
			left: 0.125rem;
			width: 1.25rem;
			height: 1.25rem;
			background: white;
			border-radius: 50%;
			transition: all 200ms ease;
			box-shadow: 0 1px 2px rgba(0,0,0,0.2);
		}

		.cuenta-consent-item:hover .toggle-track {
			background: var(--stone-300);
		}

		/* When checkbox is checked, toggle turns orange */
		.cuenta-consent-item:has(.js-consent-toggle:checked) .toggle-track {
			background: var(--orange-500);
		}

		.cuenta-consent-item:has(.js-consent-toggle:checked) .toggle-track::after {
			transform: translateX(1.25rem);
		}

		.cuenta-consent-item:has(.js-consent-toggle:checked):hover .toggle-track {
			background: var(--orange-600);
		}

		/* Modal */
		.modal-overlay {
			position: fixed;
			inset: 0;
			background: rgba(0, 0, 0, 0.5);
			z-index: 200;
			display: none;
			align-items: center;
			justify-content: center;
			backdrop-filter: blur(4px);
			padding: 1rem;
		}

		.modal-overlay.is-open {
			display: flex;
		}

		.modal-content {
			background: white;
			border-radius: var(--radius-2xl);
			box-shadow: 0 25px 50px rgba(0,0,0,0.25);
			width: 100%;
			max-width: 28rem;
			transform: scale(0.95);
			transition: transform 300ms ease;
		}

		.modal-overlay.is-open .modal-content {
			transform: scale(1);
		}

		.modal-header {
			padding: 1.5rem;
			border-bottom: 1px solid var(--border-light);
			display: flex;
			justify-content: space-between;
			align-items: center;
			background: #fef2f2;
			border-radius: var(--radius-2xl) var(--radius-2xl) 0 0;
		}

		.modal-title {
			font-size: 1.125rem;
			font-weight: 700;
			color: var(--text-primary);
			display: flex;
			align-items: center;
			gap: 0.5rem;
		}

		.modal-title i {
			color: #dc2626;
		}

		.modal-close {
			background: none;
			border: none;
			color: var(--stone-400);
			cursor: pointer;
			font-size: 1.5rem;
			transition: color 200ms ease;
		}

		.modal-close:hover {
			color: var(--stone-600);
		}

		.modal-form {
			padding: 1.5rem;
			display: flex;
			flex-direction: column;
			gap: 1rem;
		}

		.modal-warning {
			background: var(--amber-50);
			border: 1px solid var(--amber-200);
			padding: 1rem;
			border-radius: var(--radius-xl);
		}

		.modal-warning-text {
			font-size: 0.875rem;
			color: var(--amber-700);
			font-weight: 500;
			line-height: 1.6;
			display: flex;
			gap: 0.5rem;
		}

		.modal-warning-text i {
			flex-shrink: 0;
		}

		.modal-field {
			display: flex;
			flex-direction: column;
			gap: 0.25rem;
		}

		.modal-label {
			font-size: 0.6875rem;
			font-weight: 700;
			color: var(--stone-700);
		}

		.modal-label-danger {
			color: #dc2626;
			font-weight: 800;
		}

		.modal-input {
			width: 100%;
			background: var(--stone-50);
			border: 1px solid var(--border-default);
			border-radius: var(--radius-xl);
			padding: 0.75rem 1rem;
			font-size: 0.875rem;
			transition: all 200ms ease;
		}

		.modal-input:focus {
			outline: none;
			border-color: #dc2626;
			box-shadow: 0 0 0 3px rgba(220, 38, 38, 0.1);
		}

		.modal-actions {
			display: flex;
			gap: 0.5rem;
			padding-top: 0.5rem;
		}

		.modal-btn {
			flex: 1;
			padding: 0.75rem;
			border-radius: var(--radius-xl);
			font-weight: 700;
			font-size: 0.875rem;
			transition: all 200ms ease;
			cursor: pointer;
			border: none;
		}

		.modal-btn-cancel {
			background: white;
			color: var(--stone-600);
			border: 1px solid var(--border-default);
		}

		.modal-btn-cancel:hover {
			border-color: var(--amber-400);
			color: var(--amber-600);
		}

		.modal-btn-danger {
			background: #dc2626;
			color: white;
			box-shadow: 0 2px 4px rgba(220, 38, 38, 0.3);
		}

		.modal-btn-danger:hover {
			background: #b91c1c;
		}

		.modal-btn-disabled {
			opacity: 0.5;
			cursor: not-allowed;
		}
	</style>

	<script>
		import { inicializarAccionesCuenta } from '../lib/client/auth/account-actions';
		inicializarAccionesCuenta();
	</script>
</BaseLayout>
