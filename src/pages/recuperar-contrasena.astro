---
import BaseLayout from '../layouts/BaseLayout.astro';

const url = Astro.url;
const enviado = url.searchParams.get('sent') === '1';
---

<BaseLayout title="Recuperar contraseña — QuiénSabe">
  <main class="auth-page">
    <a href="/iniciar-sesion" class="auth-page__back">← Volver a iniciar sesión</a>

    {enviado ? (
      <article class="auth-card">
        <header class="auth-card__header">
          <div class="auth-card__icon auth-card__icon--success auth-card__icon--compact">
            <i class="ri-mail-check-line" aria-hidden="true"></i>
          </div>
          <h1 class="auth-card__title">Revisa tu correo</h1>
          <p class="auth-card__subtitle">
            Si el correo está registrado, te enviamos un enlace para crear una nueva contraseña.
          </p>
        </header>

        <p class="auth-card__alt">
          ¿No lo encuentras? Revisa la carpeta de spam.
        </p>

        <p class="auth-card__note">
          <a href="/iniciar-sesion">Volver a iniciar sesión</a>
        </p>
      </article>
    ) : (
      <article class="auth-card">
        <header class="auth-card__header">
          <div class="auth-card__icon">
            <i class="ri-lock-unlock-line" aria-hidden="true"></i>
          </div>
          <h1 class="auth-card__title">¿Olvidaste tu contraseña?</h1>
          <p class="auth-card__subtitle">
            Ingresa tu correo y te enviaremos un enlace para crear una nueva.
          </p>
        </header>

        <form id="form-recuperar" class="auth-form" novalidate>
          <div class="auth-form__field">
            <label class="auth-form__label" for="correo">Correo electrónico</label>
            <input
              id="correo"
              name="correo"
              type="email"
              required
              maxlength="255"
              autocomplete="email"
              class="auth-form__input"
              placeholder="tu@email.com"
            />
          </div>

          <div
            id="errores-campos"
            class="auth-card__alert auth-card__alert--error auth-card__alert--hidden"
            role="alert"
          ></div>

          <button type="submit" class="btn btn--primary btn--block">
            Enviar enlace de recuperación
          </button>
        </form>

        <p class="auth-card__alt">
          ¿Recordaste tu contraseña? <a href="/iniciar-sesion">Inicia sesión</a>
        </p>
      </article>
    )}
  </main>
</BaseLayout>

<script>
  import { initForgotPasswordForm } from '../lib/client/auth/forgot-password';
  initForgotPasswordForm();
</script>