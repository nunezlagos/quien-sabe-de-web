---
import BaseLayout from '../layouts/BaseLayout.astro';

// Mapeo explícito de tokens por categoría (evita interpolación dinámica de var()).
const categoryColors: Record<string, { bg: string; icon: string }> = {
  amber: { bg: 'var(--amber-100)', icon: 'var(--amber-600)' },
  blue: { bg: 'var(--blue-100)', icon: 'var(--blue-600)' },
  orange: { bg: 'var(--orange-100)', icon: 'var(--orange-600)' },
  pink: { bg: 'var(--pink-100)', icon: 'var(--pink-600)' },
};

const categorias = [
  {
    id: 'general',
    titulo: 'General',
    icono: 'ri-information-line',
    colorFondo: 'amber',
    preguntas: [
      {
        q: '¿Qué es QuiénSabe?',
        a: 'QuiénSabe es una plataforma comunitaria chilena que conecta vecinos con oficios de barrio. Buscamos gasfíter, electricistas, jardineros y más, todos verificados y reseñados por la comunidad.',
      },
      {
        q: '¿Tiene costo usar QuiénSabe?',
        a: 'Para los vecinos que buscan un oficio, el uso es <b>totalmente gratuito</b>. Los prestadores tampoco pagan comisiones por contactarles. Nos sostenemos con donaciones voluntarias de la comunidad.',
      },
      {
        q: '¿Está disponible solo en la Región Metropolitana?',
        a: 'Sí, en esta primera versión cubrimos las 52 comunas de la Región Metropolitana. Próximamente esperamos expandirnos a otras regiones.',
      },
      {
        q: '¿Cómo contacto a soporte?',
        a: 'Escríbenos a <a href="mailto:soporte@quiensabe.cl">soporte@quiensabe.cl</a> o usa el formulario de "Reportar" en el perfil de cualquier prestador.',
      },
    ],
  },
  {
    id: 'vecinos',
    titulo: 'Para vecinos',
    icono: 'ri-user-search-line',
    colorFondo: 'blue',
    preguntas: [
      {
        q: '¿Cómo busco un oficio?',
        a: 'En la página principal, escribe el oficio que necesitas (ej: "gasfiter"), tu comuna y presiona buscar. Puedes filtrar por rating, precio y disponibilidad inmediata.',
      },
      {
        q: '¿Cómo contacto a un prestador?',
        a: 'Desde el perfil del prestador, haz click en el botón de WhatsApp o email. Se abrirá directamente tu app con un mensaje pre-armado.',
      },
      {
        q: '¿Cómo califico después del trabajo?',
        a: 'Después de contactar a un prestador, te aparecerá una invitación para dejar una reseña (1 a 5 estrellas + comentario). Puedes editarla hasta 7 días después.',
      },
      {
        q: '¿Puedo guardar prestadores como favoritos?',
        a: 'Sí. En cada tarjeta o perfil, haz click en el ícono de corazón (<i class="ri-heart-line"></i>). Los verás en tu panel como "Vecinos guardados".',
      },
    ],
  },
  {
    id: 'prestadores',
    titulo: 'Para prestadores',
    icono: 'ri-tools-line',
    colorFondo: 'orange',
    preguntas: [
      {
        q: '¿Cómo me registro como prestador?',
        a: 'Primero regístrate como vecino, luego desde tu panel haz click en "Crear Perfil PRO". Completa el wizard con tu oficio, comunas que cubres y datos de contacto.',
      },
      {
        q: '¿Qué es la verificación?',
        a: 'Es un proceso donde subes tu RUT y opcionalmente certificaciones o fotos de trabajos. Un administrador revisa y te da el badge "Verificado" en tu perfil. No es obligatorio publicar, pero aumenta la confianza.',
      },
      {
        q: '¿QuiénSabe me cobra comisión?',
        a: '<b>No.</b> No cobramos comisión por contacto, por mensaje o por trabajo concretado. El contacto entre tú y el vecino es directo. La plataforma se sostiene con donaciones.',
      },
      {
        q: '¿Puedo pausar mi disponibilidad?',
        a: 'Sí. En el sidebar de tu panel hay un toggle "Estado". Si lo apagas, tu perfil sigue visible pero aparece como "En pausa" y no aparece en búsquedas con filtro "Disponible ahora".',
      },
    ],
  },
  {
    id: 'donaciones',
    titulo: 'Donaciones y transparencia',
    icono: 'ri-heart-3-line',
    colorFondo: 'pink',
    preguntas: [
      {
        q: '¿Para qué se usan las donaciones?',
        a: 'Cubrimos costos de infraestructura (hosting, base de datos, emails) y un pequeño fondo para mantención. Publicamos cada gasto en <a href="/transparency">/transparency</a>.',
      },
      {
        q: '¿Puedo donar de forma anónima?',
        a: 'Sí. Al donar puedes elegir si quieres aparecer públicamente en la lista de donors o mantenerte anónimo.',
      },
      {
        q: '¿Aceptan pagos recurrentes?',
        a: 'Sí, puedes configurar una donación mensual desde la página de donaciones. Puedes cancelar en cualquier momento.',
      },
    ],
  },
];
---

<BaseLayout title="Preguntas frecuentes - QuiénSabe">

  <header class="faq-header">
    <div class="container mx-auto px-4 text-center relative z-10">
      <div class="faq-header-badge">
        <i class="ri-question-line" aria-hidden="true"></i> Centro de ayuda
      </div>
      <h1 class="faq-header-title">
        Preguntas frecuentes
      </h1>
      <p class="faq-header-subtitle">
        Encuentra respuestas rápidas. Si no, escríbenos.
      </p>

      <div class="max-w-xl mx-auto relative">
        <label for="faq-search" class="sr-only">Buscar una pregunta frecuente</label>
        <i class="ri-search-line faq-search-icon" aria-hidden="true"></i>
        <input
          id="faq-search"
          type="search"
          placeholder="Busca una pregunta..."
          class="faq-search-input"
        />
      </div>
    </div>
  </header>

  <main class="faq-main">

    {categorias.map((cat) => {
      const colores = categoryColors[cat.colorFondo] ?? categoryColors.amber;
      return (
      <section class="faq-category" data-category={cat.id}>
        <h2 class="faq-category-title">
          <span class="faq-category-icon" style={`background: ${colores.bg}; color: ${colores.icon}`}>
            <i class={cat.icono} aria-hidden="true"></i>
          </span>
          {cat.titulo}
        </h2>
        <div class="faq-list">
          {cat.preguntas.map((p, idx) => (
            <details class="faq-item" data-faq={`${cat.id}-${idx + 1}`}>
              <summary class="faq-question">
                <span>{p.q}</span>
                <i class="ri-arrow-down-s-line faq-arrow" aria-hidden="true"></i>
              </summary>
              <div class="faq-answer" set:html={p.a} />
            </details>
          ))}
        </div>
      </section>
      );
    })}

    <div id="faq-no-matches" class="faq-no-matches hidden">
      <i class="ri-search-eye-line" aria-hidden="true"></i>
      <p class="faq-no-matches-text">No encontramos preguntas para tu búsqueda.</p>
      <p class="faq-no-matches-sub">
        Intenta con otra palabra o escríbenos a <a href="mailto:soporte@quiensabe.cl">soporte@quiensabe.cl</a>.
      </p>
    </div>

    <div class="faq-contact-banner">
      <h3 class="faq-contact-title">¿No encontraste tu respuesta?</h3>
      <p class="faq-contact-subtitle">Escríbenos y te respondemos en menos de 24h.</p>
      <a href="mailto:soporte@quiensabe.cl" class="faq-contact-btn">
        <i class="ri-mail-send-line" aria-hidden="true"></i> Contactar soporte
      </a>
    </div>

  </main>

  <style>
    .faq-header {
      background: linear-gradient(135deg, var(--amber-50) 0%, var(--cream-200) 100%);
      padding: 3rem 0;
      position: relative;
      overflow: hidden;
    }

    .faq-header-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: white;
      border: 1px solid var(--border-default);
      padding: 0.375rem 1rem;
      border-radius: var(--radius-full);
      font-size: 0.75rem;
      font-weight: 700;
      color: var(--text-secondary);
      margin-bottom: 1rem;
    }

    .faq-header-badge i {
      color: var(--amber-600);
    }

    .faq-header-title {
      font-size: 1.875rem;
      font-weight: 800;
      color: var(--text-primary);
      margin-bottom: 0.75rem;
      letter-spacing: -0.02em;
    }

    .faq-header-subtitle {
      color: var(--text-secondary);
      margin-bottom: 1.5rem;
      max-width: 36rem;
      margin-left: auto;
      margin-right: auto;
    }

    .faq-search-icon {
      position: absolute;
      left: 1rem;
      top: 50%;
      transform: translateY(-50%);
      color: var(--text-muted);
      font-size: 1.25rem;
    }

    .faq-search-input {
      width: 100%;
      padding: 0.875rem 1rem 0.875rem 3rem;
      border-radius: var(--radius-xl);
      border: 2px solid var(--border-default);
      font-size: 1rem;
      background: white;
      transition: all 200ms ease;
      box-shadow: var(--shadow-card);
    }

    .faq-search-input:focus-visible {
      outline: none;
      border-color: var(--border-focus);
      box-shadow: 0 0 0 3px var(--amber-100);
    }

    .faq-question:focus-visible {
      outline: none;
      box-shadow: 0 0 0 3px var(--amber-100);
      border-radius: var(--radius-xl);
    }

    .faq-main {
      max-width: 48rem;
      margin: 0 auto;
      padding: 3rem 1rem;
    }

    .faq-category {
      margin-bottom: 2.5rem;
    }

    .faq-category-title {
      font-size: 1.25rem;
      font-weight: 800;
      color: var(--text-primary);
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .faq-category-icon {
      width: 2.25rem;
      height: 2.25rem;
      border-radius: var(--radius-lg);
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .faq-list {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .faq-item {
      background: white;
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow-card);
      border: 1px solid var(--border-light);
      overflow: hidden;
      transition: box-shadow 200ms ease;
    }

    .faq-item:hover {
      box-shadow: var(--shadow-card-hover);
    }

    .faq-question {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.25rem;
      font-weight: 700;
      color: var(--text-primary);
      cursor: pointer;
      list-style: none;
    }

    .faq-question::-webkit-details-marker {
      display: none;
    }

    .faq-arrow {
      font-size: 1.5rem;
      color: var(--text-muted);
      transition: transform 200ms ease;
      flex-shrink: 0;
    }

    .faq-item[open] .faq-arrow {
      transform: rotate(180deg);
    }

    .faq-answer {
      padding: 0 1.25rem 1.25rem;
      color: var(--text-secondary);
      font-size: 0.875rem;
      line-height: 1.7;
    }

    .faq-answer a {
      color: var(--amber-600);
      font-weight: 700;
    }

    .faq-no-matches {
      text-align: center;
      padding: 3rem;
      background: white;
      border-radius: var(--radius-xl);
      border: 1px solid var(--border-light);
    }

    .faq-no-matches i {
      font-size: 3rem;
      color: var(--stone-300);
    }

    .faq-no-matches-text {
      color: var(--text-muted);
      font-weight: 500;
      margin-top: 0.75rem;
    }

    .faq-no-matches-sub {
      font-size: 0.875rem;
      color: var(--text-muted);
      margin-top: 0.25rem;
    }

    .faq-no-matches-sub a {
      color: var(--amber-600);
      font-weight: 700;
    }

    .faq-contact-banner {
      margin-top: 3rem;
      text-align: center;
      background: linear-gradient(135deg, var(--amber-50) 0%, var(--cream-200) 100%);
      border-radius: var(--radius-2xl);
      padding: 2rem;
      border: 1px solid var(--amber-200);
    }

    .faq-contact-title {
      font-size: 1.125rem;
      font-weight: 800;
      color: var(--text-primary);
      margin-bottom: 0.5rem;
    }

    .faq-contact-subtitle {
      font-size: 0.875rem;
      color: var(--text-secondary);
      margin-bottom: 1rem;
    }

    .faq-contact-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--color-accent);
      color: var(--text-inverse);
      padding: 0.75rem 1.5rem;
      min-height: 44px;
      border-radius: var(--radius-full);
      font-weight: 700;
      font-size: 0.875rem;
      transition: all 200ms ease;
      box-shadow: var(--shadow-btn);
    }

    .faq-contact-btn:hover {
      background: var(--color-accent-dark);
      transform: translateY(-1px);
      box-shadow: var(--shadow-card-hover);
    }

    .faq-contact-btn:focus-visible {
      outline: none;
      box-shadow: 0 0 0 3px var(--amber-200);
    }
  </style>

  <script>
    import { inicializarBusquedaFaq } from '../lib/client/faq/search';
    inicializarBusquedaFaq();
  </script>

</BaseLayout>
