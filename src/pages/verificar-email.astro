---
import BaseLayout from '../layouts/BaseLayout.astro';

const estadosValidos = ['verifying', 'success', 'expired'] as const;
type Estado = (typeof estadosValidos)[number];

const estadoParam = Astro.url.searchParams.get('status');
const estado: Estado = (estadosValidos as readonly string[]).includes(estadoParam ?? '')
  ? (estadoParam as Estado)
  : 'verifying';
---

<BaseLayout title="Verificación de correo — QuiénSabe">
  <main class="auth-page">
    <a href="/" class="auth-page__back">← Volver al inicio</a>

    <article class="auth-card">
      {estado === 'verifying' && (
        <div class="verify-email__state">
          <div class="verify-email__spinner" role="status" aria-label="Verificando tu correo"></div>
          <h1 class="verify-email__title">Verificando tu correo...</h1>
          <p class="verify-email__message">Espera un momento mientras confirmamos tu cuenta.</p>
        </div>
      )}

      {estado === 'success' && (
        <div class="verify-email__state">
          <div class="verify-email__icon-circle verify-email__icon-circle--success">
            <i class="ri-checkbox-circle-fill" aria-hidden="true"></i>
          </div>
          <h1 class="verify-email__title">¡Correo verificado!</h1>
          <p class="verify-email__message">Ya puedes acceder a todas las funciones de Quién Sabe.</p>
          <a href="/dashboard" class="btn btn--primary btn--block">Ir a mi dashboard</a>
        </div>
      )}

      {estado === 'expired' && (
        <div class="verify-email__state">
          <div class="verify-email__icon-circle verify-email__icon-circle--expired">
            <i class="ri-time-line" aria-hidden="true"></i>
          </div>
          <h1 class="verify-email__title">El enlace expiró</h1>
          <p class="verify-email__message">Los enlaces de verificación caducan a las 24 horas. Pídenos uno nuevo.</p>
          <form method="POST" action="/api/v1/auth/verify-email/resend">
            <button type="submit" class="btn btn--primary btn--block">Reenviar correo</button>
          </form>
          <p class="verify-email__contact">
            Si el problema persiste, <a href="/contacto">contáctanos</a>.
          </p>
        </div>
      )}
    </article>
  </main>
</BaseLayout>