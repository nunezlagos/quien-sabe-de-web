---
const { title = "QuiénSabe - Conecta con oficios de tu barrio", description, image } = Astro.props;
import '../styles/base.css';
import RoleSwitcher from '../components/navbar/RoleSwitcher.astro';

const currentUser = Astro.locals.user;
const isLoggedIn = Boolean(currentUser);
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content="Encuentra gasfíteres, electricistas y más oficios en tu comunidad.">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.min.js" is:inline></script>
    <meta property="og:title" content={title} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="QuiénSabe" />
    {description ? <meta property="og:description" content={description} /> : null}
    {image ? <meta property="og:image" content={image} /> : null}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description ? <meta name="twitter:description" content={description} /> : null}
    {image ? <meta name="twitter:image" content={image} /> : null}
</head>
<body class="page-body">

    <!-- Navigation -->
    <nav class="navbar">
        <div class="nav-container">
            <a href="/" class="nav-brand">
                <div class="nav-logo">
                    <i class="ri-community-fill"></i>
                </div>
                <span class="nav-brand-text">
                    Quién<span class="brand-accent">Sabe</span>
                </span>
            </a>

            <div class="nav-actions">
                {isLoggedIn && currentUser ? (
                    <>
                        <RoleSwitcher
                            userRoles={currentUser.roles || [currentUser.role]}
                            currentRole={currentUser.activeRole || currentUser.role}
                            currentPath={currentPath}
                        />
                        <a href={currentUser.role === 'provider' ? '/dashboard-prestador' : '/dashboard'} class="nav-btn nav-btn-user">
                            <i class="ri-user-line"></i>
                            <span class="nav-user-name">{currentUser.name.split(' ')[0]}</span>
                        </a>
                        <form method="POST" action="/api/v1/auth/cerrar-sesion" class="nav-logout-form js-logout-form" id="form-cerrar-sesion">
                            <button type="submit" class="nav-btn nav-btn-logout">
                                <i class="ri-logout-box-r-line"></i>
                            </button>
                        </form>
                    </>
                ) : (
                    <>
                        <a href="/donar" class="nav-btn nav-btn-donate">
                            <i class="ri-heart-3-fill"></i>
                            <span>Donar</span>
                        </a>
                        <a href="/iniciar-sesion" class="nav-btn nav-btn-outline">
                            Ingresar
                        </a>
                        <a href="/registro" class="nav-btn nav-btn-primary">
                            Crear cuenta
                        </a>
                    </>
                )}
            </div>

            <button class="nav-mobile-toggle" aria-label="Menú">
                <i class="ri-menu-line"></i>
            </button>
        </div>
    </nav>

    <slot />

    <!-- Footer -->
    <footer class="footer">
        <div class="footer-glow"></div>
        <div class="footer-container">
            <div class="footer-brand">
                <div class="footer-logo">
                    <i class="ri-community-fill"></i>
                    <span>QuiénSabe</span>
                </div>
                <p class="footer-tagline">Conectando barrios, un oficio a la vez. Construido con cariño para la comunidad.</p>
                <div class="footer-social">
                    <a href="/donar" class="footer-social-link" title="Donar">
                        <i class="ri-heart-3-fill"></i>
                    </a>
                    <a href="https://github.com/nunezlagos/quien-sabe-de-web" class="footer-social-link" title="GitHub" target="_blank">
                        <i class="ri-github-fill"></i>
                    </a>
                </div>
            </div>

            <div class="footer-links">
                <div class="footer-column">
                    <h4 class="footer-heading">Explorar</h4>
                    <a href="/" class="footer-link">Buscar oficios</a>
                    <a href="/donar" class="footer-link">Donaciones</a>
                    <a href="/registro" class="footer-link">Crear cuenta</a>
                </div>
                <div class="footer-column">
                    <h4 class="footer-heading">Legal</h4>
                    <a href="/terminos" class="footer-link">Términos</a>
                    <a href="/privacidad" class="footer-link">Privacidad</a>
                    <a href="/transparency" class="footer-link">Transparencia</a>
                </div>
                <div class="footer-column">
                    <h4 class="footer-heading">Plataforma</h4>
                    <a href="/dashboard-admin" class="footer-link">
                        <i class="ri-shield-keyhole-line"></i> Admin
                    </a>
                    <a href="https://status.quien-sabe.cl" class="footer-link" target="_blank" rel="noopener">
                        <i class="ri-heart-pulse-line"></i> Estado
                    </a>
                </div>
            </div>
        </div>

        <div class="footer-bottom">
            <div class="footer-bottom-container">
                <p class="footer-copyright">
                    &copy; 2026 Quién Sabe. Hecho en Chile 🇨🇱
                </p>
                <p class="footer-tech">
                    Powered by Cloudflare Workers + D1
                </p>
            </div>
        </div>
    </footer>

    <!-- Cookie Consent Modal -->
    <div id="cookie-modal" class="cookie-modal" role="dialog" aria-modal="true" aria-labelledby="cookie-title">
        <div class="cookie-backdrop"></div>
        <div class="cookie-card">
            <div class="cookie-icon">
                <i class="ri-cookie-line"></i>
            </div>
            <h2 id="cookie-title" class="cookie-title">Aviso de cookies</h2>
            <p class="cookie-desc">
                Usamos cookies para mejorar tu experiencia. Las técnicas son necesarias para el funcionamiento; las analytics son opcionales y nos ayudan a mejorar.
            </p>
            <div class="cookie-actions">
                <button id="cookie-reject" class="cookie-btn cookie-btn-secondary">Solo necesarias</button>
                <button id="cookie-accept" class="cookie-btn cookie-btn-primary">Aceptar todas</button>
            </div>
            <a href="/terminos" class="cookie-link">Leer política de cookies</a>
        </div>
    </div>

    <script>
        import { initLogout } from '../lib/client/auth/logout';
        initLogout();

        (function() {
            const modal = document.getElementById('cookie-modal');
            const acceptBtn = document.getElementById('cookie-accept');
            const rejectBtn = document.getElementById('cookie-reject');
            if (!modal || !acceptBtn || !rejectBtn) return;
            const consent = localStorage.getItem('cookie-consent');
            if (consent === 'accepted' || consent === 'rejected') return;
            modal.classList.add('cookie-modal-visible');
            acceptBtn.addEventListener('click', function() {
                localStorage.setItem('cookie-consent', 'accepted');
                modal.classList.remove('cookie-modal-visible');
            });
            rejectBtn.addEventListener('click', function() {
                localStorage.setItem('cookie-consent', 'rejected');
                modal.classList.remove('cookie-modal-visible');
            });
        })();
    </script>
</body>
</html>

<style>
    .page-body {
        background: var(--bg-page);
        color: var(--text-primary);
        font-family: 'Nunito', sans-serif;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
    }

    /* === NAVBAR === */
    .navbar {
        background: white;
        border-bottom: 1px solid var(--border-default);
        position: sticky;
        top: 0;
        z-index: 100;
        box-shadow: 0 1px 3px rgba(41, 37, 36, 0.04);
        overflow: hidden;
    }

    .nav-container {
        max-width: 1280px;
        margin: 0 auto;
        padding: 0.75rem 1rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        width: 100%;
        box-sizing: border-box;
    }

    .nav-brand {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        text-decoration: none;
    }

    .nav-logo {
        width: 2.5rem;
        height: 2.5rem;
        background: linear-gradient(135deg, var(--amber-500) 0%, var(--orange-600) 100%);
        border-radius: 0.625rem;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.25rem;
        box-shadow: 0 2px 4px rgba(249, 115, 22, 0.3);
    }

    .nav-brand-text {
        font-size: 1.375rem;
        font-weight: 800;
        color: var(--stone-800);
        letter-spacing: -0.02em;
    }

    .brand-accent {
        color: var(--amber-600);
    }

    .nav-actions {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-shrink: 0;
    }

    .nav-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        padding: 0.5rem 1rem;
        border-radius: var(--radius-lg);
        font-size: 0.875rem;
        font-weight: 700;
        text-decoration: none;
        transition: all 200ms ease;
        cursor: pointer;
        border: none;
    }

    .nav-btn-donate {
        background: var(--green-50);
        color: var(--green-700);
        border: 1px solid var(--green-200);
    }

    .nav-btn-donate:hover {
        background: var(--green-100);
        border-color: var(--green-300);
    }

    .nav-btn-outline {
        background: transparent;
        color: var(--stone-600);
        border: 1px solid var(--border-default);
    }

    .nav-btn-outline:hover {
        background: var(--stone-50);
        color: var(--stone-800);
        border-color: var(--stone-300);
    }

    .nav-btn-primary {
        background: linear-gradient(135deg, var(--orange-500) 0%, var(--orange-600) 100%);
        color: white;
        box-shadow: 0 2px 4px rgba(249, 115, 22, 0.3);
    }

    .nav-btn-primary:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 8px rgba(249, 115, 22, 0.4);
    }

    .nav-btn-user {
        background: var(--stone-100);
        color: var(--stone-700);
        border: 1px solid var(--stone-200);
    }

    .nav-btn-user:hover {
        background: var(--stone-200);
    }

    .nav-user-name {
        display: none;
    }

    @media (min-width: 640px) {
        .nav-user-name {
            display: inline;
        }
    }

    .nav-btn-logout {
        background: transparent;
        color: var(--stone-400);
        padding: 0.5rem;
        border: none;
    }

    .nav-btn-logout:hover {
        color: #ef4444;
        background: #fef2f2;
    }

    .nav-logout-form {
        margin: 0;
    }

    .nav-mobile-toggle {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 2.5rem;
        height: 2.5rem;
        background: var(--stone-100);
        border: none;
        border-radius: var(--radius-md);
        color: var(--stone-600);
        font-size: 1.25rem;
        cursor: pointer;
        transition: all 200ms ease;
    }

    .nav-mobile-toggle:hover {
        background: var(--stone-200);
        color: var(--stone-800);
    }

    @media (min-width: 768px) {
        .nav-mobile-toggle {
            display: none;
        }
    }

    /* === FOOTER === */
    .footer {
        background: linear-gradient(180deg, var(--stone-800) 0%, var(--stone-900) 100%);
        color: white;
        padding: 4rem 0 0;
        margin-top: auto;
        position: relative;
        overflow: hidden;
    }

    .footer-glow {
        position: absolute;
        top: 0;
        left: 50%;
        transform: translateX(-50%);
        width: 600px;
        max-width: 100vw;
        height: 300px;
        background: radial-gradient(ellipse at center, rgba(249, 115, 22, 0.12) 0%, transparent 70%);
        pointer-events: none;
    }

    .footer-container {
        max-width: 1280px;
        margin: 0 auto;
        padding: 0 1rem 3rem;
        display: grid;
        grid-template-columns: 1fr;
        gap: 3rem;
    }

    @media (min-width: 768px) {
        .footer-container {
            grid-template-columns: 1.5fr 2fr;
        }
    }

    .footer-brand {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .footer-logo {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 1.5rem;
        font-weight: 800;
        color: white;
    }

    .footer-logo i {
        font-size: 2rem;
        color: var(--amber-500);
    }

    .footer-tagline {
        color: var(--stone-400);
        font-size: 0.875rem;
        line-height: 1.6;
        max-width: 280px;
    }

    .footer-social {
        display: flex;
        gap: 0.75rem;
    }

    .footer-social-link {
        width: 2.5rem;
        height: 2.5rem;
        border-radius: var(--radius-lg);
        background: var(--stone-800);
        border: 1px solid var(--stone-700);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--stone-400);
        font-size: 1.125rem;
        transition: all 200ms ease;
        text-decoration: none;
    }

    .footer-social-link:hover {
        background: var(--amber-600);
        border-color: var(--amber-600);
        color: white;
        transform: translateY(-2px);
    }

    .footer-links {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
    }

    @media (max-width: 480px) {
        .footer-links {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    .footer-column {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .footer-heading {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--stone-400);
        margin-bottom: 0.25rem;
    }

    .footer-link {
        font-size: 0.875rem;
        color: var(--stone-300);
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 0.375rem;
        transition: all 200ms ease;
    }

    .footer-link:hover {
        color: var(--amber-400);
        transform: translateX(4px);
    }

    .footer-link i {
        font-size: 1rem;
    }

    .footer-bottom {
        border-top: 1px solid var(--stone-800);
        padding: 1.5rem 0;
    }

    .footer-bottom-container {
        max-width: 1280px;
        margin: 0 auto;
        padding: 0 1rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .footer-copyright {
        font-size: 0.75rem;
        color: var(--stone-500);
    }

    .footer-tech {
        font-size: 0.625rem;
        color: var(--stone-600);
    }

    /* === COOKIE MODAL === */
    .cookie-modal {
        position: fixed;
        inset: 0;
        z-index: 300;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
        opacity: 0;
        pointer-events: none;
        transition: opacity 300ms ease;
    }

    .cookie-modal.cookie-modal-visible {
        opacity: 1;
        pointer-events: all;
    }

    .cookie-backdrop {
        position: absolute;
        inset: 0;
        background: rgba(28, 25, 23, 0.6);
        backdrop-filter: blur(4px);
    }

    .cookie-card {
        position: relative;
        background: white;
        border-radius: var(--radius-2xl);
        box-shadow: var(--shadow-card-lifted);
        padding: 2rem;
        max-width: 26rem;
        width: 100%;
        text-align: center;
        transform: scale(0.9) translateY(16px);
        transition: transform 300ms ease;
    }

    .cookie-modal-visible .cookie-card {
        transform: scale(1) translateY(0);
    }

    .cookie-icon {
        width: 4rem;
        height: 4rem;
        border-radius: 50%;
        background: var(--amber-50);
        border: 2px solid var(--amber-200);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1rem;
        font-size: 1.75rem;
        color: var(--amber-600);
    }

    .cookie-title {
        font-size: 1.25rem;
        font-weight: 800;
        color: var(--text-primary);
        margin-bottom: 0.5rem;
    }

    .cookie-desc {
        font-size: 0.875rem;
        color: var(--text-secondary);
        line-height: 1.6;
        margin-bottom: 1.5rem;
    }

    .cookie-actions {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    @media (min-width: 480px) {
        .cookie-actions {
            flex-direction: row;
        }
    }

    .cookie-btn {
        flex: 1;
        padding: 0.75rem 1rem;
        border-radius: var(--radius-xl);
        font-size: 0.875rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 200ms ease;
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .cookie-btn-secondary {
        background: var(--stone-100);
        color: var(--stone-600);
        border: 1px solid var(--border-default);
    }

    .cookie-btn-secondary:hover {
        background: var(--stone-200);
        color: var(--stone-800);
    }

    .cookie-btn-primary {
        background: linear-gradient(135deg, var(--orange-500) 0%, var(--orange-600) 100%);
        color: white;
        box-shadow: var(--shadow-btn);
    }

    .cookie-btn-primary:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(249, 115, 22, 0.4);
    }

    .cookie-link {
        display: block;
        margin-top: 1rem;
        font-size: 0.75rem;
        color: var(--text-muted);
        text-decoration: underline;
    }

    .cookie-link:hover {
        color: var(--amber-600);
    }
</style>
