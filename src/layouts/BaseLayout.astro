---
const { title = "QuiénSabe - Conecta con oficios de tu barrio", description, image } = Astro.props;
import '../styles/base.css';

const currentUser = Astro.locals.user;
const isLoggedIn = Boolean(currentUser);
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content="Encuentra gasfíteres, electricistas y más oficios en tu comunidad.">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <meta property="og:title" content={title} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="QuiénSabe" />
    {description ? <meta property="og:description" content={description} /> : null}
    {image ? <meta property="og:image" content={image} /> : null}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description ? <meta name="twitter:description" content={description} /> : null}
    {image ? <meta name="twitter:image" content={image} /> : null}
</head>
<body class="bg-gray-50 text-gray-800 font-sans flex flex-col min-h-screen transition-all duration-300">

    <nav class="bg-white shadow-sm sticky top-0 z-50">
        <div class="container mx-auto px-4 py-3 flex justify-between items-center">
            <a href="/" class="text-2xl font-extrabold text-gray-800 flex items-center gap-2 tracking-tight">
                <i class="ri-community-line text-orange-500 text-3xl"></i>
                Quién<span class="text-orange-500">Sabe</span>
            </a>

            <div class="hidden md:flex items-center gap-3">
                {isLoggedIn && currentUser ? (
                    <>
                        <a href="/dashboard" class={`px-4 py-2 rounded-full font-bold text-sm transition ${currentPath.startsWith('/dashboard') ? 'bg-orange-100 text-orange-700' : 'text-gray-600 hover:bg-gray-100'}`}>
                            <i class="ri-user-line mr-1"></i> Hola, {currentUser.name.split(' ')[0]}
                        </a>
                        <form method="POST" action="/api/v1/auth/cerrar-sesion" class="contents js-logout-form" id="form-cerrar-sesion">
                            <button type="submit" class="text-gray-600 hover:text-red-500 px-3 py-2 rounded-full font-bold text-sm transition">
                                <i class="ri-logout-box-r-line"></i> Cerrar sesión
                            </button>
                        </form>
                    </>
                ) : (
                    <>
                        <a href="/donar" class="bg-orange-100 text-orange-500 hover:bg-orange-200 px-4 py-2 rounded-full font-bold text-sm transition flex items-center gap-2">
                            <i class="ri-heart-3-fill"></i> Donaciones
                        </a>
                        <a href="/iniciar-sesion" class="text-gray-600 hover:text-orange-500 px-4 py-2 rounded-full font-bold text-sm transition">
                            Ingresar
                        </a>
                        <a href="/registro" class="bg-gradient-to-r from-orange-500 to-orange-600 text-white px-6 py-2 rounded-full font-bold shadow-md hover:shadow-lg transform hover:-translate-y-0.5 transition duration-300">
                            Crear cuenta
                        </a>
                    </>
                )}
            </div>

            <button class="md:hidden text-gray-600 text-2xl">
                <i class="ri-menu-line"></i>
            </button>
        </div>
    </nav>

    <slot />

    <footer class="relative bg-gray-900 text-white py-12 text-center text-xs mt-12 overflow-hidden">
        <div class="absolute inset-0 z-0 bg-gradient-to-t from-gray-900 via-gray-900/80 to-gray-900/40"></div>
        <div class="container mx-auto px-4 flex flex-col md:flex-row justify-between items-center gap-6 relative z-10">
            <div class="text-left">
                <h4 class="text-xl font-extrabold text-white mb-1 flex items-center gap-2">
                    <i class="ri-community-line text-orange-500"></i> QuiénSabe
                </h4>
                <p class="text-gray-400 max-w-xs">Conectando barrios, un oficio a la vez. Construido con cariño para la comunidad.</p>
            </div>
            <div class="flex gap-8">
                <a href="/donar" class="hover:text-orange-500 transition font-bold text-gray-300 hover:scale-105 transform">Donaciones</a>
                <a href="/terminos" class="hover:text-orange-500 transition font-bold text-gray-300 hover:scale-105 transform">Términos</a>
                <a href="/transparency" class="hover:text-orange-500 transition font-bold text-gray-300 hover:scale-105 transform">Transparencia</a>
                <a href="/dashboard-admin" class="hover:text-orange-500 transition font-bold text-gray-300 hover:scale-105 transform"><i class="ri-shield-keyhole-line"></i> Admin</a>
            </div>
            <div class="text-right text-gray-500">
                <p class="font-bold">&copy; 2026 Quién Sabe.</p>
                <p class="text-[10px]">Hecho en Chile 🇨🇱</p>
            </div>
        </div>
    </footer>

    <!-- Cookie Consent Banner -->
    <div id="cookie-banner" class="fixed bottom-0 left-0 right-0 z-50 bg-gray-900 text-white p-4 shadow-2xl transition-all duration-500 translate-y-0" style="display:none">
        <div class="container mx-auto flex flex-col md:flex-row items-center justify-between gap-3">
            <p class="text-xs md:text-sm text-gray-300">Usamos cookies técnicas para el funcionamiento del sitio. Al navegar, aceptas su uso.</p>
            <button id="cookie-accept" class="bg-orange-500 hover:bg-orange-600 text-white px-6 py-2 rounded-full font-bold text-xs transition flex-shrink-0">
                Aceptar
            </button>
        </div>
    </div>

    <script>
        import { initLogout } from '../lib/client/auth/logout';
        initLogout();

        (function() {
            const banner = document.getElementById('cookie-banner');
            const acceptBtn = document.getElementById('cookie-accept');
            if (!banner || !acceptBtn) return;
            if (localStorage.getItem('cookie-consent') === 'accepted') return;
            banner.style.display = 'block';
            acceptBtn.addEventListener('click', function() {
                localStorage.setItem('cookie-consent', 'accepted');
                banner.classList.add('translate-y-full');
                setTimeout(function() { banner.style.display = 'none'; }, 500);
            });
        })();
    </script>
</body>
</html>