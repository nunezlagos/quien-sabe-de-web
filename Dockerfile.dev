FROM oven/bun:1.3.8

WORKDIR /app

# Dependencias del sistema mínimas (curl para healthchecks, git para algunos paquetes)
RUN apt-get update && apt-get install -y --no-install-recommends curl git bash && rm -rf /var/lib/apt/lists/*

# Instalar dependencias primero para cachear esta capa
COPY package.json bun.lock ./
RUN bun install

# El código fuente se monta como volume en docker-compose.dev.yml para hot reload.
# Esto sólo deja la imagen lista por si se levanta sin volume.
COPY . .

EXPOSE 4323

# Hot reload: Astro dev escucha en 0.0.0.0:4323.
# CHOKIDAR_USEPOLLING habilita watch confiable dentro de volúmenes Docker.
ENV CHOKIDAR_USEPOLLING=true
ENV WATCHPACK_POLLING=true
ENV HOST=0.0.0.0
ENV PORT=4323

CMD ["bun", "run", "dev"]
