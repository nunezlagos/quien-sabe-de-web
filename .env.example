# ==============================================================================
# App
# ==============================================================================
PUBLIC_SITE_URL=http://localhost:4323

# ==============================================================================
# MySQL (servicio `mysql` del docker-compose.yml)
# Estos valores se inyectan al container app y se usan para crear la DB.
# ==============================================================================
DB_USER=quiensabe
DB_PASSWORD=quiensabe
DB_NAME=quiensabe
MYSQL_ROOT_PASSWORD=quiensabe_root

# ==============================================================================
# MinIO (mock S3/R2 - servicio `minio` del docker-compose.yml)
# Desde el container app usa minio:9000 (red interna).
# Desde el host navega http://localhost:9003 para la consola.
# ==============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=quien-sabe-files
