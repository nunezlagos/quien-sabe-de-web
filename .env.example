# ==============================================================================
# Cloudflare
# ==============================================================================
D1_DATABASE_ID=your-database-id
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_API_TOKEN=your-api-token
R2_BUCKET_NAME=quien-sabe-files

# ==============================================================================
# App
# ==============================================================================
PUBLIC_SITE_URL=http://localhost:4323

# ==============================================================================
# Servicios dev (docker-compose.dev.yml)
# Estas variables las inyecta el compose, no es obligatorio definirlas a mano.
# Se listan acá como referencia para que las apunte el código en dev.
# ==============================================================================

# Mailpit (mock SES)
# Desde el container app: usar SMTP_HOST=mailpit (red interna)
# Desde el host:          usar SMTP_HOST=localhost SMTP_PORT=1028
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=

# MinIO (mock R2 / S3)
# Desde el container app: S3_ENDPOINT=http://minio:9000
# Desde el host:          S3_ENDPOINT=http://localhost:9002
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=quien-sabe-files
